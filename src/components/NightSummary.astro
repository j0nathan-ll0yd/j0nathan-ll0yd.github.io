---
const { health } = Astro.props;
const sleepScore = health.sleepScore;
const sleepDuration = health.sleepDurationFormatted;
const phases = health.sleepPhaseFormatted;
const derived = health.derived;

const pills = [
  { label: 'Deep', phase: 'deep', formatted: phases.deep, color: '#1e40af' },
  { label: 'REM', phase: 'rem', formatted: phases.rem, color: '#a855f7' },
  { label: 'Core', phase: 'core', formatted: phases.core, color: '#3a86ff' },
  { label: 'Awake', phase: 'awake', formatted: phases.awake, color: '#f59e0b' }
];
---
<div class="tri-card tri-card-accent-purple" id="cardSleep">
  <div class="widget-header">
    <span class="widget-label">Night Summary</span>
    <div class="widget-header-right">
      <div class="live-dot live-dot-purple"></div>
      <span class="widget-timestamp">last night</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
        <div class="skeleton-circle" style="width: 40px; height: 40px;"></div>
        <div class="skeleton-bar" style="width: 80px; height: 22px;"></div>
        <div class="skeleton-bar" style="width: 100%; height: 8px; border-radius: 4px;"></div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <div class="skeleton-bar" style="width: 60px; height: 22px; border-radius: 50px;"></div>
          <div class="skeleton-bar" style="width: 55px; height: 22px; border-radius: 50px;"></div>
          <div class="skeleton-bar" style="width: 65px; height: 22px; border-radius: 50px;"></div>
          <div class="skeleton-bar" style="width: 50px; height: 22px; border-radius: 50px;"></div>
        </div>
      </div>
    </div>
    <div class="sleep-moon-top">
      <div class="sleep-moon-wrap">
        <svg width="70" height="70" viewBox="0 0 80 80">
          <defs>
            <filter id="moonGlow">
              <feGaussianBlur stdDeviation="3" result="blur"/>
              <feMerge>
                <feMergeNode in="blur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>
          <circle cx="40" cy="40" r="28" fill="#a855f7" opacity="0.15" filter="url(#moonGlow)"/>
          <circle cx="40" cy="40" r="28" fill="none" stroke="#a855f7" stroke-width="1.5" opacity="0.4"/>
          <path d="M40,12 A28,28 0 1,1 40,68 A20,20 0 1,0 40,12" fill="#a855f7" opacity="0.3" filter="url(#moonGlow)"/>
          <circle cx="34" cy="30" r="3" fill="rgba(168,85,247,0.2)"/>
          <circle cx="48" cy="45" r="2" fill="rgba(168,85,247,0.15)"/>
        </svg>
      </div>
      <div class="sleep-moon-info">
        <div class="sleep-moon-hero" id="sleepDuration">{sleepDuration}</div>
        <div class="sleep-moon-score-row">
          <span class="sleep-moon-score-label">Score</span>
          <div class="sleep-moon-score-track">
            <div class="sleep-moon-score-fill" id="sleepScoreFill" style={`width: ${sleepScore}%`}></div>
          </div>
          <span class="sleep-moon-score-val" id="sleepScoreVal">{sleepScore}</span>
        </div>
      </div>
    </div>
    <div class="sleep-moon-pills">
      {pills.map((p, i) => (
        <div class="sleep-moon-pill" data-phase={p.phase} style={`background: ${p.color}15; animation-delay: ${i * 0.1 + 0.3}s`}>
          <div class="sleep-moon-pill-label">{p.label}</div>
          <div class="sleep-moon-pill-val" style={`color: ${p.color}`}>{p.formatted}</div>
        </div>
      ))}
    </div>
    <div class="sleep-moon-insight" id="sleepInsight">
      <span>{derived.deepPct}% deep</span> &mdash; <span>{derived.remPct}% REM</span> &mdash; restorative sleep
    </div>
  </div>
</div>
