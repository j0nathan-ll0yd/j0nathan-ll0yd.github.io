---
// Focus overlay — shown when currentFocus === 'Work' from the live API
// Activation is handled by live-data.ts via updateFocusOverlay().
// Starts hidden (display: none); JS sets display: flex when active.
---
<div id="focusOverlay">
  <div class="shift-badge">
    <span class="dot"></span>
    Shift Active
  </div>
  <div class="card">
    <div class="no-entry"></div>
    <div class="heading">Shift Active</div>
    <div class="subheading">
      Jonathan is currently heads-down at work. The dashboard will be available after hours.
    </div>
    <div class="divider"></div>
    <div class="clock-section">
      <span class="clock-label">Current Time (PST)</span>
      <span class="clock-time" id="focusClock">--:--:--</span>
      <span class="clock-zone">Pacific Standard Time</span>
    </div>
    <div class="schedule">
      <div class="schedule-block">
        <span class="schedule-label">Shift Start</span>
        <span class="schedule-value start">07:00</span>
      </div>
      <div class="schedule-block">
        <span class="schedule-label">Shift End</span>
        <span class="schedule-value end">15:00</span>
      </div>
    </div>
  </div>
</div>

<style>
  #focusOverlay {
    display: none;
    position: fixed;
    inset: 0;
    background: #06060f;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    font-family: 'Space Grotesk', sans-serif;
    color: #f0f0f0;
  }

  .shift-badge {
    position: fixed;
    top: 20px;
    right: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid rgba(239, 68, 68, 0.3);
    background: rgba(239, 68, 68, 0.08);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ef4444;
  }

  .shift-badge .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #ef4444;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .card {
    width: min(440px, 88vw);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    backdrop-filter: blur(16px);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .no-entry {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 4px solid #ef4444;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 30px rgba(239, 68, 68, 0.15);
  }

  .no-entry::after {
    content: '';
    width: 44px;
    height: 4px;
    background: #ef4444;
    border-radius: 2px;
  }

  .heading {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-align: center;
  }

  .subheading {
    font-size: 0.75rem;
    font-weight: 300;
    color: #9ca3af;
    text-align: center;
    line-height: 1.5;
    max-width: 320px;
  }

  .divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
  }

  .clock-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .clock-label {
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #9ca3af;
  }

  .clock-time {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
    color: #f59e0b;
  }

  .clock-zone {
    font-size: 0.6rem;
    font-weight: 400;
    color: #9ca3af;
    letter-spacing: 0.1em;
  }

  .schedule {
    display: flex;
    gap: 24px;
  }

  .schedule-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .schedule-label {
    font-size: 0.5rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #9ca3af;
  }

  .schedule-value {
    font-size: 0.8rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .schedule-value.start { color: #ef4444; }
  .schedule-value.end { color: #06d6a0; }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @media (max-width: 600px) {
    .card { padding: 32px 24px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shift-badge .dot { animation: none; opacity: 1; }
  }
</style>
