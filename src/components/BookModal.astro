---
---
<div class="book-overlay" id="bookOverlay" role="dialog" aria-modal="true" aria-label="Book details" aria-hidden="true">
  <div class="book-modal" id="bookModal"></div>
</div>

<script is:inline>
(function() {
  var overlay = document.getElementById('bookOverlay');
  var modal = document.getElementById('bookModal');
  if (!overlay || !modal) return;

  var triggerElement = null;

  var cardBooks = document.getElementById('cardBooks');
  if (cardBooks) {
    cardBooks.addEventListener('click', function(e) {
      var book = e.target.closest('.shelf-book[data-book]');
      if (book) {
        triggerElement = book;
        var data = JSON.parse(book.getAttribute('data-book'));
        openModal(data);
      }
    });
    cardBooks.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        var book = e.target.closest('.shelf-book[data-book]');
        if (book) {
          e.preventDefault();
          triggerElement = book;
          var data = JSON.parse(book.getAttribute('data-book'));
          openModal(data);
        }
      }
    });
  }

  function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function openModal(b) {
    var asin = b.asin;
    var cover = b.cover || ('https://m.media-amazon.com/images/P/' + asin + '.01._SCLZZZZZZZ_SX200_.jpg');

    var html = '<div class="book-modal-header">';
    html += '<img class="book-modal-cover" src="' + esc(cover) + '" width="80" height="120" alt="' + esc(b.title) + ' cover">';
    html += '<div class="book-modal-info">';
    if (b.series) html += '<div class="book-modal-series">' + esc(b.series) + '</div>';
    html += '<div class="book-modal-title">' + esc(b.title) + '</div>';
    html += '<div class="book-modal-author">' + esc(b.author) + '</div>';
    if (b.rating) {
      html += '<div class="book-modal-stars">';
      for (var s = 1; s <= 5; s++) {
        html += '<span class="' + (s <= b.rating ? 'star-on' : 'star-off') + '">' + (s <= b.rating ? '\u2605' : '\u2606') + '</span>';
      }
      html += '</div>';
    }
    html += '</div>';
    html += '<button class="book-modal-close" id="bookModalClose" aria-label="Close">&times;</button>';
    html += '</div>';

    html += '<div class="book-modal-body">';
    html += '<div class="book-modal-stats">';
    html += '<div class="book-modal-stat"><div class="book-modal-stat-val">' + (b.pages || '\u2014') + '</div><div class="book-modal-stat-label">Pages</div></div>';
    html += '<div class="book-modal-stat"><div class="book-modal-stat-val">' + (b.year || '\u2014') + '</div><div class="book-modal-stat-label">Published</div></div>';
    html += '<div class="book-modal-stat"><div class="book-modal-stat-val shelf-book-status shelf-status-' + b.status + '" style="font-size:0.7rem;margin:0">' + b.statusLabel + '</div><div class="book-modal-stat-label">Status</div></div>';
    html += '</div>';

    if (b.status === 'in_progress' && b.progress !== undefined) {
      html += '<div><div class="book-modal-progress"><div class="book-modal-progress-fill" style="width:' + b.progress + '%"></div></div>';
      html += '<div class="book-modal-progress-label">' + b.progress + '% complete</div></div>';
    }

    if (b.desc) html += '<div class="book-modal-desc">' + esc(b.desc) + '</div>';

    if (b.genres && b.genres.length) {
      html += '<div class="book-modal-tags">';
      b.genres.forEach(function(g) { html += '<span class="book-modal-tag">' + esc(g) + '</span>'; });
      html += '</div>';
    }

    if (b.status === 'completed' && b.notes) {
      html += '<div class="book-modal-notes">';
      html += '<div class="book-modal-notes-label">Notes</div>';
      html += '<div class="book-modal-notes-text">' + esc(b.notes) + '</div>';
      html += '</div>';
    }

    if (b.link) {
      html += '<div><a href="' + esc(b.link) + '" target="_blank" rel="noopener" class="book-modal-amazon">View on Amazon &rarr;</a></div>';
    }

    // Edit button (shown only when authenticated)
    var token = localStorage.getItem('portal_api_token');
    var apiUrl = localStorage.getItem('portal_api_url');
    if (token && apiUrl) {
      html += '<div style="margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.06)">';
      html += '<button class="book-modal-edit-btn" id="bookModalEdit" style="font:bold 11px/1 monospace;letter-spacing:2px;color:var(--neon-amber,#f5a623);background:rgba(245,166,35,0.1);border:1px solid rgba(245,166,35,0.2);padding:10px 20px;border-radius:8px;cursor:pointer;width:100%">EDIT METADATA</button>';
      html += '</div>';
    }
    html += '</div>';

    modal.innerHTML = html;
    overlay.classList.add('visible');
    overlay.setAttribute('aria-hidden', 'false');

    var closeBtn = document.getElementById('bookModalClose');
    closeBtn.addEventListener('click', function() {
      closeModal();
    });
    closeBtn.focus();

    // Wire up edit button
    var editBtn = document.getElementById('bookModalEdit');
    if (editBtn) {
      editBtn.addEventListener('click', function() {
        openEditMode(b);
      });
    }

    trapFocus(overlay);
  }

  function closeModal() {
    overlay.classList.remove('visible');
    overlay.setAttribute('aria-hidden', 'true');
    if (triggerElement) {
      triggerElement.focus();
      triggerElement = null;
    }
  }

  function trapFocus(container) {
    container.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeModal();
        return;
      }
      if (e.key !== 'Tab') return;

      var focusable = container.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
      if (!focusable.length) return;
      var first = focusable[0];
      var last = focusable[focusable.length - 1];

      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }

  function editField(label, name, value, type) {
    var inputType = type || 'text';
    return '<div style="margin-bottom:10px"><label style="display:block;font:bold 10px/1 monospace;letter-spacing:1px;color:rgba(255,255,255,0.4);margin-bottom:4px">' + esc(label) + '</label>' +
      '<input name="' + esc(name) + '" type="' + inputType + '" value="' + esc(value || '') + '" style="width:100%;box-sizing:border-box;font:14px monospace;color:#e0e0e0;background:rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:8px 12px"></div>';
  }

  function editTextarea(label, name, value) {
    return '<div style="margin-bottom:10px"><label style="display:block;font:bold 10px/1 monospace;letter-spacing:1px;color:rgba(255,255,255,0.4);margin-bottom:4px">' + esc(label) + '</label>' +
      '<textarea name="' + esc(name) + '" rows="4" style="width:100%;box-sizing:border-box;font:13px monospace;color:#e0e0e0;background:rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:8px 12px;resize:vertical">' + esc(value || '') + '</textarea></div>';
  }

  function openEditMode(b) {
    var html = '<div class="book-modal-header">';
    html += '<div class="book-modal-info" style="flex:1">';
    html += '<div style="font:bold 14px/1 monospace;letter-spacing:2px;color:var(--neon-amber,#f5a623);margin-bottom:8px">EDIT METADATA</div>';
    html += '</div>';
    html += '<button class="book-modal-close" id="bookModalClose" aria-label="Close">&times;</button>';
    html += '</div>';

    html += '<form id="bookEditForm" style="padding:0 4px">';
    html += editField('Title', 'title', b.title);
    html += editField('Series', 'series', b.series);
    html += '<div style="display:flex;gap:10px">';
    html += '<div style="flex:1">' + editField('Series #', 'seriesNumber', b.seriesNumber, 'number') + '</div>';
    html += '<div style="flex:1">' + editField('Series Total', 'seriesTotal', b.seriesTotal, 'number') + '</div>';
    html += '</div>';
    html += editTextarea('Description', 'description', b.desc);
    html += editField('Publication Date', 'publicationDate', b.publicationDate);
    html += editField('Publication Year', 'publicationYear', b.year, 'number');
    html += editField('Categories', 'category', b.genres ? b.genres.join(', ') : '');

    html += '<div style="display:flex;gap:10px;margin-top:16px">';
    html += '<button type="submit" style="flex:1;font:bold 12px/1 monospace;letter-spacing:2px;color:var(--neon-amber,#f5a623);background:rgba(245,166,35,0.15);border:1px solid rgba(245,166,35,0.3);padding:12px;border-radius:10px;cursor:pointer">SAVE</button>';
    html += '<button type="button" id="editCancel" style="flex:1;font:bold 12px/1 monospace;letter-spacing:2px;color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);padding:12px;border-radius:10px;cursor:pointer">CANCEL</button>';
    html += '</div>';
    html += '<div id="editStatus" style="margin-top:10px;font:12px monospace;text-align:center;min-height:18px"></div>';
    html += '</form>';

    modal.innerHTML = html;

    document.getElementById('bookModalClose').addEventListener('click', function() { closeModal(); });
    document.getElementById('editCancel').addEventListener('click', function() { openModal(b); });

    document.getElementById('bookEditForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var statusEl = document.getElementById('editStatus');
      statusEl.style.color = 'rgba(245,166,35,0.7)';
      statusEl.textContent = 'Saving...';

      var form = e.target;
      var payload = { asin: b.asin };
      var titleVal = form.elements.title.value.trim();
      if (titleVal) payload.title = titleVal;

      var seriesVal = form.elements.series.value.trim();
      payload.series = seriesVal || null;

      var snVal = form.elements.seriesNumber.value;
      payload.seriesNumber = snVal ? parseInt(snVal, 10) : null;

      var stVal = form.elements.seriesTotal.value;
      payload.seriesTotal = stVal ? parseInt(stVal, 10) : null;

      var descVal = form.elements.description.value.trim();
      payload.description = descVal || null;

      var pdVal = form.elements.publicationDate.value.trim();
      payload.publicationDate = pdVal || null;

      var pyVal = form.elements.publicationYear.value;
      payload.publicationYear = pyVal ? parseInt(pyVal, 10) : null;

      var catVal = form.elements.category.value.trim();
      payload.category = catVal || null;

      var apiUrl = localStorage.getItem('portal_api_url');
      var token = localStorage.getItem('portal_api_token');

      fetch(apiUrl + '/books/update', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token
        },
        body: JSON.stringify(payload)
      }).then(function(res) {
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      }).then(function() {
        statusEl.style.color = '#4ade80';
        statusEl.textContent = 'Saved! Reload to see changes.';
        setTimeout(function() { closeModal(); }, 1500);
      }).catch(function(err) {
        statusEl.style.color = '#f87171';
        statusEl.textContent = 'Error: ' + err.message;
      });
    });
  }

  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeModal();
  });
})();
</script>
