---
import { classifyHeartRate, buildECGPath, classifyHRV } from '../lib/heart-rate';

const { health } = Astro.props;
const hr = Math.round(health.quantities.heartRate.value);
const hrv = Math.round(health.quantities.hrvSDNN.value);

const state = classifyHeartRate(hr);
const ecgPath = buildECGPath(hr);
const { color: hrvColor, shadow: hrvShadow } = classifyHRV(hrv);
---
<div class={`tri-card ${state.accentClass}`} id="cardHR">
  <div class="widget-header">
    <span class="widget-label">Heart Rate</span>
    <div class="widget-header-right">
      <div class={`live-dot ${state.dotClass}`}></div>
      <span class="widget-timestamp">live</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div style="position: relative; min-height: 100px;">
        <div class="skeleton-bar" style="width: 100%; height: 60px; border-radius: 8px; margin-bottom: 12px;"></div>
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div class="skeleton-bar" style="width: 80px; height: 28px;"></div>
          <div class="skeleton-bar" style="width: 50px; height: 18px; border-radius: 50px;"></div>
        </div>
        <div style="display: flex; justify-content: flex-end; margin-top: 8px;">
          <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
        </div>
      </div>
    </div>
    <div class="hr-layout">
      <div class="hr-ecg-bg" id="hrEcgBg" style={`opacity: ${state.ecgOpacity}`}>
        <svg class="ecg-svg" id="hrEcgSvg" viewBox="0 0 800 100" preserveAspectRatio="none" style={`animation-duration: ${state.ecgSpeed}`}>
          <defs>
            <filter id="ecgGlow">
              <feGaussianBlur stdDeviation="2" result="blur"/>
              <feMerge>
                <feMergeNode in="blur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>
          <path class="ecg-line" id="hrEcgPath" d={ecgPath} style={`stroke: ${state.ecgStroke}`}/>
        </svg>
      </div>
      <div class="hr-overlay">
        <div class="hr-overlay-left">
          <div>
            <span class="pulse-bpm" id="pulseBpm" style={`color: ${state.bpmColor}; text-shadow: ${state.bpmShadow}`}>{hr}</span><span class="pulse-bpm-unit">BPM</span>
          </div>
          <span class="pulse-status-badge" id="hrZoneBadge" style={`color: ${state.badgeColor}; background: ${state.badgeBg}; border: 1px solid ${state.badgeBorder}`}>{state.zone}</span>
        </div>
        <div class="hr-overlay-right">
          <span class="hr-hrv-label">HRV</span>
          <span class="hr-hrv-value" id="hrHrvValue" style={`color: ${hrvColor}; text-shadow: ${hrvShadow}`}>{hrv}</span>
          <span class="hr-hrv-unit">ms</span>
        </div>
      </div>
    </div>
  </div>
</div>
