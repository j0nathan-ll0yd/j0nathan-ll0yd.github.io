---
// DND Privacy overlay — shown when currentFocus === 'Do Not Disturb' from the live API
// Activation is handled by live-data.ts via updateFocusOverlay().
// Starts hidden (display: none); JS sets display: flex when active.
---
<div id="dndOverlay">
  <div class="dnd-badge">
    <span class="dot"></span>
    Privacy Mode
  </div>

  <div class="shield-wrap">
    <div class="shield-fill"></div>
  </div>

  <div class="heading">Content Redacted</div>
  <div class="subheading">
    Do Not Disturb is active. Personal health, location, and activity data
    has been temporarily redacted to protect privacy during this session.
  </div>

  <div class="data-rows">
    <div class="data-row">
      <div class="data-row-text">Heart Rate: 72 BPM</div>
      <div class="data-row-blur"></div>
    </div>
    <div class="data-row">
      <div class="data-row-text">Location: San Francisco, CA</div>
      <div class="data-row-blur"></div>
    </div>
    <div class="data-row">
      <div class="data-row-text">Daily Steps: 8,421</div>
      <div class="data-row-blur"></div>
    </div>
    <div class="data-row">
      <div class="data-row-text">Sleep Duration: 7h 23m</div>
      <div class="data-row-blur"></div>
    </div>
    <div class="data-row">
      <div class="data-row-text">Status: Online</div>
      <div class="data-row-blur"></div>
    </div>
  </div>

  <div class="divider"></div>

  <div class="clock-section">
    <span class="clock-label">Current Time (PST)</span>
    <span class="clock-time" id="dndClock">--:--:--</span>
    <span class="clock-zone">Pacific Standard Time</span>
  </div>
</div>

<style>
  #dndOverlay {
    display: none;
    position: fixed;
    inset: 0;
    background: #06060f;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    font-family: 'Space Grotesk', sans-serif;
    color: #f0f0f0;
  }

  .dnd-badge {
    position: fixed;
    top: 20px;
    right: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid rgba(0, 212, 255, 0.3);
    background: rgba(0, 212, 255, 0.08);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #00d4ff;
  }

  .dnd-badge .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #00d4ff;
    animation: dnd-pulse-dot 2s ease-in-out infinite;
  }

  .shield-wrap {
    position: relative;
    width: 60px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shield-fill {
    position: absolute;
    inset: 0;
    clip-path: polygon(50% 100%, 0% 12%, 5% 0%, 95% 0%, 100% 12%);
    background: rgba(0, 212, 255, 0.15);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.15);
    animation: dnd-glow-pulse 4s ease-in-out infinite;
  }

  .heading {
    font-size: 1.3rem;
    font-weight: 700;
    color: #00d4ff;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-top: 24px;
    text-align: center;
  }

  .subheading {
    font-size: 0.75rem;
    font-weight: 300;
    color: #9ca3af;
    text-align: center;
    line-height: 1.5;
    max-width: 340px;
    margin-top: 12px;
  }

  .data-rows {
    margin-top: 24px;
    max-width: 360px;
    width: min(360px, 88vw);
  }

  .data-row {
    position: relative;
    margin-bottom: 6px;
  }

  .data-row-text {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
  }

  .data-row-blur {
    position: absolute;
    inset: 0;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background: rgba(0, 212, 255, 0.04);
    border-radius: 6px;
    border: 1px solid rgba(0, 212, 255, 0.1);
  }

  .divider {
    width: min(360px, 88vw);
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 24px 0;
  }

  .clock-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .clock-label {
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #9ca3af;
  }

  .clock-time {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
    color: #00d4ff;
  }

  .clock-zone {
    font-size: 0.6rem;
    font-weight: 400;
    color: #9ca3af;
    letter-spacing: 0.1em;
  }

  @keyframes dnd-pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @keyframes dnd-glow-pulse {
    0%, 100% { box-shadow: 0 0 20px rgba(0, 212, 255, 0.15); }
    50% { box-shadow: 0 0 35px rgba(0, 212, 255, 0.35); }
  }

  @media (max-width: 600px) {
    .heading { font-size: 1.1rem; }
    .data-row-text { font-size: 0.7rem; }
    #dndOverlay { padding: 24px 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dnd-badge .dot { animation: none; opacity: 1; }
    .shield-fill { animation: none; box-shadow: 0 0 20px rgba(0, 212, 255, 0.15); }
  }
</style>
