---
---
<div class="tri-card tri-card-accent-cyan" id="cardExplorationOdometer">
  <div class="widget-header">
    <h3 class="widget-label">Exploration</h3>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">all time</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div style="display: flex; gap: 12px;">
        <div class="skeleton-bar" style="width: 60px; height: 32px;"></div>
        <div class="skeleton-bar" style="width: 60px; height: 32px;"></div>
        <div class="skeleton-bar" style="width: 60px; height: 32px;"></div>
        <div class="skeleton-bar" style="width: 60px; height: 32px;"></div>
      </div>
    </div>
    <div class="odo-content">
      <div class="odo-stats">
        <div class="odo-stat">
          <span class="odo-value" data-loc="odo-visits">---</span>
          <span class="odo-label">Visits</span>
        </div>
        <div class="odo-stat">
          <span class="odo-value" data-loc="odo-places">---</span>
          <span class="odo-label">Places</span>
        </div>
        <div class="odo-stat">
          <span class="odo-value" data-loc="odo-cities">---</span>
          <span class="odo-label">Cities</span>
        </div>
        <div class="odo-stat">
          <span class="odo-value" data-loc="odo-states">---</span>
          <span class="odo-label">States</span>
        </div>
      </div>
      <div class="odo-subtitle" data-loc="odo-subtitle" style="display:none;"></div>
    </div>
  </div>
</div>

<style>
  .odo-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .odo-stats {
    display: flex;
    justify-content: space-around;
  }

  .odo-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .odo-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--neon-cyan, #00d4ff);
    text-shadow: 0 0 12px rgba(0, 212, 255, 0.5);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .odo-label {
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted, #9ca3af);
  }

  .odo-subtitle {
    font-size: 0.7rem;
    color: var(--text-muted, #9ca3af);
    text-align: center;
    margin-top: 8px;
    letter-spacing: 0.04em;
  }
</style>
