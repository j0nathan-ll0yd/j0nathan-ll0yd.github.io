---
// ContributionGraph.astro — GitHub-style 91-cell activity heatmap (13 weeks x 7 days)
// No raw coordinates — only visit frequency data
---
<div class="tri-card tri-card-accent-green" id="cardContributionGraph">
  <div class="widget-header">
    <h3 class="widget-label">Activity</h3>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">90d</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div class="cg-skeleton-grid">
        {Array.from({length: 91}).map(() => (
          <div class="skeleton-bar" style="width: 100%; height: 13px; border-radius: 2px;"></div>
        ))}
      </div>
      <div style="display: flex; gap: 8px; margin-top: 10px;">
        <div class="skeleton-bar" style="width: 60px; height: 12px;"></div>
        <div class="skeleton-bar" style="width: 80px; height: 12px;"></div>
      </div>
    </div>

    <div class="cg-content">
      <div class="cg-outer">
        <div class="cg-day-labels">
          <span class="cg-day-label">Mon</span>
          <span class="cg-day-label"></span>
          <span class="cg-day-label">Wed</span>
          <span class="cg-day-label"></span>
          <span class="cg-day-label">Fri</span>
          <span class="cg-day-label"></span>
          <span class="cg-day-label"></span>
        </div>
        <div class="cg-right">
          <div class="cg-month-row" data-loc="contrib-months">
            <span class="cg-month-label">Jan</span>
            <span class="cg-month-label">Feb</span>
            <span class="cg-month-label">Mar</span>
            <span class="cg-month-label">Apr</span>
            <span class="cg-month-label">May</span>
            <span class="cg-month-label">Jun</span>
            <span class="cg-month-label">Jul</span>
            <span class="cg-month-label">Aug</span>
            <span class="cg-month-label">Sep</span>
            <span class="cg-month-label">Oct</span>
            <span class="cg-month-label">Nov</span>
            <span class="cg-month-label">Dec</span>
            <span class="cg-month-label"></span>
          </div>
          <div class="cg-grid" data-loc="contrib-grid">
            {Array.from({length: 91}).map(() => (
              <div class="contrib-cell" style="opacity: 0.08;"></div>
            ))}
          </div>
        </div>
      </div>

      <div class="cg-stats-row">
        <div class="cg-stat">
          <span class="cg-stat-value" data-loc="contrib-total">—</span>
          <span class="cg-stat-label">visits (90d)</span>
        </div>
        <div class="cg-stat">
          <span class="cg-stat-value" data-loc="contrib-active-days">—</span>
          <span class="cg-stat-label">active days</span>
        </div>
        <div class="cg-legend">
          <span class="cg-legend-label">less</span>
          <div class="cg-legend-cell" style="opacity: 0.12;"></div>
          <div class="cg-legend-cell" style="opacity: 0.3;"></div>
          <div class="cg-legend-cell" style="opacity: 0.55;"></div>
          <div class="cg-legend-cell" style="opacity: 0.8;"></div>
          <div class="cg-legend-cell" style="opacity: 1;"></div>
          <span class="cg-legend-label">more</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .cg-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cg-outer {
    display: flex;
    gap: 4px;
    align-items: flex-start;
    overflow-x: auto;
  }

  .cg-day-labels {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 16px;
    flex-shrink: 0;
  }

  .cg-day-label {
    font-size: 0.55rem;
    color: var(--text-muted, rgba(255,255,255,0.4));
    height: 13px;
    line-height: 13px;
    text-align: right;
    min-width: 20px;
  }

  .cg-right {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .cg-month-row {
    display: grid;
    grid-template-columns: repeat(13, 1fr);
    gap: 2px;
    margin-bottom: 2px;
  }

  .cg-month-label {
    font-size: 0.55rem;
    color: var(--text-muted, rgba(255,255,255,0.4));
    text-align: left;
    line-height: 1;
    overflow: hidden;
    white-space: nowrap;
  }

  .cg-grid {
    display: grid;
    grid-template-columns: repeat(13, 1fr);
    grid-template-rows: repeat(7, 1fr);
    gap: 2px;
  }

  .contrib-cell {
    aspect-ratio: 1;
    min-height: 10px;
    max-height: 14px;
    border-radius: 2px;
    background-color: var(--neon-green, #00ff88);
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
    cursor: default;
  }

  .contrib-cell:hover {
    opacity: 1 !important;
    box-shadow: 0 0 6px rgba(0, 255, 136, 0.8);
  }

  .cg-skeleton-grid {
    display: grid;
    grid-template-columns: repeat(13, 1fr);
    grid-template-rows: repeat(7, 1fr);
    gap: 2px;
  }

  .cg-stats-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .cg-stat {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .cg-stat-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--neon-green, #00ff88);
    text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);
    line-height: 1;
  }

  .cg-stat-label {
    font-size: 0.6rem;
    color: var(--text-muted, rgba(255,255,255,0.4));
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cg-legend {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-left: auto;
  }

  .cg-legend-label {
    font-size: 0.55rem;
    color: var(--text-muted, rgba(255,255,255,0.4));
    margin: 0 2px;
  }

  .cg-legend-cell {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background-color: var(--neon-green, #00ff88);
  }
</style>
