---
---
<div class="tri-card tri-card-accent-blue is-loading" id="cardExplorationOdometerV3">
  <div class="widget-header">
    <h3 class="widget-label">Exploration</h3>
    <div class="widget-header-right">
      <div class="live-dot live-dot-blue"></div>
      <span class="widget-timestamp">since 3/2/26</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div style="display: flex; gap: 8px; margin-bottom: 12px;">
        <div class="skeleton-bar" style="flex: 1; height: 40px; border-radius: 4px;"></div>
        <div class="skeleton-bar" style="flex: 1; height: 40px; border-radius: 4px;"></div>
        <div class="skeleton-bar" style="flex: 1; height: 40px; border-radius: 4px;"></div>
        <div class="skeleton-bar" style="flex: 1; height: 40px; border-radius: 4px;"></div>
      </div>
      <div class="skeleton-bar" style="height: 24px; border-radius: 4px;"></div>
    </div>
    <div class="v3-content">
      <div class="v3-stats-row">
        <div class="v3-stat">
          <span class="v3-number" data-loc="odo-v3-visits">---</span>
          <span class="v3-label">Visits</span>
        </div>
        <div class="v3-divider" aria-hidden="true"></div>
        <div class="v3-stat">
          <span class="v3-number" data-loc="odo-v3-places">---</span>
          <span class="v3-label">Places</span>
        </div>
        <div class="v3-divider" aria-hidden="true"></div>
        <div class="v3-stat">
          <span class="v3-number" data-loc="odo-v3-cities">---</span>
          <span class="v3-label">Cities</span>
        </div>
        <div class="v3-divider" aria-hidden="true"></div>
        <div class="v3-stat">
          <span class="v3-number" data-loc="odo-v3-states">---</span>
          <span class="v3-label">States</span>
        </div>
      </div>
      <div class="v3-homebase">
        <div class="v3-homebase-left">
          <svg class="v3-home-icon" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M1 5.5L6 1L11 5.5V11H7.5V8H4.5V11H1V5.5Z" stroke="rgba(58,134,255,0.6)" stroke-width="1" stroke-linejoin="round"/>
          </svg>
          <span class="v3-city" data-loc="odo-v3-city">San Francisco</span>
        </div>
        <span class="v3-days" data-loc="odo-v3-days">---</span>
      </div>
    </div>
  </div>
</div>

<style>
  .v3-content {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .v3-stats-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .v3-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
  }

  .v3-divider {
    width: 1px;
    height: 28px;
    background: rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }

  .v3-number {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--neon-blue, #3a86ff);
    text-shadow: 0 0 10px rgba(58, 134, 255, 0.4);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .v3-label {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted, #9ca3af);
  }

  .v3-homebase {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 10px;
    border-top: 1px solid rgba(58, 134, 255, 0.12);
    font-size: var(--font-size-sm);
  }

  .v3-homebase-left {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .v3-home-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .v3-city {
    font-weight: 500;
    background: linear-gradient(90deg, #3a86ff, #60a5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .v3-days {
    color: rgba(255, 255, 255, 0.35);
  }
</style>
