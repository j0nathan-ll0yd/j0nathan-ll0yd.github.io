---
---
<div class="tri-card tri-card-accent-pink" id="cardPlaceLeaderboard">
  <div class="widget-header">
    <h3 class="widget-label">Top Places</h3>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">all time</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <div class="skeleton-bar" style="width: 100%; height: 20px;"></div>
        <div class="skeleton-bar" style="width: 100%; height: 20px;"></div>
        <div class="skeleton-bar" style="width: 100%; height: 20px;"></div>
        <div class="skeleton-bar" style="width: 100%; height: 20px;"></div>
        <div class="skeleton-bar" style="width: 100%; height: 20px;"></div>
      </div>
    </div>
    <div class="pl-content" data-loc="leaderboard-list">
      <div class="pl-row pl-placeholder">
        <span class="pl-rank">--</span>
        <span class="pl-name">---</span>
      </div>
    </div>
  </div>
</div>

<style>
  .pl-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pl-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .pl-rank {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--neon-pink, #ff006e);
    text-shadow: 0 0 6px rgba(255, 0, 110, 0.4);
    min-width: 18px;
    text-align: right;
    flex-shrink: 0;
  }

  .pl-name {
    flex: 1;
    color: var(--text, #f0f0f0);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pl-cat {
    font-size: 0.55rem;
    padding: 1px 6px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    border: 1px solid;
    opacity: 0.8;
  }

  .pl-bar-wrapper {
    width: 40px;
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .pl-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--neon-pink, #ff006e);
    transition: width 0.5s ease;
  }

  .pl-visits {
    font-size: 0.7rem;
    color: var(--neon-pink, #ff006e);
    font-weight: 600;
    min-width: 28px;
    text-align: right;
    flex-shrink: 0;
  }

  .pl-row:first-child .pl-rank,
  .pl-row:first-child .pl-visits {
    font-size: 0.8rem;
    text-shadow: 0 0 10px rgba(255, 0, 110, 0.6);
  }

  .pl-row:first-child .pl-name {
    font-weight: 600;
  }
</style>
