---
// WeeklyPulse.astro — ECG/heartbeat sparkline over 12 weeks
// No raw location data — only aggregated weekly visit counts
---
<div class="tri-card tri-card-accent-green" id="cardWeeklyPulse">
  <div class="widget-header">
    <h3 class="widget-label">Weekly Pulse</h3>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">12 weeks</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div class="skeleton-bar" style="width: 100%; height: 80px; border-radius: 4px;"></div>
      <div style="display: flex; gap: 16px; margin-top: 10px;">
        <div class="skeleton-bar" style="width: 100px; height: 12px;"></div>
        <div class="skeleton-bar" style="width: 80px; height: 12px;"></div>
      </div>
    </div>

    <div class="wp-content">
      <div class="wp-svg-wrapper">
        <svg
          class="wp-svg"
          viewBox="0 0 300 80"
          preserveAspectRatio="none"
          data-loc="pulse-svg"
          aria-hidden="true"
        >
          <!-- Faint grid lines -->
          <line x1="0" y1="20" x2="300" y2="20" class="wp-grid-line" />
          <line x1="0" y1="40" x2="300" y2="40" class="wp-grid-line" />
          <line x1="0" y1="60" x2="300" y2="60" class="wp-grid-line" />

          <!-- Glow fill under line -->
          <polyline
            class="wp-fill"
            data-loc="pulse-fill"
            points="0,80 300,80"
            fill="url(#pulseGradient)"
            stroke="none"
          />

          <!-- Main sparkline path -->
          <polyline
            class="wp-line"
            data-loc="pulse-path"
            points="0,80 300,80"
            fill="none"
            stroke="var(--neon-green, #00ff88)"
            stroke-width="2"
            stroke-linejoin="round"
            stroke-linecap="round"
          />

          <!-- Gradient definition for fill area -->
          <defs>
            <linearGradient id="pulseGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#00ff88" stop-opacity="0.2" />
              <stop offset="100%" stop-color="#00ff88" stop-opacity="0.0" />
            </linearGradient>
          </defs>
        </svg>
        <div class="wp-week-labels">
          {Array.from({length: 12}).map((_, i) => (
            <span class="wp-week-label">W{i + 1}</span>
          ))}
        </div>
      </div>

      <div class="wp-stats-row">
        <div class="wp-stat">
          <span class="wp-stat-label">This week</span>
          <span class="wp-stat-value" data-loc="pulse-current">—</span>
        </div>
        <div class="wp-divider"></div>
        <div class="wp-stat">
          <span class="wp-stat-label">Avg / week</span>
          <span class="wp-stat-value" data-loc="pulse-avg">—</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .wp-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .wp-svg-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .wp-svg {
    width: 100%;
    height: 80px;
    display: block;
    filter: drop-shadow(0 0 4px #00ff88);
    overflow: visible;
  }

  .wp-grid-line {
    stroke: rgba(255, 255, 255, 0.06);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .wp-line {
    filter: drop-shadow(0 0 3px rgba(0, 255, 136, 0.7));
  }

  .wp-week-labels {
    display: flex;
    justify-content: space-between;
    padding: 0 2px;
  }

  .wp-week-label {
    font-size: 0.55rem;
    color: var(--text-muted, rgba(255,255,255,0.4));
    text-align: center;
    flex: 1;
  }

  .wp-stats-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .wp-stat {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .wp-stat-label {
    font-size: 0.6rem;
    color: var(--text-muted, rgba(255,255,255,0.4));
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .wp-stat-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--neon-green, #00ff88);
    text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);
    line-height: 1;
  }

  .wp-divider {
    width: 1px;
    height: 28px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }
</style>
