---
const { profile } = Astro.props;
---
<div class="identity-card" id="identityCard">
  <img class="id-avatar" src={profile.avatar} alt="Jonathan Lloyd">
  <div class="id-info-inline">
    <div class="id-name">{profile.name}</div>
    <div class="id-title">{profile.title}</div>
  </div>
  <div class="id-bio">{profile.bio}</div>
  <nav class="id-links" aria-label="Social">
    <a href={profile.github} class="neon-pill" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={profile.linkedin} class="neon-pill" target="_blank" rel="noopener noreferrer">LinkedIn</a>
  </nav>
</div>
<script is:inline>
(function() {
  var links = document.querySelectorAll('.id-links a');
  for (var i = 0; i < links.length; i++) {
    links[i].addEventListener('click', function(e) {
      var label = e.currentTarget.textContent.trim().toLowerCase();
      if (typeof window.sa_event === 'function') {
        window.sa_event('social_click', { platform: label });
      }
    });
  }
})();
</script>
