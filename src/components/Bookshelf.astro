---
const { books } = Astro.props;
const bookList = books.books;
const bookMeta = books.bookMeta;
const statusLabels = books.statusLabels;

const statusOrder: Record<string, number> = { in_progress: 0, next: 1, completed: 2 };
const sortedBooks = bookList.slice().sort((a: any, b: any) => {
  return (statusOrder[a.status] ?? 99) - (statusOrder[b.status] ?? 99);
});
const displayBooks = sortedBooks.slice(0, 5);
---
<div class="tri-card tri-card-accent-amber" id="cardBooks">
  <div class="widget-header">
    <h3 class="widget-label">Bookshelf</h3>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">library</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div style="display: flex; gap: 16px;">
        <div style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
          <div class="skeleton-bar" style="width: 80px; height: 120px; border-radius: 4px;"></div>
          <div class="skeleton-bar" style="width: 64px; height: 10px;"></div>
          <div class="skeleton-bar" style="width: 48px; height: 8px;"></div>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
          <div class="skeleton-bar" style="width: 80px; height: 120px; border-radius: 4px;"></div>
          <div class="skeleton-bar" style="width: 56px; height: 10px;"></div>
          <div class="skeleton-bar" style="width: 44px; height: 8px;"></div>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
          <div class="skeleton-bar" style="width: 80px; height: 120px; border-radius: 4px;"></div>
          <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
          <div class="skeleton-bar" style="width: 50px; height: 8px;"></div>
        </div>
      </div>
    </div>
    <div class="shelf-row" id="dashShelfRow">
      {displayBooks.map((b: any, i: number) => {
        const asin = b.asin || b.isbn;
        const coverSrc = `https://m.media-amazon.com/images/P/${asin}.01._SCLZZZZZZZ_SX200_.jpg`;
        const meta = bookMeta[asin] || {};
        const bookData = JSON.stringify({
          title: b.title,
          author: b.author,
          asin: asin,
          status: b.status,
          statusLabel: statusLabels[b.status],
          rating: b.rating,
          progress: b.progress,
          link: `https://www.amazon.com/dp/${asin}?tag=lifegames04-20&linkCode=ll2&language=en_US&ref_=as_li_ss_tl`,
          notes: b.notes || null,
          series: meta.series || null,
          seriesNumber: meta.seriesNumber || null,
          seriesTotal: meta.seriesTotal || null,
          pages: meta.pages || null,
          year: meta.year || null,
          publicationDate: meta.publicationDate || null,
          desc: meta.desc || null,
          genres: meta.genres || [],
          cover: meta.cover || null
        });
        return (
          <div class={`shelf-book${b.status === 'in_progress' ? ' shelf-book-active' : ''}`} style={`animation-delay: ${i * 0.08}s`} data-book={bookData} tabindex="0" role="button" aria-label={`${b.title} by ${b.author}`}>
            <div class="shelf-cover-wrapper">
              <img src={coverSrc} width="80" height="120" alt={b.title} loading="lazy">
            </div>
            <div class="shelf-book-title"><span>{b.title}</span></div>
            <div class="shelf-book-author">{b.author}</div>
            {b.status === 'in_progress' ? (
              <Fragment>
                <div class="shelf-book-status shelf-status-in_progress">READING</div>
                {b.progress != null && (
                  <div class="shelf-book-progress">{b.progress}% COMPLETE</div>
                )}
              </Fragment>
            ) : (
              <Fragment>
                <div class={`shelf-book-status shelf-status-${b.status}`}>{statusLabels[b.status]}</div>
                {b.rating && (
                  <div class="shelf-book-stars">
                    {[1,2,3,4,5].map((s: number) => (
                      <span class={s <= b.rating ? 'star-on' : 'star-off'}>{s <= b.rating ? '\u2605' : '\u2606'}</span>
                    ))}
                  </div>
                )}
              </Fragment>
            )}
          </div>
        );
      })}
    </div>
  </div>
</div>
