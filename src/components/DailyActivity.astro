---
const { health } = Astro.props;
const q = health.quantities;
const totalCalories = Math.round(health.derived.totalCalories);
---
<div class="tri-card tri-card-accent-green" id="cardSteps">
  <div class="widget-header">
    <h3 class="widget-label">Daily Activity</h3>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">today</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="skeleton-state">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <div style="display: flex; flex-direction: column; gap: 10px;">
          <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
          <div class="skeleton-bar" style="width: 80px; height: 20px;"></div>
          <div class="skeleton-bar" style="width: 50px; height: 10px;"></div>
          <div class="skeleton-bar" style="width: 70px; height: 20px;"></div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          <div class="skeleton-bar" style="width: 55px; height: 10px;"></div>
          <div class="skeleton-bar" style="width: 75px; height: 20px;"></div>
          <div class="skeleton-bar" style="width: 45px; height: 10px;"></div>
          <div class="skeleton-bar" style="width: 85px; height: 20px;"></div>
        </div>
      </div>
    </div>
    <div class="split-cols">
      <div class="split-col">
        <div class="split-col-title">Movement</div>
        <div class="split-metric">
          <div class="split-metric-label">Steps</div>
          <div class="split-metric-value" data-metric="steps">{Math.round(q.stepCount.value).toLocaleString()}</div>
        </div>
        <div class="split-metric">
          <div class="split-metric-label">Distance</div>
          <div class="split-metric-value" data-metric="distance">{Math.round(q.distanceWalkingRunning.value)}<span class="split-metric-unit">m</span></div>
        </div>
        <div class="split-metric">
          <div class="split-metric-label">Exercise</div>
          <div class="split-metric-value" data-metric="exercise">{q.exerciseTime.value}<span class="split-metric-unit">min</span></div>
        </div>
      </div>
      <div class="split-col">
        <div class="split-col-title">Energy</div>
        <div class="split-metric">
          <div class="split-metric-label">Active</div>
          <div class="split-metric-value" data-metric="active">{Math.round(q.activeEnergyBurned.value)}<span class="split-metric-unit">kcal</span></div>
        </div>
        <div class="split-metric">
          <div class="split-metric-label">Basal</div>
          <div class="split-metric-value" data-metric="basal">{Math.round(q.basalEnergyBurned.value)}<span class="split-metric-unit">kcal</span></div>
        </div>
        <div class="split-metric">
          <div class="split-metric-label">Total</div>
          <div class="split-metric-value" data-metric="total">{totalCalories}<span class="split-metric-unit">kcal</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
