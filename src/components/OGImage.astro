---
interface Props {
  avatarUrl: string;
  name?: string;
  title?: string;
  quote?: string;
  experience?: string;
}

const {
  avatarUrl,
  name = 'Jonathan Lloyd',
  title = 'ENGINEERING DIRECTOR',
  quote = '"Enjoying the passage of time"',
  experience = '24+ years professionally & counting',
} = Astro.props;
---
<svg viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
  <defs>
    <clipPath id="ogAvatarClip"><circle cx="200" cy="315" r="100"/></clipPath>
    <linearGradient id="ogGrad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#ff006e"/>
      <stop offset="50%" stop-color="#3a86ff"/>
      <stop offset="100%" stop-color="#06d6a0"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="#06060f"/>
  <!-- Top & bottom gradient lines -->
  <rect x="0" y="0" width="1200" height="2" fill="url(#ogGrad)"/>
  <rect x="0" y="628" width="1200" height="2" fill="url(#ogGrad)"/>
  <!-- Large avatar -->
  <circle cx="200" cy="315" r="104" fill="none" stroke="#ff006e" stroke-width="1.5" opacity="0.25"/>
  <circle cx="200" cy="315" r="110" fill="none" stroke="#ff006e" stroke-width="0.5" opacity="0.1"/>
  <image href={avatarUrl} x="100" y="215" width="200" height="200" clip-path="url(#ogAvatarClip)" preserveAspectRatio="xMidYMid slice"/>
  <!-- Name and title -->
  <text x="200" y="460" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="28" font-weight="700" fill="#f0f0f0">{name}</text>
  <text x="200" y="488" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="12" font-weight="400" fill="#ff006e" letter-spacing="3">{title}</text>
  <!-- Divider -->
  <line x1="380" y1="80" x2="380" y2="550" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
  <!-- Right side: clean metric blocks -->
  <g transform="translate(440, 100)">
    <!-- HUMAN DATASTREAM label -->
    <text x="0" y="0" font-family="Space Grotesk, sans-serif" font-size="11" fill="#9ca3af" letter-spacing="6">HUMAN DATASTREAM</text>
    <!-- Metric grid: 3x2 -->
    <g transform="translate(0, 40)">
      <text x="0" y="0" font-family="Space Grotesk, sans-serif" font-size="9" fill="#9ca3af" letter-spacing="2">HEART RATE</text>
      <text x="0" y="36" font-family="Space Grotesk, sans-serif" font-size="44" font-weight="700" fill="#f59e0b">58</text>
      <text x="60" y="36" font-family="Space Grotesk, sans-serif" font-size="16" fill="#9ca3af">BPM</text>

      <text x="240" y="0" font-family="Space Grotesk, sans-serif" font-size="9" fill="#9ca3af" letter-spacing="2">SLEEP</text>
      <text x="240" y="36" font-family="Space Grotesk, sans-serif" font-size="44" font-weight="700" fill="#a855f7">7h 24m</text>

      <text x="500" y="0" font-family="Space Grotesk, sans-serif" font-size="9" fill="#9ca3af" letter-spacing="2">STEPS</text>
      <text x="500" y="36" font-family="Space Grotesk, sans-serif" font-size="44" font-weight="700" fill="#ff006e">6,842</text>
    </g>

    <g transform="translate(0, 140)">
      <text x="0" y="0" font-family="Space Grotesk, sans-serif" font-size="9" fill="#9ca3af" letter-spacing="2">CONTRIBUTIONS</text>
      <text x="0" y="36" font-family="Space Grotesk, sans-serif" font-size="44" font-weight="700" fill="#06d6a0">1,847</text>

      <text x="240" y="0" font-family="Space Grotesk, sans-serif" font-size="9" fill="#9ca3af" letter-spacing="2">REPOSITORIES</text>
      <text x="240" y="36" font-family="Space Grotesk, sans-serif" font-size="44" font-weight="700" fill="#3a86ff">42</text>

      <text x="500" y="0" font-family="Space Grotesk, sans-serif" font-size="9" fill="#9ca3af" letter-spacing="2">HYDRATION</text>
      <text x="500" y="36" font-family="Space Grotesk, sans-serif" font-size="44" font-weight="700" fill="#3a86ff">74 <tspan font-size="18" fill="#9ca3af">oz</tspan></text>
    </g>

    <!-- Languages -->
    <g transform="translate(0, 260)">
      <rect x="0" y="0" width="700" height="6" rx="3" fill="rgba(255,255,255,0.06)"/>
      <rect x="0" y="0" width="280" height="6" rx="3" fill="#f59e0b" opacity="0.6"/>
      <rect x="280" y="0" width="194" height="6" fill="#3a86ff" opacity="0.6"/>
      <rect x="474" y="0" width="94" height="6" fill="#06d6a0" opacity="0.6"/>
      <rect x="568" y="0" width="56" height="6" fill="#ff006e" opacity="0.6"/>
      <rect x="624" y="0" width="36" height="6" fill="#a855f7" opacity="0.6"/>

      <text x="0" y="24" font-family="Space Grotesk, sans-serif" font-size="10" fill="#f59e0b">JavaScript</text>
      <text x="100" y="24" font-family="Space Grotesk, sans-serif" font-size="10" fill="#3a86ff">TypeScript</text>
      <text x="200" y="24" font-family="Space Grotesk, sans-serif" font-size="10" fill="#06d6a0">Python</text>
      <text x="275" y="24" font-family="Space Grotesk, sans-serif" font-size="10" fill="#ff006e">Swift</text>
      <text x="330" y="24" font-family="Space Grotesk, sans-serif" font-size="10" fill="#a855f7">Go</text>
    </g>

    <!-- Quote -->
    <text x="0" y="340" font-family="Space Grotesk, sans-serif" font-size="15" fill="rgba(255,255,255,0.25)" font-style="italic">{quote}</text>
    <text x="0" y="370" font-family="monospace" font-size="11" fill="#9ca3af">{experience}</text>
  </g>
</svg>
