---
interface Repo {
  owner: string;
  name: string;
  description: string;
  stars: number;
  language: string;
  languageColor: string;
  starredAt: string;
}

interface Props {
  repos: Repo[];
}

const { repos } = Astro.props;
---

<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Starred Timeline</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">activity</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-star-tl">
      <div class="gh-stl-line"></div>
      {repos.map((repo: Repo) => (
        <div class="gh-stl-item">
          <div class="gh-stl-date">{repo.starredAt}</div>
          <div class="gh-stl-dot" style={`background: ${repo.languageColor}; box-shadow: 0 0 8px ${repo.languageColor};`}></div>
          <div class="gh-stl-content">
            <div class="gh-stl-name">
              <span class="gh-stl-owner">{repo.owner}/</span>{repo.name}
            </div>
            <div class="gh-stl-desc">{repo.description}</div>
            <div class="gh-stl-meta">
              <span class="gh-stl-lang">
                <span class="gh-stl-lang-dot" style={`background: ${repo.languageColor};`}></span>
                {repo.language}
              </span>
              <span class="gh-stl-stars">&#9733; {repo.stars.toLocaleString()}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .gh-star-tl {
    position: relative;
    padding-left: 90px;
  }

  .gh-stl-line {
    position: absolute;
    left: 82px;
    top: 4px;
    bottom: 4px;
    width: 1px;
    background: linear-gradient(180deg, rgba(6, 214, 160, 0.4), rgba(6, 214, 160, 0.08));
  }

  .gh-stl-item {
    position: relative;
    padding-bottom: 16px;
  }

  .gh-stl-item:last-child {
    padding-bottom: 0;
  }

  .gh-stl-date {
    position: absolute;
    left: -86px;
    top: 2px;
    width: 74px;
    text-align: right;
    font-size: 0.54rem;
    font-family: 'Space Grotesk', monospace;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .gh-stl-dot {
    position: absolute;
    left: -12px;
    top: 4px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .gh-stl-content {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding-left: 4px;
  }

  .gh-stl-name {
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--neon-green);
    text-shadow: 0 0 6px rgba(6, 214, 160, 0.3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-stl-owner {
    color: rgba(6, 214, 160, 0.5);
    font-weight: 400;
  }

  .gh-stl-desc {
    font-size: 0.6rem;
    color: var(--text-muted);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-stl-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 1px;
  }

  .gh-stl-lang {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.54rem;
    color: var(--text-muted);
  }

  .gh-stl-lang-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gh-stl-stars {
    font-size: 0.54rem;
    font-family: 'Space Grotesk', monospace;
    color: var(--neon-amber);
    text-shadow: 0 0 6px rgba(245, 158, 11, 0.25);
  }
</style>
