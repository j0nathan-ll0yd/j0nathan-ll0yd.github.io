---
interface Event {
  type: string;
  repo: string;
  title: string;
  date: string;
  detail: string;
}

interface Props {
  events: Event[];
}

const { events } = Astro.props;

const iconMap: Record<string, { symbol: string; colorClass: string }> = {
  'pushed':       { symbol: '\u2192', colorClass: 'gh-act-icon-green' },
  'opened PR':    { symbol: '\u2295', colorClass: 'gh-act-icon-blue' },
  'opened issue': { symbol: '\u25C9', colorClass: 'gh-act-icon-amber' },
  'starred':      { symbol: '\u2605', colorClass: 'gh-act-icon-pink' },
  'created':      { symbol: '+',      colorClass: 'gh-act-icon-green' },
};

function getIcon(type: string) {
  return iconMap[type] || { symbol: '\u00B7', colorClass: 'gh-act-icon-green' };
}
---

<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Activity Feed</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">recent</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-activity">
      {events.map((event) => {
        const icon = getIcon(event.type);
        return (
          <div class="gh-act-item">
            <span class={`gh-act-icon ${icon.colorClass}`}>{icon.symbol}</span>
            <div class="gh-act-content">
              <div class="gh-act-top-row">
                <span class="gh-act-repo">{event.repo}</span>
                <span class="gh-act-date">{event.date}</span>
              </div>
              <div class="gh-act-bottom-row">
                <span class="gh-act-title">{event.title}</span>
                {event.detail && <span class="gh-act-detail">{event.detail}</span>}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>

<style>
  .gh-activity {
    display: flex;
    flex-direction: column;
  }

  .gh-act-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .gh-act-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .gh-act-item:first-child {
    padding-top: 0;
  }

  .gh-act-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
    margin-top: 1px;
  }

  .gh-act-icon-green {
    color: var(--neon-green);
  }

  .gh-act-icon-blue {
    color: var(--neon-blue);
  }

  .gh-act-icon-amber {
    color: var(--neon-amber);
  }

  .gh-act-icon-pink {
    color: var(--neon-pink);
  }

  .gh-act-content {
    flex: 1;
    min-width: 0;
  }

  .gh-act-top-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .gh-act-repo {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-act-date {
    font-size: 0.55rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .gh-act-bottom-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 2px;
  }

  .gh-act-title {
    font-size: 0.6rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-act-detail {
    font-size: 0.5rem;
    color: var(--neon-green);
    opacity: 0.7;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
