---
interface Event {
  type: 'commit' | 'pr_opened' | 'pr_closed' | 'pr_merged' | 'issue_opened' | 'issue_closed';
  repo: string;
  title: string;
  date: string;
  hash?: string;
  additions?: number;
  deletions?: number;
  number?: number;
}

interface Props {
  events: Event[];
}

const { events } = Astro.props;

const iconMap: Record<string, { symbol: string; color: string; label: string }> = {
  'commit':       { symbol: '\u2192', color: 'var(--neon-green)',  label: 'PUSHED' },
  'pr_opened':    { symbol: '\u2295', color: 'var(--neon-blue)',   label: 'PR OPENED' },
  'pr_closed':    { symbol: '\u2296', color: 'var(--neon-blue)',   label: 'PR CLOSED' },
  'pr_merged':    { symbol: '\u229E', color: 'var(--neon-blue)',   label: 'PR MERGED' },
  'issue_opened': { symbol: '\u25C9', color: 'var(--neon-amber)',  label: 'ISSUE' },
  'issue_closed': { symbol: '\u2714', color: 'var(--neon-amber)',  label: 'CLOSED' },
};

function getIcon(type: string) {
  return iconMap[type] || { symbol: '\u00B7', color: 'var(--neon-green)', label: 'EVENT' };
}
---
<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Dev Timeline</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">recent</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-dat-timeline">
      <div class="gh-dat-line"></div>
      {events.map((event: Event) => {
        const icon = getIcon(event.type);
        return (
          <div class="gh-dat-item">
            <div class="gh-dat-dot" style={`background: ${icon.color}; box-shadow: 0 0 8px ${icon.color};`}></div>
            <div class="gh-dat-content">
              <span class="gh-dat-title">{event.title}</span>
              <div class="gh-dat-meta">
                <span class="gh-dat-badge" style={`background: ${icon.color}15; border-color: ${icon.color}40; color: ${icon.color};`}>
                  {icon.symbol} {icon.label}
                </span>
                <span class="gh-dat-repo">{event.repo}</span>
                <span class="gh-dat-date">{event.date}</span>
              </div>
              {event.type === 'commit' && event.hash && (
                <div class="gh-dat-commit-detail">
                  <span class="gh-dat-hash">{event.hash}</span>
                  <span class="gh-dat-additions">+{event.additions || 0}</span>
                  <span class="gh-dat-deletions">-{event.deletions || 0}</span>
                </div>
              )}
              {event.type !== 'commit' && event.number !== undefined && (
                <div class="gh-dat-ref">#{event.number}</div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>

<style>
  .gh-dat-timeline {
    position: relative;
    padding-left: 20px;
  }

  .gh-dat-line {
    position: absolute;
    left: 5px;
    top: 4px;
    bottom: 4px;
    width: 1px;
    background: linear-gradient(180deg, rgba(6, 214, 160, 0.4), rgba(6, 214, 160, 0.08));
  }

  .gh-dat-item {
    position: relative;
    padding-bottom: 14px;
    display: flex;
    align-items: flex-start;
  }

  .gh-dat-item:last-child {
    padding-bottom: 0;
  }

  .gh-dat-dot {
    position: absolute;
    left: -18px;
    top: 4px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gh-dat-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .gh-dat-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-dat-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .gh-dat-badge {
    display: inline-block;
    font-size: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 2px 8px;
    border-radius: 10px;
    border: 1px solid;
    white-space: nowrap;
  }

  .gh-dat-repo {
    font-size: 0.58rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-dat-date {
    font-size: 0.58rem;
    font-family: 'Space Grotesk', monospace;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.5px;
    white-space: nowrap;
    margin-left: auto;
  }

  .gh-dat-commit-detail {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Space Grotesk', monospace;
    font-size: 0.58rem;
  }

  .gh-dat-hash {
    color: var(--neon-green);
    text-shadow: 0 0 6px rgba(6, 214, 160, 0.3);
  }

  .gh-dat-additions {
    color: var(--neon-green);
  }

  .gh-dat-deletions {
    color: #ef4444;
  }

  .gh-dat-ref {
    font-size: 0.58rem;
    font-family: 'Space Grotesk', monospace;
    color: var(--text-muted);
    opacity: 0.7;
  }
</style>
