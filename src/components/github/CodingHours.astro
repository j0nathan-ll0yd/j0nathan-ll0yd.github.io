---
interface Props {
  grid: number[][];
}

const { grid } = Astro.props;

const dayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const hourLabels = [0, 3, 6, 9, 12, 15, 18, 21];
---
<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Coding Hours</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">this week</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-punch-card">
      {grid.map((row: number[], dayIndex: number) => (
        <div class="gh-pc-row">
          <span class="gh-pc-label">{dayLabels[dayIndex]}</span>
          <div class="gh-pc-cells">
            {row.map((level: number) => (
              <div class="gh-pc-cell" data-level={level}></div>
            ))}
          </div>
        </div>
      ))}
      <div class="gh-pc-hours">
        <span class="gh-pc-label"></span>
        <div class="gh-pc-hour-labels">
          {hourLabels.map((h: number) => (
            <span class="gh-pc-hour" style={`left: calc(${(h / 24) * 100}%);`}>{h}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .gh-punch-card {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .gh-pc-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .gh-pc-label {
    width: 28px;
    flex-shrink: 0;
    font-size: 0.5rem;
    font-family: 'Space Grotesk', monospace;
    color: var(--text-muted);
    letter-spacing: 0.5px;
    text-align: right;
  }

  .gh-pc-cells {
    display: flex;
    gap: 2px;
    flex: 1;
  }

  .gh-pc-cell {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .gh-pc-cell[data-level="0"] {
    background: rgba(6, 214, 160, 0.05);
  }

  .gh-pc-cell[data-level="1"] {
    background: rgba(6, 214, 160, 0.2);
  }

  .gh-pc-cell[data-level="2"] {
    background: rgba(6, 214, 160, 0.4);
    box-shadow: 0 0 3px rgba(6, 214, 160, 0.15);
  }

  .gh-pc-cell[data-level="3"] {
    background: rgba(6, 214, 160, 0.65);
    box-shadow: 0 0 4px rgba(6, 214, 160, 0.25);
  }

  .gh-pc-cell[data-level="4"] {
    background: var(--neon-green);
    box-shadow: 0 0 6px rgba(6, 214, 160, 0.4);
  }

  .gh-pc-hours {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
  }

  .gh-pc-hour-labels {
    position: relative;
    flex: 1;
    height: 12px;
  }

  .gh-pc-hour {
    position: absolute;
    top: 0;
    font-size: 0.42rem;
    font-family: 'Space Grotesk', monospace;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.5px;
    transform: translateX(-50%);
  }
</style>
