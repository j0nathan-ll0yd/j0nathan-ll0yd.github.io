---
interface Props {
  totalContributions: number;
  topLanguage: string;
  mostActiveMonth: string;
  reposCreated: number;
  longestStreak: number;
}

const { totalContributions, topLanguage, mostActiveMonth, reposCreated, longestStreak } = Astro.props;

const currentYear = new Date().getFullYear();
---

<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Year in Review</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">{currentYear}</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-year">
      <div class="gh-year-title">{currentYear} in Review</div>
      <div class="gh-year-hero">
        <div class="gh-year-stat-val">{totalContributions.toLocaleString()}</div>
        <div class="gh-year-stat-label">Total Contributions</div>
      </div>
      <div class="gh-year-stats">
        <div class="gh-year-stat">
          <div class="gh-year-stat-val">{topLanguage}</div>
          <div class="gh-year-stat-label">Top Language</div>
        </div>
        <div class="gh-year-stat">
          <div class="gh-year-stat-val">{mostActiveMonth}</div>
          <div class="gh-year-stat-label">Most Active</div>
        </div>
        <div class="gh-year-stat">
          <div class="gh-year-stat-val">{reposCreated}</div>
          <div class="gh-year-stat-label">Repos Created</div>
        </div>
        <div class="gh-year-stat">
          <div class="gh-year-stat-val">{longestStreak}</div>
          <div class="gh-year-stat-label">Day Streak</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .gh-year {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .gh-year-title {
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--neon-green);
    text-shadow: 0 0 8px rgba(6, 214, 160, 0.3);
    text-align: center;
  }

  .gh-year-hero {
    text-align: center;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .gh-year-hero .gh-year-stat-val {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--neon-green);
    text-shadow:
      0 0 12px rgba(6, 214, 160, 0.5),
      0 0 30px rgba(6, 214, 160, 0.2);
    line-height: 1;
  }

  .gh-year-hero .gh-year-stat-label {
    font-size: 0.55rem;
    margin-top: 6px;
  }

  .gh-year-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .gh-year-stat {
    text-align: center;
    padding: 8px 4px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
  }

  .gh-year-stat-val {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--neon-green);
    line-height: 1.2;
  }

  .gh-year-stat-label {
    font-size: 0.48rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-top: 3px;
  }
</style>
