---
interface Event {
  type: 'commit' | 'pr_opened' | 'pr_closed' | 'pr_merged' | 'issue_opened' | 'issue_closed';
  repo: string;
  title: string;
  date: string;
  hash?: string;
  additions?: number;
  deletions?: number;
  number?: number;
}

interface Props {
  events: Event[];
}

const { events } = Astro.props;

const iconMap: Record<string, { symbol: string; color: string; label: string }> = {
  'commit':       { symbol: '\u2192', color: 'var(--neon-green)',  label: 'Commit' },
  'pr_opened':    { symbol: '\u2295', color: 'var(--neon-blue)',   label: 'PR Opened' },
  'pr_closed':    { symbol: '\u2296', color: 'var(--neon-blue)',   label: 'PR Closed' },
  'pr_merged':    { symbol: '\u229E', color: 'var(--neon-blue)',   label: 'PR Merged' },
  'issue_opened': { symbol: '\u25C9', color: 'var(--neon-amber)',  label: 'Issue Opened' },
  'issue_closed': { symbol: '\u2714', color: 'var(--neon-amber)',  label: 'Issue Closed' },
};

function getIcon(type: string) {
  return iconMap[type] || { symbol: '\u00B7', color: 'var(--neon-green)', label: 'Event' };
}

function getDetail(event: Event): string {
  if (event.type === 'commit' && event.hash) {
    return event.hash + ' +' + (event.additions || 0) + '/-' + (event.deletions || 0);
  }
  if (event.number !== undefined) {
    return '#' + event.number;
  }
  return '';
}
---
<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Dev Activity</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">stream</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-dac-feed">
      {events.map((event: Event) => {
        const icon = getIcon(event.type);
        const detail = getDetail(event);
        return (
          <div class="gh-dac-card" style={`border-left-color: ${icon.color};`}>
            <div class="gh-dac-header">
              <span class="gh-dac-icon" style={`color: ${icon.color}; background: ${icon.color}15;`}>{icon.symbol}</span>
              <span class="gh-dac-type" style={`color: ${icon.color};`}>{icon.label}</span>
              <span class="gh-dac-date">{event.date}</span>
            </div>
            <div class="gh-dac-title">{event.title}</div>
            <div class="gh-dac-footer">
              <span class="gh-dac-repo">{event.repo}</span>
              {detail && <span class="gh-dac-detail">{detail}</span>}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>

<style>
  .gh-dac-feed {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .gh-dac-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-left: 2px solid;
    border-radius: 8px;
    padding: 10px 12px;
  }

  .gh-dac-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .gh-dac-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .gh-dac-type {
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .gh-dac-date {
    font-size: 0.55rem;
    color: rgba(255, 255, 255, 0.3);
    margin-left: auto;
    white-space: nowrap;
  }

  .gh-dac-title {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-dac-footer {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .gh-dac-repo {
    font-size: 0.6rem;
    color: var(--neon-green);
    font-family: 'Space Grotesk', monospace;
  }

  .gh-dac-detail {
    font-size: 0.55rem;
    color: var(--text-muted);
    font-family: 'Space Grotesk', monospace;
    opacity: 0.7;
    margin-left: auto;
  }
</style>
