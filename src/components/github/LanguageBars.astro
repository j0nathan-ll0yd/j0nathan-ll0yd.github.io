---
interface Props {
  languages: { name: string; pct: number; color: string }[];
}

const { languages } = Astro.props;
const sorted = [...languages].sort((a, b) => b.pct - a.pct);
---

<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Language Bars</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">all repos</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-lang-bars">
      {sorted.map((lang) => (
        <div class="gh-lb-row">
          <div class="gh-lb-info">
            <span class="gh-lb-dot" style={`background: ${lang.color};`}></span>
            <span class="gh-lb-name">{lang.name}</span>
            <span class="gh-lb-pct">{lang.pct}%</span>
          </div>
          <div class="gh-lb-track">
            <div class="gh-lb-fill" style={`width: ${lang.pct}%; background: ${lang.color};`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .gh-lang-bars {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .gh-lb-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .gh-lb-info {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .gh-lb-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gh-lb-name {
    font-size: var(--font-size-base);
    color: var(--text);
    flex: 1;
  }

  .gh-lb-pct {
    font-size: var(--font-size-base);
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .gh-lb-track {
    height: 6px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
    overflow: hidden;
  }

  .gh-lb-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s ease;
  }
</style>
