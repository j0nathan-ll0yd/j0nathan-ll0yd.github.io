---
interface Commit {
  hash: string;
  message: string;
  repo: string;
  date: string;
  repoColor: string;
}

interface Props {
  commits: Commit[];
}

const { commits } = Astro.props;
---
<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Commit Timeline</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">recent</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-timeline">
      <div class="gh-tl-line"></div>
      {commits.map((c: Commit) => (
        <div class="gh-tl-item">
          <div class="gh-tl-dot" style={`background: ${c.repoColor}; box-shadow: 0 0 8px ${c.repoColor};`}></div>
          <div class="gh-tl-content">
            <span class="gh-tl-msg">{c.message}</span>
            <div class="gh-tl-meta">
              <span class="gh-tl-repo-badge" style={`background: ${c.repoColor}20; border-color: ${c.repoColor}40; color: ${c.repoColor};`}>{c.repo}</span>
              <span class="gh-tl-date">{c.date}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .gh-timeline {
    position: relative;
    padding-left: 20px;
  }

  .gh-tl-line {
    position: absolute;
    left: 5px;
    top: 4px;
    bottom: 4px;
    width: 1px;
    background: linear-gradient(180deg, rgba(6, 214, 160, 0.4), rgba(6, 214, 160, 0.08));
  }

  .gh-tl-item {
    position: relative;
    padding-bottom: 14px;
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .gh-tl-item:last-child {
    padding-bottom: 0;
  }

  .gh-tl-dot {
    position: absolute;
    left: -18px;
    top: 4px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gh-tl-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .gh-tl-msg {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-tl-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .gh-tl-repo-badge {
    display: inline-block;
    font-size: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 2px 8px;
    border-radius: 10px;
    border: 1px solid;
    white-space: nowrap;
  }

  .gh-tl-date {
    font-size: 0.58rem;
    font-family: 'Space Grotesk', monospace;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
</style>
