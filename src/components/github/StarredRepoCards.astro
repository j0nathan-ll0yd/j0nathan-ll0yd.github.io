---
interface Repo {
  owner: string;
  name: string;
  description: string;
  stars: number;
  forks: number;
  language: string;
  languageColor: string;
  url: string;
}

interface Props {
  repos: Repo[];
}

const { repos } = Astro.props;
---

<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Starred Repos</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">recently starred</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-starred-cards">
      {repos.map((repo: Repo) => (
        <a class="gh-stc-card" href={repo.url}>
          <div class="gh-stc-owner">{repo.owner}</div>
          <div class="gh-stc-name">{repo.name}</div>
          <div class="gh-stc-desc">{repo.description}</div>
          <div class="gh-stc-meta">
            <span class="gh-stc-lang">
              <span class="gh-stc-lang-dot" style={`background: ${repo.languageColor}; box-shadow: 0 0 6px ${repo.languageColor};`}></span>
              {repo.language}
            </span>
            <span class="gh-stc-stat">&#9733; {repo.stars.toLocaleString()}</span>
            <span class="gh-stc-stat">&#9282; {repo.forks.toLocaleString()}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .gh-starred-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  @media (max-width: 600px) {
    .gh-starred-cards {
      grid-template-columns: 1fr;
    }
  }

  .gh-stc-card {
    display: flex;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    padding: 12px 14px;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .gh-stc-card:hover {
      background: rgba(6, 214, 160, 0.05);
      border-color: rgba(6, 214, 160, 0.15);
    }

    .gh-stc-card:hover .gh-stc-name {
      text-shadow: 0 0 10px rgba(6, 214, 160, 0.5);
    }
  }

  .gh-stc-owner {
    font-size: 0.56rem;
    color: rgba(255, 255, 255, 0.35);
    font-family: 'Space Grotesk', monospace;
    letter-spacing: 0.5px;
    margin-bottom: 2px;
  }

  .gh-stc-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--neon-green);
    margin-bottom: 4px;
    text-shadow: 0 0 6px rgba(6, 214, 160, 0.3);
  }

  .gh-stc-desc {
    font-size: 0.62rem;
    color: var(--text-muted);
    line-height: 1.4;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .gh-stc-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.58rem;
    font-family: 'Space Grotesk', monospace;
    color: var(--text-muted);
    margin-top: auto;
  }

  .gh-stc-lang {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .gh-stc-lang-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gh-stc-stat {
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.5px;
  }
</style>
