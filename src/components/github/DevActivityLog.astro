---
interface Event {
  type: 'commit' | 'pr_opened' | 'pr_closed' | 'pr_merged' | 'issue_opened' | 'issue_closed';
  repo: string;
  title: string;
  date: string;
  hash?: string;
  additions?: number;
  deletions?: number;
  number?: number;
}

interface Props {
  events: Event[];
}

const { events } = Astro.props;

const iconMap: Record<string, { symbol: string; color: string }> = {
  'commit':       { symbol: '\u2192', color: 'var(--neon-green)' },
  'pr_opened':    { symbol: '\u2295', color: 'var(--neon-blue)' },
  'pr_closed':    { symbol: '\u2296', color: 'var(--neon-blue)' },
  'pr_merged':    { symbol: '\u229E', color: 'var(--neon-blue)' },
  'issue_opened': { symbol: '\u25C9', color: 'var(--neon-amber)' },
  'issue_closed': { symbol: '\u2714', color: 'var(--neon-amber)' },
};

function getIcon(type: string) {
  return iconMap[type] || { symbol: '\u00B7', color: 'var(--neon-green)' };
}

function getDetail(event: Event): string {
  if (event.type === 'commit' && event.hash) {
    return event.hash + ' +' + (event.additions || 0) + '/-' + (event.deletions || 0);
  }
  if (event.number !== undefined) {
    return '#' + event.number;
  }
  return '';
}
---
<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Dev Log</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">live</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-dal-terminal">
      {events.map((event: Event) => {
        const icon = getIcon(event.type);
        const detail = getDetail(event);
        return (
          <div class="gh-dal-line">
            <span class="gh-dal-icon" style={`color: ${icon.color};`}>{icon.symbol}</span>
            <span class="gh-dal-repo">{event.repo}</span>
            <span class="gh-dal-title">{event.title}</span>
            {detail && <span class="gh-dal-detail">{detail}</span>}
            <span class="gh-dal-date">{event.date}</span>
          </div>
        );
      })}
    </div>
  </div>
</div>

<style>
  .gh-dal-terminal {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(6, 214, 160, 0.1);
    border-radius: 8px;
    padding: 10px 12px;
    font-family: 'Space Grotesk', monospace;
    font-size: 0.68rem;
    line-height: 1.8;
  }

  .gh-dal-line {
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: nowrap;
    white-space: nowrap;
    overflow: hidden;
  }

  .gh-dal-icon {
    flex-shrink: 0;
    font-size: 0.72rem;
  }

  .gh-dal-repo {
    color: var(--text);
    font-weight: 600;
    flex-shrink: 0;
    font-size: 0.64rem;
  }

  .gh-dal-title {
    color: var(--text-muted);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gh-dal-detail {
    color: var(--neon-green);
    opacity: 0.7;
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .gh-dal-date {
    color: rgba(255, 255, 255, 0.2);
    font-size: 0.6rem;
    flex-shrink: 0;
    margin-left: auto;
  }
</style>
