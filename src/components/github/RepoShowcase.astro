---
interface Repo {
  name: string;
  description: string;
  stars: number;
  forks: number;
  language: string;
  languageColor: string;
  topics: string[];
  url: string;
}

interface Props {
  repos: Repo[];
}

const { repos } = Astro.props;
---

<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Repo Showcase</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">featured</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-showcase">
      <div class="gh-sc-grid">
        {repos.map((repo: Repo) => (
          <a class="gh-sc-card" href={repo.url}>
            <div class="gh-sc-name">{repo.name}</div>
            <div class="gh-sc-desc">{repo.description}</div>
            {repo.topics.length > 0 && (
              <div class="gh-sc-topics">
                {repo.topics.map((topic: string) => (
                  <span class="gh-sc-topic">{topic}</span>
                ))}
              </div>
            )}
            <div class="gh-sc-meta">
              <span class="gh-sc-meta-lang">
                <span class="gh-sc-meta-lang-dot" style={`background: ${repo.languageColor}; box-shadow: 0 0 6px ${repo.languageColor};`}></span>
                {repo.language}
              </span>
              <span class="gh-sc-meta-stat">&#9733; {repo.stars}</span>
              <span class="gh-sc-meta-stat">&#9282; {repo.forks}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .gh-showcase {
    /* container */
  }

  .gh-sc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  @media (max-width: 600px) {
    .gh-sc-grid {
      grid-template-columns: 1fr;
    }
  }

  .gh-sc-card {
    display: flex;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    padding: 12px 14px;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .gh-sc-card:hover {
      background: rgba(6, 214, 160, 0.05);
      border-color: rgba(6, 214, 160, 0.15);
    }

    .gh-sc-card:hover .gh-sc-name {
      text-shadow: 0 0 10px rgba(6, 214, 160, 0.5);
    }
  }

  .gh-sc-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--neon-green);
    margin-bottom: 4px;
    text-shadow: 0 0 6px rgba(6, 214, 160, 0.3);
  }

  .gh-sc-desc {
    font-size: 0.62rem;
    color: var(--text-muted);
    line-height: 1.4;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .gh-sc-topics {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .gh-sc-topic {
    display: inline-block;
    font-size: 0.48rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 10px;
    text-transform: lowercase;
    letter-spacing: 0.5px;
    background: rgba(6, 214, 160, 0.08);
    border: 1px solid rgba(6, 214, 160, 0.15);
    color: rgba(6, 214, 160, 0.75);
  }

  .gh-sc-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.58rem;
    font-family: 'Space Grotesk', monospace;
    color: var(--text-muted);
    margin-top: auto;
  }

  .gh-sc-meta-lang {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .gh-sc-meta-lang-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gh-sc-meta-stat {
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.5px;
  }
</style>
