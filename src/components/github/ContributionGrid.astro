---
interface Props {
  contributions: number[][];
  stats: { repos: number; stars: number; contributions: number };
}

const { contributions, stats } = Astro.props;
---

<div class="tri-card tri-card-accent-green">
  <div class="widget-header">
    <span class="widget-label">Contribution Grid</span>
    <div class="widget-header-right">
      <div class="live-dot"></div>
      <span class="widget-timestamp">this year</span>
    </div>
  </div>
  <div class="widget-body">
    <div class="gh-contrib-grid">
      {contributions.map((week: number[]) => (
        <div class="gh-contrib-week">
          {week.map((level: number) => (
            <div class="gh-contrib-cell" data-level={level}></div>
          ))}
        </div>
      ))}
    </div>
    <div class="gh-contrib-stats-row">
      <div>
        <div class="gh-contrib-stat-value">{stats.repos}</div>
        <div class="gh-contrib-stat-label">Repos</div>
      </div>
      <div>
        <div class="gh-contrib-stat-value">{stats.stars}</div>
        <div class="gh-contrib-stat-label">Stars</div>
      </div>
      <div>
        <div class="gh-contrib-stat-value">{stats.contributions.toLocaleString()}</div>
        <div class="gh-contrib-stat-label">Contributions</div>
      </div>
    </div>
  </div>
</div>

<style>
  .gh-contrib-grid {
    display: flex;
    gap: 2px;
    margin-bottom: 14px;
    overflow: hidden;
  }

  .gh-contrib-week {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .gh-contrib-cell {
    width: 8px;
    height: 8px;
    border-radius: 2px;
  }

  .gh-contrib-cell[data-level="0"] {
    background: rgba(6,214,160,0.05);
  }

  .gh-contrib-cell[data-level="1"] {
    background: rgba(6,214,160,0.2);
  }

  .gh-contrib-cell[data-level="2"] {
    background: rgba(6,214,160,0.4);
    box-shadow: 0 0 3px rgba(6,214,160,0.15);
  }

  .gh-contrib-cell[data-level="3"] {
    background: rgba(6,214,160,0.65);
    box-shadow: 0 0 4px rgba(6,214,160,0.25);
  }

  .gh-contrib-cell[data-level="4"] {
    background: var(--neon-green);
    box-shadow: 0 0 6px rgba(6,214,160,0.4);
  }

  .gh-contrib-stats-row {
    display: flex;
    gap: 24px;
  }

  .gh-contrib-stat-value {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--neon-green);
  }

  .gh-contrib-stat-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }
</style>
