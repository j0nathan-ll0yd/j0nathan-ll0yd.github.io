---
import Dashboard from '../layouts/Dashboard.astro';
---
<Dashboard title="Page Not Found — Jonathan Lloyd" description="The requested page could not be found." robots="noindex">
  <main id="main-content" class="command-layout" style="display:flex;align-items:center;justify-content:center;min-height:100vh;">
    <div class="tri-card" style="max-width:480px;text-align:center;padding:var(--space-32);">
      <div class="widget-header">
        <span class="widget-label">SIGNAL LOST</span>
      </div>
      <div class="widget-body">
        <p style="font-size:var(--font-size-hero);margin-bottom:var(--space-16);color:var(--neon-red);">404</p>
        <p style="color:var(--text-muted);margin-bottom:var(--space-24);">The requested datastream could not be located.</p>
        <a href="/" style="color:var(--neon-blue);text-decoration:none;">Return to Command Center</a>
      </div>
    </div>
  </main>
</Dashboard>
