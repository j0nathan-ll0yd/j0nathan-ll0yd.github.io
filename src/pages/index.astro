---
import fs from 'node:fs';
import path from 'node:path';
import Dashboard from '../layouts/Dashboard.astro';
import IdentityCard from '../components/IdentityCard.astro';
import BioTerminal from '../components/BioTerminal.astro';
import SystemStatus from '../components/SystemStatus.astro';
import HeartRate from '../components/HeartRate.astro';
import DailyActivity from '../components/DailyActivity.astro';
import Workouts from '../components/Workouts.astro';
import NightSummary from '../components/NightSummary.astro';
import Hydration from '../components/Hydration.astro';
import StarredRepoList from '../components/github/StarredRepoList.astro';
import { CLOUDFRONT_BASE, ENDPOINTS } from '../lib/constants';
import DevActivityLog from '../components/github/DevActivityLog.astro';
import ReadingFeed from '../components/ReadingFeed.astro';
import Bookshelf from '../components/Bookshelf.astro';
import BookModal from '../components/BookModal.astro';
import FocusOverlay from '../components/FocusOverlay.astro';
import DndOverlay from '../components/DndOverlay.astro';
import PlaceLeaderboardV3 from '../components/location/PlaceLeaderboardV3.astro';
import ExplorationOdometerV3 from '../components/location/ExplorationOdometerV3.astro';
import TheatreReviews from '../components/TheatreReviews.astro';

const dataDir = path.join(process.cwd(), 'data');
const profile = JSON.parse(fs.readFileSync(path.join(dataDir, 'profile.json'), 'utf-8'));
const health = JSON.parse(fs.readFileSync(path.join(dataDir, 'health.json'), 'utf-8'));
const github = JSON.parse(fs.readFileSync(path.join(dataDir, 'github.json'), 'utf-8'));
const reading = JSON.parse(fs.readFileSync(path.join(dataDir, 'reading.json'), 'utf-8'));
const books = JSON.parse(fs.readFileSync(path.join(dataDir, 'books.json'), 'utf-8'));
const system = JSON.parse(fs.readFileSync(path.join(dataDir, 'system.json'), 'utf-8'));

const LANG_COLORS: Record<string, string> = {
  TypeScript: '#3178c6', JavaScript: '#f1e05a', Python: '#3572A5',
  Java: '#b07219', 'C#': '#178600', 'C++': '#f34b7d', C: '#555555',
  Go: '#00ADD8', Rust: '#dea584', Swift: '#F05138', Kotlin: '#A97BFF',
  Ruby: '#701516', PHP: '#4F5D95', Dart: '#00B4AB', Scala: '#c22d40',
  Shell: '#89e051', Lua: '#000080', Perl: '#0298c3', Haskell: '#5e5086',
  R: '#198CE7', Julia: '#a270ba', Elixir: '#6e4a7e', Clojure: '#db5855',
  Erlang: '#B83998', OCaml: '#ef7a08', 'F#': '#b845fc', Zig: '#ec915c',
  Nim: '#ffc200', V: '#4f87c4', Crystal: '#000100', 'Objective-C': '#438eff',
  HTML: '#e34c26', CSS: '#563d7c', SCSS: '#c6538c', Vue: '#41b883',
  Svelte: '#ff3e00', Astro: '#bc52ee', HCL: '#844FBA', Terraform: '#5c4ee5',
  Dockerfile: '#384d54', Makefile: '#427819', CMake: '#DA3434',
  PowerShell: '#012456', 'Vim Script': '#199f4b', 'Emacs Lisp': '#c065db',
  Nix: '#7e7eff', YAML: '#cb171e', TOML: '#9c4221', Markdown: '#083fa1',
  TeX: '#3D6117',
};

let starredRepos: { owner: string; name: string; url: string; stars: number; language: string; languageColor: string; starredAt: string }[] = [];
try {
  const res = await fetch(`${CLOUDFRONT_BASE}${ENDPOINTS.starredRepos}`);
  const json = await res.json();
  const now = Date.now();
  starredRepos = (json.repos || []).slice(0, 5).map((r: any) => {
    const msAgo = now - new Date(r.starredAt).getTime();
    const hoursAgo = Math.floor(msAgo / 3600000);
    const daysAgo = Math.floor(hoursAgo / 24);
    const weeksAgo = Math.floor(daysAgo / 7);
    let starredAt: string;
    if (weeksAgo > 0) starredAt = `${weeksAgo} week${weeksAgo > 1 ? 's' : ''} ago`;
    else if (daysAgo > 0) starredAt = `${daysAgo} day${daysAgo > 1 ? 's' : ''} ago`;
    else starredAt = `${hoursAgo}h ago`;
    const lang = r.languages?.[0]?.language || 'Unknown';
    return {
      owner: r.ownerLogin,
      name: r.name,
      url: r.htmlUrl,
      stars: r.stargazersCount,
      language: lang,
      languageColor: LANG_COLORS[lang] || '#8b949e',
      starredAt,
    };
  });
} catch (err) {
  console.warn('[build] Failed to fetch starred repos:', (err as Error).message);
}
---
<Dashboard>
  <FocusOverlay />
  <DndOverlay />
  <canvas id="particle-canvas" aria-hidden="true"></canvas>

  <div class="command-layout">

    <!-- LEFT PANEL: Identity -->
    <aside class="left-panel" aria-label="Profile">
      <IdentityCard profile={profile} />
      <BioTerminal profile={profile} />
      <SystemStatus system={system} />
    </aside>


    <!-- TOP BAR -->
    <header class="top-bar">
      <div class="top-bar-title">Human Datastream</div>
      <span id="pollStatus" class="poll-status">
        <span class="poll-dot poll-dot--off"></span>
        <span class="poll-label"></span>
      </span>
      <div class="top-bar-clock" id="liveClock" aria-live="off" aria-label="Current time"></div>
    </header>

    <!-- RIGHT PANEL: Triptych Grid -->
    <main id="main-content" class="right-panel">
      <div class="triptych-grid" id="triptychGrid">

        <!-- COLUMN 1: BODY -->
        <section class="triptych-column triptych-column-body" aria-label="Body">
          <h2 class="column-header column-header-pink">Body</h2>
          <HeartRate health={health} />
          <DailyActivity health={health} />
          <Workouts health={health} />
          <Hydration health={health} />
          <NightSummary health={health} />
          {import.meta.env.DEV && <PlaceLeaderboardV3 />}
          {import.meta.env.DEV && <ExplorationOdometerV3 />}
        </section>

        <!-- COLUMN 2: MIND -->
        <section class="triptych-column triptych-column-mind" aria-label="Mind">
          <h2 class="column-header column-header-green">Mind</h2>
          <DevActivityLog events={github.devActivity} />
          <ReadingFeed reading={reading} />
          <StarredRepoList repos={starredRepos} />
          <Bookshelf books={books} />
          <TheatreReviews />
        </section>

      </div>
    </main>

  </div>

  <BookModal />

  <!-- Particles -->
  <script>
    window.addEventListener('load', () => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      import('../scripts/particles').then(m => m.startParticles());
    });
  </script>

  <!-- Live Clock -->
  <script is:inline>
  (function() {
    function updateClock() {
      var el = document.getElementById('liveClock');
      if (!el) return;
      var now = new Date();
      var h = String(now.getHours()).padStart(2, '0');
      var m = String(now.getMinutes()).padStart(2, '0');
      var s = String(now.getSeconds()).padStart(2, '0');
      el.textContent = h + ':' + m + ':' + s;
    }
    updateClock();
    setInterval(updateClock, 1000);
  })();
  </script>

  <!-- Staggered Card Reveal -->
  <script is:inline>
  (function() {
    setTimeout(function() {
      var id = document.getElementById('identityCard');
      if (id) id.classList.add('visible');
    }, 100);
    setTimeout(function() {
      var bio = document.getElementById('cardBio');
      if (bio) bio.classList.add('visible');
    }, 250);
    setTimeout(function() {
      var sys = document.getElementById('cardSystem');
      if (sys) sys.classList.add('visible');
    }, 550);

    var columns = document.querySelectorAll('.triptych-column');
    columns.forEach(function(col, colIdx) {
      var cards = col.querySelectorAll('.tri-card');
      cards.forEach(function(card, rowIdx) {
        setTimeout(function() {
          card.classList.add('visible');
        }, 400 + colIdx * 150 + rowIdx * 100);
      });
    });
  })();
  </script>

  <!-- Canvas ECG Animation -->
  <script is:inline>
  (function() {
    var canvas = document.getElementById('hrEcgCanvas');
    if (!canvas) return;

    var ctx = canvas.getContext('2d', { alpha: false });
    var motionReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Waveform generator: ECGSYN Gaussian model ----
    function ecgBeat(bpm, numSamples) {
      var hrFact = Math.sqrt(bpm / 60);
      var waves = [
        [0.15,  0.12, 0.040, false],
        [-0.10, 0.28, 0.015, true],
        [1.00,  0.32, 0.018, true],
        [-0.25, 0.38, 0.020, true],
        [0.30,  0.58, 0.070, false]
      ];
      var samples = [];
      var i, j, t, val, w, width, center, exponent;
      for (i = 0; i < numSamples; i++) {
        t = i / numSamples;
        val = 0;
        for (j = 0; j < waves.length; j++) {
          w = waves[j];
          width = w[3] ? w[2] : w[2] / hrFact;
          center = w[1];
          if (j === 4) {
            center = 0.58 - (hrFact - 1) * 0.08;
            if (center < 0.42) center = 0.42;
          }
          exponent = (t - center) / width;
          val += w[0] * Math.exp(-0.5 * exponent * exponent);
        }
        samples[i] = val;
      }
      return samples;
    }

    // ---- HRV beat spacing jitter ----
    function nextRR(meanRR, sdnn) {
      var jitter = (Math.random() - 0.5) * 2 * sdnn;
      var rr = meanRR + jitter;
      if (rr < 250) rr = 250;
      if (rr > 2000) rr = 2000;
      return rr;
    }

    // ---- Draw medical grid ----
    function drawGrid(gctx, gw, gh) {
      var gridSpacing = 20;
      var i;
      gctx.save();
      gctx.lineWidth = 0.5;
      gctx.strokeStyle = 'rgba(255,255,255,0.03)';
      for (i = 0; i <= gw; i += gridSpacing) {
        gctx.beginPath();
        gctx.moveTo(Math.round(i) + 0.5, 0);
        gctx.lineTo(Math.round(i) + 0.5, gh);
        gctx.stroke();
      }
      for (i = 0; i <= gh; i += gridSpacing) {
        gctx.beginPath();
        gctx.moveTo(0, Math.round(i) + 0.5);
        gctx.lineTo(gw, Math.round(i) + 0.5);
        gctx.stroke();
      }
      gctx.strokeStyle = 'rgba(255,255,255,0.07)';
      for (i = 0; i <= gw; i += gridSpacing * 5) {
        gctx.beginPath();
        gctx.moveTo(Math.round(i) + 0.5, 0);
        gctx.lineTo(Math.round(i) + 0.5, gh);
        gctx.stroke();
      }
      for (i = 0; i <= gh; i += gridSpacing * 5) {
        gctx.beginPath();
        gctx.moveTo(0, Math.round(i) + 0.5);
        gctx.lineTo(gw, Math.round(i) + 0.5);
        gctx.stroke();
      }
      gctx.restore();
    }

    // ---- Redraw grid in a strip (sweep erase bar) ----
    function redrawGridStrip(gctx, sx, stripW, gh) {
      var gridSpacing = 20;
      var gx, gy;
      var x2 = sx + stripW;
      gctx.save();
      gctx.lineWidth = 0.5;
      gctx.strokeStyle = 'rgba(255,255,255,0.03)';
      var firstMinor = Math.floor(sx / gridSpacing) * gridSpacing;
      for (gx = firstMinor; gx <= x2; gx += gridSpacing) {
        if (gx >= sx && gx <= x2) {
          gctx.beginPath();
          gctx.moveTo(Math.round(gx) + 0.5, 0);
          gctx.lineTo(Math.round(gx) + 0.5, gh);
          gctx.stroke();
        }
      }
      for (gy = 0; gy <= gh; gy += gridSpacing) {
        gctx.beginPath();
        gctx.moveTo(sx, Math.round(gy) + 0.5);
        gctx.lineTo(x2, Math.round(gy) + 0.5);
        gctx.stroke();
      }
      gctx.strokeStyle = 'rgba(255,255,255,0.07)';
      var firstMajor = Math.floor(sx / (gridSpacing * 5)) * (gridSpacing * 5);
      for (gx = firstMajor; gx <= x2; gx += gridSpacing * 5) {
        if (gx >= sx && gx <= x2) {
          gctx.beginPath();
          gctx.moveTo(Math.round(gx) + 0.5, 0);
          gctx.lineTo(Math.round(gx) + 0.5, gh);
          gctx.stroke();
        }
      }
      for (gy = 0; gy <= gh; gy += gridSpacing * 5) {
        gctx.beginPath();
        gctx.moveTo(sx, Math.round(gy) + 0.5);
        gctx.lineTo(x2, Math.round(gy) + 0.5);
        gctx.stroke();
      }
      gctx.restore();
    }

    // ---- Widget state ----
    var bpm = parseInt(canvas.getAttribute('data-bpm'), 10) || 72;
    var hrv = parseInt(canvas.getAttribute('data-hrv'), 10) || 40;
    var stroke = canvas.getAttribute('data-stroke') || '#f59e0b';
    var now = performance.now();

    var wgt = {
      canvas: canvas,
      ctx: ctx,
      bpm: bpm,
      hrv: hrv,
      stroke: stroke,
      beatSamples: ecgBeat(bpm, 64),
      samplesPerBeat: 64,
      cursorX: 0,
      canvasW: 0,
      canvasH: 0,
      pixelsPerSecond: 50,
      meanRR: 60000 / bpm,
      nextBeatTime: now + Math.random() * (60000 / bpm),
      beatStartTime: now - 9999,
      beatDurationMs: 0,
      currentRR: 60000 / bpm,
      lastFrameTime: now,
      prevX: 0,
      prevY: 0,
      isVisible: false
    };

    // ---- Resize canvas buffer to CSS size * DPR ----
    function resizeCanvas() {
      var rect = wgt.canvas.getBoundingClientRect();
      var dpr = window.devicePixelRatio || 1;
      wgt.canvas.width = Math.round(rect.width * dpr);
      wgt.canvas.height = Math.round(rect.height * dpr);
      wgt.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      wgt.canvasW = rect.width;
      wgt.canvasH = rect.height;
      wgt.ctx.fillStyle = '#06060f';
      wgt.ctx.fillRect(0, 0, rect.width, rect.height);
      drawGrid(wgt.ctx, rect.width, rect.height);
      wgt.cursorX = 0;
      wgt.prevX = 0;
      wgt.prevY = rect.height * 0.6;
    }

    // ---- Render one frame ----
    function renderFrame(ts) {
      var elapsed = ts - wgt.lastFrameTime;
      if (elapsed > 100) elapsed = 100;
      wgt.lastFrameTime = ts;
      var advance = (elapsed / 1000) * wgt.pixelsPerSecond;
      var x = wgt.cursorX + advance;
      var wrapped = false;
      var w = wgt.canvasW;
      var h = wgt.canvasH;
      if (x >= w) {
        x = x - w;
        wrapped = true;
      }
      var clearWidth = Math.max(10, w * 0.04);
      if (wrapped) {
        ctx.fillStyle = '#06060f';
        ctx.fillRect(Math.round(wgt.cursorX), 0, Math.ceil(w - wgt.cursorX), h);
        redrawGridStrip(ctx, Math.round(wgt.cursorX), Math.ceil(w - wgt.cursorX), h);
      }
      ctx.fillStyle = '#06060f';
      ctx.fillRect(Math.round(x), 0, Math.ceil(clearWidth), h);
      redrawGridStrip(ctx, Math.round(x), Math.ceil(clearWidth), h);

      var baseline = h * 0.6;
      var amplitude = h * 0.48;
      var sample = 0;

      if (ts >= wgt.nextBeatTime) {
        wgt.currentRR = nextRR(wgt.meanRR, wgt.hrv);
        wgt.nextBeatTime = ts + wgt.currentRR;
        wgt.beatStartTime = ts;
        var activeFraction = 0.55 + 0.30 * (1 - Math.exp(-(wgt.bpm - 40) / 80));
        wgt.beatDurationMs = wgt.currentRR * activeFraction;
      }

      var timeSinceBeat = ts - wgt.beatStartTime;
      if (timeSinceBeat >= 0 && timeSinceBeat < wgt.beatDurationMs) {
        var progress = timeSinceBeat / wgt.beatDurationMs;
        var idx = Math.floor(progress * wgt.samplesPerBeat);
        if (idx >= wgt.samplesPerBeat) idx = wgt.samplesPerBeat - 1;
        sample = wgt.beatSamples[idx];
      }

      var y = baseline - sample * amplitude;

      if (!wrapped) {
        ctx.beginPath();
        ctx.moveTo(Math.round(wgt.prevX), Math.round(wgt.prevY));
        ctx.lineTo(Math.round(x), Math.round(y));
        ctx.strokeStyle = wgt.stroke;
        ctx.globalAlpha = 0.25;
        ctx.lineWidth = 3.5;
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(Math.round(wgt.prevX), Math.round(wgt.prevY));
        ctx.lineTo(Math.round(x), Math.round(y));
        ctx.globalAlpha = 1.0;
        ctx.lineWidth = 1.5;
        ctx.stroke();
        ctx.globalAlpha = 1.0;
      } else {
        ctx.beginPath();
        ctx.arc(Math.round(x), Math.round(y), 1.5, 0, Math.PI * 2);
        ctx.fillStyle = wgt.stroke;
        ctx.globalAlpha = 1.0;
        ctx.fill();
      }

      wgt.cursorX = x;
      wgt.prevX = x;
      wgt.prevY = y;
    }

    // ---- Draw static PQRST waveform (reduced motion) ----
    function drawStaticWaveform() {
      var w = wgt.canvasW;
      var h = wgt.canvasH;
      var baseline = h * 0.6;
      var amplitude = h * 0.48;
      var samples = wgt.beatSamples;
      var n = samples.length;
      var waveW = w * 0.6;
      var startX = w * 0.2;
      ctx.beginPath();
      ctx.moveTo(0, baseline);
      ctx.lineTo(startX, baseline);
      var i, px, py;
      for (i = 0; i < n; i++) {
        px = startX + (i / (n - 1)) * waveW;
        py = baseline - samples[i] * amplitude;
        if (i === 0) {
          ctx.moveTo(px, py);
        } else {
          ctx.lineTo(px, py);
        }
      }
      ctx.lineTo(w, baseline);
      ctx.strokeStyle = wgt.stroke;
      ctx.globalAlpha = 0.7;
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.globalAlpha = 1.0;
    }

    if (motionReduced) {
      resizeCanvas();
      drawStaticWaveform();
    }

    // ---- Live-data bridge ----
    window.__ecgUpdate = function(newBpm, newHrv, newStroke) {
      wgt.bpm = newBpm;
      wgt.hrv = newHrv;
      wgt.stroke = newStroke;
      wgt.meanRR = 60000 / newBpm;
      wgt.beatSamples = ecgBeat(newBpm, 64);
    };

    if (motionReduced) return;

    // ---- IntersectionObserver ----
    var observer = new IntersectionObserver(function(entries) {
      var j;
      for (j = 0; j < entries.length; j++) {
        if (entries[j].target === wgt.canvas) {
          wgt.isVisible = entries[j].isIntersecting;
          if (entries[j].isIntersecting) {
            if (!wgt.canvasW) resizeCanvas();
            wgt.lastFrameTime = performance.now();
          }
        }
      }
    }, { threshold: 0.1 });
    observer.observe(wgt.canvas);

    // ---- Debounced resize ----
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(resizeCanvas, 200);
    });

    // ---- Animation loop ----
    function animLoop(timestamp) {
      if (wgt.isVisible) {
        renderFrame(timestamp);
      }
      requestAnimationFrame(animLoop);
    }
    requestAnimationFrame(animLoop);
  })();
  </script>

  <!-- Scroll Depth Tracking -->
  <script is:inline>
  (function() {
    var depths = [25, 50, 75, 100];
    var tracked = {};
    window.addEventListener('scroll', function() {
      var docHeight = document.documentElement.scrollHeight - window.innerHeight;
      if (docHeight <= 0) return;
      var scrollPct = Math.round((window.scrollY / docHeight) * 100);
      for (var i = 0; i < depths.length; i++) {
        if (scrollPct >= depths[i] && !tracked[depths[i]]) {
          tracked[depths[i]] = true;
          if (window.sa_event) sa_event('scroll_depth_' + depths[i]);
        }
      }
    });
  })();
  </script>

  <!-- Live Data Integration -->
  <script>
    import '../scripts/live-data';
  </script>
</Dashboard>
