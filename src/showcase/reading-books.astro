---
import fs from 'node:fs';
import path from 'node:path';
import Showcase from '../layouts/Showcase.astro';
import ReadingFeed from '../components/ReadingFeed.astro';
import Bookshelf from '../components/Bookshelf.astro';
import BookModal from '../components/BookModal.astro';

const dataDir = path.join(process.cwd(), 'data');
const reading = JSON.parse(fs.readFileSync(path.join(dataDir, 'reading.json'), 'utf-8'));
const books = JSON.parse(fs.readFileSync(path.join(dataDir, 'books.json'), 'utf-8'));
const empty = JSON.parse(fs.readFileSync(path.join(dataDir, 'showcase-empty.json'), 'utf-8'));
---
<Showcase title="Reading & Books">
  <main class="lib-container">
    <h1 class="lib-page-title">Reading &amp; Books</h1>
    <p class="lib-page-desc">
      The reading and bookshelf components that surface curated articles and the current book collection. Includes a modal detail overlay activated by clicking a book in the Bookshelf.
    </p>

    <!-- ==================== 1. READING FEED ==================== -->
    <div class="component-section">
      <div class="component-name">ReadingFeed</div>
      <div class="component-description">
        A curated list of recently read or saved articles. Each item features an optional star for favorites, a title that highlights on hover, and metadata showing the source domain and relative date.
      </div>
      <div class="component-classes">.article-list, .article-list-item, .article-list-star, .article-list-title</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Reading Feed</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <ul class="article-list" style="list-style: none; padding: 0; margin: 0;">
                  <li class="article-list-item" style="display: flex; gap: 10px; align-items: flex-start; padding: 6px 0;">
                    <span class="skeleton-bar" style="width: 14px; height: 14px; flex-shrink: 0; border-radius: 2px;"></span>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 6px;">
                      <span class="skeleton-bar" style="width: 80%; height: 13px;"></span>
                      <span class="skeleton-bar" style="width: 40%; height: 10px;"></span>
                    </div>
                  </li>
                  <li class="article-list-item" style="display: flex; gap: 10px; align-items: flex-start; padding: 6px 0;">
                    <span class="skeleton-bar" style="width: 14px; height: 14px; flex-shrink: 0; border-radius: 2px;"></span>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 6px;">
                      <span class="skeleton-bar" style="width: 65%; height: 13px;"></span>
                      <span class="skeleton-bar" style="width: 35%; height: 10px;"></span>
                    </div>
                  </li>
                  <li class="article-list-item" style="display: flex; gap: 10px; align-items: flex-start; padding: 6px 0;">
                    <span class="skeleton-bar" style="width: 14px; height: 14px; flex-shrink: 0; border-radius: 2px;"></span>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 6px;">
                      <span class="skeleton-bar" style="width: 75%; height: 13px;"></span>
                      <span class="skeleton-bar" style="width: 45%; height: 10px;"></span>
                    </div>
                  </li>
                  <li class="article-list-item" style="display: flex; gap: 10px; align-items: flex-start; padding: 6px 0;">
                    <span class="skeleton-bar" style="width: 14px; height: 14px; flex-shrink: 0; border-radius: 2px;"></span>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 6px;">
                      <span class="skeleton-bar" style="width: 70%; height: 13px;"></span>
                      <span class="skeleton-bar" style="width: 38%; height: 10px;"></span>
                    </div>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <ReadingFeed reading={empty.reading} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <ReadingFeed reading={reading} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 2. BOOKSHELF ==================== -->
    <div class="component-section">
      <div class="component-name">Bookshelf</div>
      <div class="component-description">
        A horizontally scrolling row of book covers with title, author, and reading status beneath each. Books lift on hover and their titles glow green. Clicking a book opens the BookModal overlay.
      </div>
      <div class="component-classes">.shelf-row, .shelf-book, .shelf-cover-wrapper, .book-overlay, .book-modal</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Bookshelf</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div class="shelf-row" style="display: flex; gap: 16px;">
                  <div class="shelf-book" style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
                    <div class="skeleton-bar" style="width: 80px; height: 120px; border-radius: 4px;"></div>
                    <div class="skeleton-bar" style="width: 64px; height: 10px;"></div>
                    <div class="skeleton-bar" style="width: 48px; height: 8px;"></div>
                  </div>
                  <div class="shelf-book" style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
                    <div class="skeleton-bar" style="width: 80px; height: 120px; border-radius: 4px;"></div>
                    <div class="skeleton-bar" style="width: 56px; height: 10px;"></div>
                    <div class="skeleton-bar" style="width: 44px; height: 8px;"></div>
                  </div>
                  <div class="shelf-book" style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
                    <div class="skeleton-bar" style="width: 80px; height: 120px; border-radius: 4px;"></div>
                    <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
                    <div class="skeleton-bar" style="width: 50px; height: 8px;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <Bookshelf books={empty.books} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <Bookshelf books={books} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 2b. ACTIVE BOOK VARIATIONS ==================== -->
    <div class="component-section">
      <div class="component-name">Active Book Highlight Variations</div>
      <div class="component-description">
        15 visual treatments for the currently-reading book. Each mini-shelf shows the active book (first) alongside two normal books for contrast. V1–V10 are subtle/static; V11–V15 are animated and dramatic.
      </div>

      <div class="variation-grid">

        <!-- V1 — Subtle Lift -->
        <div class="variation-card shelf-v1">
          <span class="variation-label">V1 — Subtle Lift</span>
          <div class="variation-render">
            <div class="shelf-row">
              <div class="shelf-book shelf-book-active">
                <div class="shelf-cover-wrapper">
                  <img src="https://m.media-amazon.com/images/P/0525573844.01._SCLZZZZZZZ_SX200_.jpg" width="80" height="120" alt="Foundryside" loading="lazy">
                </div>
                <div class="shelf-book-title"><span>Foundryside</span></div>
                <div class="shelf-book-author">Robert Jackson Bennett</div>
                <div class="shelf-book-status shelf-status-in_progress">READING</div>
                <div class="shelf-book-progress-bar"><div class="shelf-book-progress-fill" style="width: 42%"></div></div>
                <div class="shelf-book-progress">42%</div>
              </div>
              <div class="shelf-book">
                <div class="shelf-cover-wrapper">
                  <img src="https://m.media-amazon.com/images/P/1984820710.01._SCLZZZZZZZ_SX200_.jpg" width="80" height="120" alt="The Tainted Cup" loading="lazy">
                </div>
                <div class="shelf-book-title"><span>The Tainted Cup</span></div>
                <div class="shelf-book-author">Robert Jackson Bennett</div>
                <div class="shelf-book-status shelf-status-completed">Recently Finished</div>
              </div>
              <div class="shelf-book">
                <div class="shelf-cover-wrapper">
                  <img src="https://m.media-amazon.com/images/P/B0FBRJY116.01._SCLZZZZZZZ_SX200_.jpg" width="80" height="120" alt="Crafting Engineering Strategy" loading="lazy">
                </div>
                <div class="shelf-book-title"><span>Crafting Engineering Strategy</span></div>
                <div class="shelf-book-author">Will Larson</div>
                <div class="shelf-book-status shelf-status-next">Up Next</div>
              </div>
            </div>
          </div>
        </div>

