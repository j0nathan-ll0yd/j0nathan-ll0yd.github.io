---
import fs from 'node:fs';
import path from 'node:path';
import Showcase from '../layouts/Showcase.astro';
import HeartRate from '../components/HeartRate.astro';
import DailyActivity from '../components/DailyActivity.astro';
import Workouts from '../components/Workouts.astro';
import NightSummary from '../components/NightSummary.astro';
import Hydration from '../components/Hydration.astro';


const dataDir = path.join(process.cwd(), 'data');
const health = JSON.parse(fs.readFileSync(path.join(dataDir, 'health.json'), 'utf-8'));

const empty = JSON.parse(fs.readFileSync(path.join(dataDir, 'showcase-empty.json'), 'utf-8'));
const healthWithWorkouts = { ...health, workouts: health.sampleWorkouts };
---
<Showcase title="Health & Wellness">
  <link slot="head" rel="stylesheet" href="/vendor/leaflet/leaflet.css">
  <script slot="head" is:inline src="/vendor/leaflet/leaflet.js"></script>
  <main class="lib-container">
    <h1 class="lib-page-title">Health &amp; Wellness</h1>
    <p class="lib-page-desc">
      The six health and wellness components: heart rate with ECG waveform, daily activity metrics, workout tracking, sleep summary, hydration levels, and current location with map.
    </p>

    <h2 class="lib-section-title">Vitals</h2>

    <!-- ==================== 1. HEART RATE ==================== -->
    <div class="component-section">
      <div class="component-name">HeartRate</div>
      <div class="component-description">
        Real-time heart rate display with animated ECG waveform background, BPM readout, zone badge, and HRV metric. Contains SVG filter id="ecgGlow" so only one component instance per page.
      </div>
      <div class="component-classes">.tri-card-accent-pink, .hr-layout, .hr-ecg-bg, .ecg-svg, .hr-overlay, .pulse-bpm, .pulse-status-badge, .hr-hrv-value</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-pink">
              <div class="widget-header">
                <span class="widget-label">Heart Rate</span>
                <div class="widget-header-right">
                  <div class="live-dot live-dot-pink"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="position: relative; min-height: 100px;">
                  <div class="skeleton-bar" style="width: 100%; height: 60px; border-radius: 8px; margin-bottom: 12px;"></div>
                  <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div class="skeleton-bar" style="width: 80px; height: 28px;"></div>
                    <div class="skeleton-bar" style="width: 50px; height: 18px; border-radius: 50px;"></div>
                  </div>
                  <div style="display: flex; justify-content: flex-end; margin-top: 8px;">
                    <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <!-- Hand-written: avoids duplicate SVG id="ecgGlow" -->
            <div class="tri-card tri-card-accent-pink">
              <div class="widget-header">
                <span class="widget-label">Heart Rate</span>
                <div class="widget-header-right">
                  <div class="live-dot live-dot-pink"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div class="hr-layout">
                  <div class="hr-overlay" style="position: relative;">
                    <div class="pulse-bpm" style="color: var(--text-muted);">---</div>
                    <div class="pulse-status-badge" style="opacity: 0.3;">---</div>
                  </div>
                </div>
                <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
                  <span class="hr-hrv-value" style="color: var(--text-muted);">HRV: ---</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <HeartRate health={health} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== HEART RATE ZONES ==================== -->
    <div class="component-section">
      <div class="component-name">HeartRate &mdash; Zone Gallery</div>
      <div class="component-description">All 5 heart rate zones plus 5 additional scenarios showing how BPM, HRV, ECG waveform amplitude, ECG scroll speed, and accent colors change across conditions. Each card has a unique SVG filter ID to avoid conflicts.</div>
      <div class="scenario-grid">

        <!-- Card 1: Bradycardia — 40 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-bradycardia">Bradycardia</div>
          <div class="scenario-sublabel">~40 BPM &mdash; Deep sleep, very low activity. ECG: 8s cycle (slowest). HRV high (62ms).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.35;">
                  <canvas class="ecg-canvas"
                    data-bpm="40"
                    data-hrv="62"
                    data-stroke="#3a86ff"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #3a86ff; text-shadow: 0 0 16px rgba(58,134,255,0.6), 0 0 40px rgba(58,134,255,0.25);">40</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-blue); background: rgba(58,134,255,0.12); border: 1px solid rgba(58,134,255,0.25);">Bradycardia</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #06d6a0; text-shadow: 0 0 12px rgba(6,214,160,0.5), 0 0 30px rgba(6,214,160,0.2);">62</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 2: Resting Zone — 52 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-resting">Resting Zone</div>
          <div class="scenario-sublabel">~52 BPM &mdash; Relaxed or light sleep. ECG: 6s cycle. HRV good (55ms).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.35;">
                  <canvas class="ecg-canvas"
                    data-bpm="52"
                    data-hrv="55"
                    data-stroke="#ff006e"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ff006e; text-shadow: 0 0 16px rgba(255,0,110,0.6), 0 0 40px rgba(255,0,110,0.25);">52</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-green); background: rgba(6,214,160,0.12); border: 1px solid rgba(6,214,160,0.25);">Resting Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #06d6a0; text-shadow: 0 0 12px rgba(6,214,160,0.5), 0 0 30px rgba(6,214,160,0.2);">55</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 3: Normal Zone — 75 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-normal">Normal Zone</div>
          <div class="scenario-sublabel">~75 BPM &mdash; Daily activity, walking. ECG: 4s cycle. HRV moderate (35ms).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.35;">
                  <canvas class="ecg-canvas"
                    data-bpm="75"
                    data-hrv="35"
                    data-stroke="#ff006e"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ff006e; text-shadow: 0 0 16px rgba(255,0,110,0.6), 0 0 40px rgba(255,0,110,0.25);">75</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-green); background: rgba(6,214,160,0.12); border: 1px solid rgba(6,214,160,0.25);">Normal Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #f59e0b; text-shadow: 0 0 12px rgba(245,158,11,0.5), 0 0 30px rgba(245,158,11,0.2);">35</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 4: Fat Burn — 125 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-fatburn">Fat Burn</div>
          <div class="scenario-sublabel">~125 BPM &mdash; Moderate exercise, jogging. ECG: 2.5s cycle. HRV lowered (22ms).</div>
          <div class="tri-card tri-card-accent-amber">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-amber"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.4;">
                  <canvas class="ecg-canvas"
                    data-bpm="125"
                    data-hrv="22"
                    data-stroke="#f59e0b"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #f59e0b; text-shadow: 0 0 16px rgba(245,158,11,0.7), 0 0 40px rgba(245,158,11,0.3);">125</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-amber); background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25);">Fat Burn</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #f59e0b; text-shadow: 0 0 12px rgba(245,158,11,0.5), 0 0 30px rgba(245,158,11,0.2);">22</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 5: Peak Zone — 165 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-peak">Peak Zone</div>
          <div class="scenario-sublabel">~165 BPM &mdash; Intense exercise, sprinting. ECG: 1.5s cycle (fastest). HRV stressed (12ms).</div>
          <div class="tri-card tri-card-accent-red">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-red"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.5;">
                  <canvas class="ecg-canvas"
                    data-bpm="165"
                    data-hrv="12"
                    data-stroke="#ef4444"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ef4444; text-shadow: 0 0 20px rgba(239,68,68,0.8), 0 0 50px rgba(239,68,68,0.35);">165</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: #ef4444; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.25);">Peak Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #ef4444; text-shadow: 0 0 12px rgba(239,68,68,0.5), 0 0 30px rgba(239,68,68,0.2);">12</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 6: Deep Sleep — 42 BPM, HRV 80ms -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-bradycardia">Deep Sleep</div>
          <div class="scenario-sublabel">~42 BPM &mdash; Stage 3/4 deep sleep. ECG: 8s cycle. HRV excellent (80ms, green).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.35;">
                  <canvas class="ecg-canvas"
                    data-bpm="42"
                    data-hrv="80"
                    data-stroke="#3a86ff"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #3a86ff; text-shadow: 0 0 16px rgba(58,134,255,0.6), 0 0 40px rgba(58,134,255,0.25);">42</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-blue); background: rgba(58,134,255,0.12); border: 1px solid rgba(58,134,255,0.25);">Bradycardia</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #06d6a0; text-shadow: 0 0 12px rgba(6,214,160,0.5), 0 0 30px rgba(6,214,160,0.2);">80</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 7: Meditation — 55 BPM, HRV 70ms -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-resting">Meditation</div>
          <div class="scenario-sublabel">~55 BPM &mdash; Calm, focused breathing. ECG: 6s cycle. HRV excellent (70ms, green).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.35;">
                  <canvas class="ecg-canvas"
                    data-bpm="55"
                    data-hrv="70"
                    data-stroke="#ff006e"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ff006e; text-shadow: 0 0 16px rgba(255,0,110,0.6), 0 0 40px rgba(255,0,110,0.25);">55</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-green); background: rgba(6,214,160,0.12); border: 1px solid rgba(6,214,160,0.25);">Resting Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #06d6a0; text-shadow: 0 0 12px rgba(6,214,160,0.5), 0 0 30px rgba(6,214,160,0.2);">70</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 8: Post-Coffee — 85 BPM, HRV 18ms -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-normal">Post-Coffee</div>
          <div class="scenario-sublabel">~85 BPM &mdash; Normal HR but poor HRV from stimulants. ECG: 4s cycle. HRV stressed (18ms, red).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.35;">
                  <canvas class="ecg-canvas"
                    data-bpm="85"
                    data-hrv="18"
                    data-stroke="#ff006e"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ff006e; text-shadow: 0 0 16px rgba(255,0,110,0.6), 0 0 40px rgba(255,0,110,0.25);">85</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-green); background: rgba(6,214,160,0.12); border: 1px solid rgba(6,214,160,0.25);">Normal Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #ef4444; text-shadow: 0 0 12px rgba(239,68,68,0.5), 0 0 30px rgba(239,68,68,0.2);">18</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 9: Cardio Warmup — 110 BPM, HRV 28ms -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-fatburn">Cardio Warmup</div>
          <div class="scenario-sublabel">~110 BPM &mdash; Entering fat burn zone, cycling warmup. ECG: 2.5s cycle. HRV moderate (28ms).</div>
          <div class="tri-card tri-card-accent-amber">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-amber"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.4;">
                  <canvas class="ecg-canvas"
                    data-bpm="110"
                    data-hrv="28"
                    data-stroke="#f59e0b"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #f59e0b; text-shadow: 0 0 16px rgba(245,158,11,0.7), 0 0 40px rgba(245,158,11,0.3);">110</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-amber); background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25);">Fat Burn</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #f59e0b; text-shadow: 0 0 12px rgba(245,158,11,0.5), 0 0 30px rgba(245,158,11,0.2);">28</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 10: Sprint Finish — 180 BPM, HRV 8ms -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-peak">Sprint Finish</div>
          <div class="scenario-sublabel">~180 BPM &mdash; Max effort, race finish. ECG: 1.5s cycle (fastest). HRV critically low (8ms, red).</div>
          <div class="tri-card tri-card-accent-red">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-red"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg ecg-canvas-bg" style="opacity: 0.5;">
                  <canvas class="ecg-canvas"
                    data-bpm="180"
                    data-hrv="8"
                    data-stroke="#ef4444"
                    width="400" height="120">
                  </canvas>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ef4444; text-shadow: 0 0 20px rgba(239,68,68,0.8), 0 0 50px rgba(239,68,68,0.35);">180</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: #ef4444; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.25);">Peak Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #ef4444; text-shadow: 0 0 12px rgba(239,68,68,0.5), 0 0 30px rgba(239,68,68,0.2);">8</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ==================== 2. DAILY ACTIVITY ==================== -->
    <div class="component-section">
      <div class="component-name">DailyActivity</div>
      <div class="component-description">
