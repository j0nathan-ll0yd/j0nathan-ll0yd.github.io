---
import fs from 'node:fs';
import path from 'node:path';
import Showcase from '../layouts/Showcase.astro';
import HeartRate from '../components/HeartRate.astro';
import DailyActivity from '../components/DailyActivity.astro';
import Workouts from '../components/Workouts.astro';
import NightSummary from '../components/NightSummary.astro';
import Hydration from '../components/Hydration.astro';


const dataDir = path.join(process.cwd(), 'data');
const health = JSON.parse(fs.readFileSync(path.join(dataDir, 'health.json'), 'utf-8'));

const empty = JSON.parse(fs.readFileSync(path.join(dataDir, 'showcase-empty.json'), 'utf-8'));
const healthWithWorkouts = { ...health, workouts: health.sampleWorkouts };
---
<Showcase title="Health & Wellness">
  <link slot="head" rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  <script slot="head" is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <main class="lib-container">
    <h1 class="lib-page-title">Health &amp; Wellness</h1>
    <p class="lib-page-desc">
      The six health and wellness components: heart rate with ECG waveform, daily activity metrics, workout tracking, sleep summary, hydration levels, and current location with map.
    </p>

    <h2 class="lib-section-title">Vitals</h2>

    <!-- ==================== 1. HEART RATE ==================== -->
    <div class="component-section">
      <div class="component-name">HeartRate</div>
      <div class="component-description">
        Real-time heart rate display with animated ECG waveform background, BPM readout, zone badge, and HRV metric. Contains SVG filter id="ecgGlow" so only one component instance per page.
      </div>
      <div class="component-classes">.tri-card-accent-pink, .hr-layout, .hr-ecg-bg, .ecg-svg, .hr-overlay, .pulse-bpm, .pulse-status-badge, .hr-hrv-value</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-pink">
              <div class="widget-header">
                <span class="widget-label">Heart Rate</span>
                <div class="widget-header-right">
                  <div class="live-dot live-dot-pink"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="position: relative; min-height: 100px;">
                  <div class="skeleton-bar" style="width: 100%; height: 60px; border-radius: 8px; margin-bottom: 12px;"></div>
                  <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div class="skeleton-bar" style="width: 80px; height: 28px;"></div>
                    <div class="skeleton-bar" style="width: 50px; height: 18px; border-radius: 50px;"></div>
                  </div>
                  <div style="display: flex; justify-content: flex-end; margin-top: 8px;">
                    <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <!-- Hand-written: avoids duplicate SVG id="ecgGlow" -->
            <div class="tri-card tri-card-accent-pink">
              <div class="widget-header">
                <span class="widget-label">Heart Rate</span>
                <div class="widget-header-right">
                  <div class="live-dot live-dot-pink"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div class="hr-layout">
                  <div class="hr-overlay" style="position: relative;">
                    <div class="pulse-bpm" style="color: var(--text-muted);">---</div>
                    <div class="pulse-status-badge" style="opacity: 0.3;">---</div>
                  </div>
                </div>
                <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
                  <span class="hr-hrv-value" style="color: var(--text-muted);">HRV: ---</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <HeartRate health={health} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== HEART RATE ZONES ==================== -->
    <div class="component-section">
      <div class="component-name">HeartRate &mdash; Zone Gallery</div>
      <div class="component-description">All 5 heart rate zones plus 5 additional scenarios showing how BPM, HRV, ECG waveform amplitude, ECG scroll speed, and accent colors change across conditions. Each card has a unique SVG filter ID to avoid conflicts.</div>
      <div class="scenario-grid">

        <!-- Card 1: Bradycardia — 40 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-bradycardia">Bradycardia</div>
          <div class="scenario-sublabel">~40 BPM &mdash; Deep sleep, very low activity. ECG: 8s cycle (slowest). HRV high (62ms).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg" style="opacity: 0.35;">
                  <svg class="ecg-svg" viewBox="0 0 800 100" preserveAspectRatio="none" style="animation-duration: 8s;">
                    <defs><filter id="ecgGlow1"><feGaussianBlur stdDeviation="2" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
                    <path class="ecg-line" d="M 0 55 L 10 55 Q 18 52.0 26 55 L 34 55 L 38 57.0 L 44 17.5 L 50 59.0 L 56 55 Q 68 50.0 80 55 L 100 55 L 110 55 Q 118 52.0 126 55 L 134 55 L 138 57.0 L 144 17.5 L 150 59.0 L 156 55 Q 168 50.0 180 55 L 200 55 L 210 55 Q 218 52.0 226 55 L 234 55 L 238 57.0 L 244 17.5 L 250 59.0 L 256 55 Q 268 50.0 280 55 L 300 55 L 310 55 Q 318 52.0 326 55 L 334 55 L 338 57.0 L 344 17.5 L 350 59.0 L 356 55 Q 368 50.0 380 55 L 400 55 L 410 55 Q 418 52.0 426 55 L 434 55 L 438 57.0 L 444 17.5 L 450 59.0 L 456 55 Q 468 50.0 480 55 L 500 55 L 510 55 Q 518 52.0 526 55 L 534 55 L 538 57.0 L 544 17.5 L 550 59.0 L 556 55 Q 568 50.0 580 55 L 600 55 L 610 55 Q 618 52.0 626 55 L 634 55 L 638 57.0 L 644 17.5 L 650 59.0 L 656 55 Q 668 50.0 680 55 L 700 55 L 710 55 Q 718 52.0 726 55 L 734 55 L 738 57.0 L 744 17.5 L 750 59.0 L 756 55 Q 768 50.0 780 55 L 800 55" style="stroke: #3a86ff; filter: url(#ecgGlow1);"/>
                  </svg>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #3a86ff; text-shadow: 0 0 16px rgba(58,134,255,0.6), 0 0 40px rgba(58,134,255,0.25);">40</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-blue); background: rgba(58,134,255,0.12); border: 1px solid rgba(58,134,255,0.25);">Bradycardia</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #06d6a0; text-shadow: 0 0 12px rgba(6,214,160,0.5), 0 0 30px rgba(6,214,160,0.2);">62</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 2: Resting Zone — 52 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-resting">Resting Zone</div>
          <div class="scenario-sublabel">~52 BPM &mdash; Relaxed or light sleep. ECG: 6s cycle. HRV good (55ms).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg" style="opacity: 0.35;">
                  <svg class="ecg-svg" viewBox="0 0 800 100" preserveAspectRatio="none" style="animation-duration: 6s;">
                    <defs><filter id="ecgGlow2"><feGaussianBlur stdDeviation="2" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
                    <path class="ecg-line" d="M 0 55 L 10 55 Q 18 51.1 26 55 L 34 55 L 38 57.6 L 44 15.2 L 50 60.2 L 56 55 Q 68 48.5 80 55 L 100 55 L 110 55 Q 118 51.1 126 55 L 134 55 L 138 57.6 L 144 15.2 L 150 60.2 L 156 55 Q 168 48.5 180 55 L 200 55 L 210 55 Q 218 51.1 226 55 L 234 55 L 238 57.6 L 244 15.2 L 250 60.2 L 256 55 Q 268 48.5 280 55 L 300 55 L 310 55 Q 318 51.1 326 55 L 334 55 L 338 57.6 L 344 15.2 L 350 60.2 L 356 55 Q 368 48.5 380 55 L 400 55 L 410 55 Q 418 51.1 426 55 L 434 55 L 438 57.6 L 444 15.2 L 450 60.2 L 456 55 Q 468 48.5 480 55 L 500 55 L 510 55 Q 518 51.1 526 55 L 534 55 L 538 57.6 L 544 15.2 L 550 60.2 L 556 55 Q 568 48.5 580 55 L 600 55 L 610 55 Q 618 51.1 626 55 L 634 55 L 638 57.6 L 644 15.2 L 650 60.2 L 656 55 Q 668 48.5 680 55 L 700 55 L 710 55 Q 718 51.1 726 55 L 734 55 L 738 57.6 L 744 15.2 L 750 60.2 L 756 55 Q 768 48.5 780 55 L 800 55" style="stroke: #ff006e; filter: url(#ecgGlow2);"/>
                  </svg>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ff006e; text-shadow: 0 0 16px rgba(255,0,110,0.6), 0 0 40px rgba(255,0,110,0.25);">52</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-green); background: rgba(6,214,160,0.12); border: 1px solid rgba(6,214,160,0.25);">Resting Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #06d6a0; text-shadow: 0 0 12px rgba(6,214,160,0.5), 0 0 30px rgba(6,214,160,0.2);">55</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 3: Normal Zone — 75 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-normal">Normal Zone</div>
          <div class="scenario-sublabel">~75 BPM &mdash; Daily activity, walking. ECG: 4s cycle. HRV moderate (35ms).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg" style="opacity: 0.35;">
                  <svg class="ecg-svg" viewBox="0 0 800 100" preserveAspectRatio="none" style="animation-duration: 4s;">
                    <defs><filter id="ecgGlow3"><feGaussianBlur stdDeviation="2" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
                    <path class="ecg-line" d="M 0 55 L 10 55 Q 18 49.4 26 55 L 34 55 L 38 58.8 L 44 10.9 L 50 62.5 L 56 55 Q 68 45.6 80 55 L 100 55 L 110 55 Q 118 49.4 126 55 L 134 55 L 138 58.8 L 144 10.9 L 150 62.5 L 156 55 Q 168 45.6 180 55 L 200 55 L 210 55 Q 218 49.4 226 55 L 234 55 L 238 58.8 L 244 10.9 L 250 62.5 L 256 55 Q 268 45.6 280 55 L 300 55 L 310 55 Q 318 49.4 326 55 L 334 55 L 338 58.8 L 344 10.9 L 350 62.5 L 356 55 Q 368 45.6 380 55 L 400 55 L 410 55 Q 418 49.4 426 55 L 434 55 L 438 58.8 L 444 10.9 L 450 62.5 L 456 55 Q 468 45.6 480 55 L 500 55 L 510 55 Q 518 49.4 526 55 L 534 55 L 538 58.8 L 544 10.9 L 550 62.5 L 556 55 Q 568 45.6 580 55 L 600 55 L 610 55 Q 618 49.4 626 55 L 634 55 L 638 58.8 L 644 10.9 L 650 62.5 L 656 55 Q 668 45.6 680 55 L 700 55 L 710 55 Q 718 49.4 726 55 L 734 55 L 738 58.8 L 744 10.9 L 750 62.5 L 756 55 Q 768 45.6 780 55 L 800 55" style="stroke: #ff006e; filter: url(#ecgGlow3);"/>
                  </svg>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ff006e; text-shadow: 0 0 16px rgba(255,0,110,0.6), 0 0 40px rgba(255,0,110,0.25);">75</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-green); background: rgba(6,214,160,0.12); border: 1px solid rgba(6,214,160,0.25);">Normal Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #f59e0b; text-shadow: 0 0 12px rgba(245,158,11,0.5), 0 0 30px rgba(245,158,11,0.2);">35</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 4: Fat Burn — 125 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-fatburn">Fat Burn</div>
          <div class="scenario-sublabel">~125 BPM &mdash; Moderate exercise, jogging. ECG: 2.5s cycle. HRV lowered (22ms).</div>
          <div class="tri-card tri-card-accent-amber">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-amber"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg" style="opacity: 0.4;">
                  <svg class="ecg-svg" viewBox="0 0 800 100" preserveAspectRatio="none" style="animation-duration: 2.5s;">
                    <defs><filter id="ecgGlow4"><feGaussianBlur stdDeviation="2" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
                    <path class="ecg-line" d="M 0 55 L 10 55 Q 18 45.6 26 55 L 34 55 L 38 61.2 L 44 1.6 L 50 67.5 L 56 55 Q 68 39.4 80 55 L 100 55 L 110 55 Q 118 45.6 126 55 L 134 55 L 138 61.2 L 144 1.6 L 150 67.5 L 156 55 Q 168 39.4 180 55 L 200 55 L 210 55 Q 218 45.6 226 55 L 234 55 L 238 61.2 L 244 1.6 L 250 67.5 L 256 55 Q 268 39.4 280 55 L 300 55 L 310 55 Q 318 45.6 326 55 L 334 55 L 338 61.2 L 344 1.6 L 350 67.5 L 356 55 Q 368 39.4 380 55 L 400 55 L 410 55 Q 418 45.6 426 55 L 434 55 L 438 61.2 L 444 1.6 L 450 67.5 L 456 55 Q 468 39.4 480 55 L 500 55 L 510 55 Q 518 45.6 526 55 L 534 55 L 538 61.2 L 544 1.6 L 550 67.5 L 556 55 Q 568 39.4 580 55 L 600 55 L 610 55 Q 618 45.6 626 55 L 634 55 L 638 61.2 L 644 1.6 L 650 67.5 L 656 55 Q 668 39.4 680 55 L 700 55 L 710 55 Q 718 45.6 726 55 L 734 55 L 738 61.2 L 744 1.6 L 750 67.5 L 756 55 Q 768 39.4 780 55 L 800 55" style="stroke: #f59e0b; filter: url(#ecgGlow4);"/>
                  </svg>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #f59e0b; text-shadow: 0 0 16px rgba(245,158,11,0.7), 0 0 40px rgba(245,158,11,0.3);">125</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-amber); background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25);">Fat Burn</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #f59e0b; text-shadow: 0 0 12px rgba(245,158,11,0.5), 0 0 30px rgba(245,158,11,0.2);">22</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 5: Peak Zone — 165 BPM -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-peak">Peak Zone</div>
          <div class="scenario-sublabel">~165 BPM &mdash; Intense exercise, sprinting. ECG: 1.5s cycle (fastest). HRV stressed (12ms).</div>
          <div class="tri-card tri-card-accent-red">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-red"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg" style="opacity: 0.5;">
                  <svg class="ecg-svg" viewBox="0 0 800 100" preserveAspectRatio="none" style="animation-duration: 1.5s;">
                    <defs><filter id="ecgGlow5"><feGaussianBlur stdDeviation="2" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
                    <path class="ecg-line" d="M 0 55 L 10 55 Q 18 44.2 26 55 L 34 55 L 38 62.2 L 44 -2.0 L 50 69.4 L 56 55 Q 68 37.0 80 55 L 100 55 L 110 55 Q 118 44.2 126 55 L 134 55 L 138 62.2 L 144 -2.0 L 150 69.4 L 156 55 Q 168 37.0 180 55 L 200 55 L 210 55 Q 218 44.2 226 55 L 234 55 L 238 62.2 L 244 -2.0 L 250 69.4 L 256 55 Q 268 37.0 280 55 L 300 55 L 310 55 Q 318 44.2 326 55 L 334 55 L 338 62.2 L 344 -2.0 L 350 69.4 L 356 55 Q 368 37.0 380 55 L 400 55 L 410 55 Q 418 44.2 426 55 L 434 55 L 438 62.2 L 444 -2.0 L 450 69.4 L 456 55 Q 468 37.0 480 55 L 500 55 L 510 55 Q 518 44.2 526 55 L 534 55 L 538 62.2 L 544 -2.0 L 550 69.4 L 556 55 Q 568 37.0 580 55 L 600 55 L 610 55 Q 618 44.2 626 55 L 634 55 L 638 62.2 L 644 -2.0 L 650 69.4 L 656 55 Q 668 37.0 680 55 L 700 55 L 710 55 Q 718 44.2 726 55 L 734 55 L 738 62.2 L 744 -2.0 L 750 69.4 L 756 55 Q 768 37.0 780 55 L 800 55" style="stroke: #ef4444; filter: url(#ecgGlow5);"/>
                  </svg>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #ef4444; text-shadow: 0 0 20px rgba(239,68,68,0.8), 0 0 50px rgba(239,68,68,0.35);">165</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: #ef4444; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.25);">Peak Zone</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #ef4444; text-shadow: 0 0 12px rgba(239,68,68,0.5), 0 0 30px rgba(239,68,68,0.2);">12</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 6: Deep Sleep — 42 BPM, HRV 80ms -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-bradycardia">Deep Sleep</div>
          <div class="scenario-sublabel">~42 BPM &mdash; Stage 3/4 deep sleep. ECG: 8s cycle. HRV excellent (80ms, green).</div>
          <div class="tri-card tri-card-accent-pink">
            <div class="widget-header">
              <h3 class="widget-label">Heart Rate</h3>
              <div class="widget-header-right">
                <div class="live-dot live-dot-pink"></div>
                <span class="widget-timestamp">live</span>
              </div>
            </div>
            <div class="widget-body">
              <div class="hr-layout">
                <div class="hr-ecg-bg" style="opacity: 0.35;">
                  <svg class="ecg-svg" viewBox="0 0 800 100" preserveAspectRatio="none" style="animation-duration: 8s;">
                    <defs><filter id="ecgGlow6"><feGaussianBlur stdDeviation="2" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
                    <path class="ecg-line" d="M 0 55 L 10 55 Q 18 51.9 26 55 L 34 55 L 38 57.1 L 44 17.1 L 50 59.2 L 56 55 Q 68 49.8 80 55 L 100 55 L 110 55 Q 118 51.9 126 55 L 134 55 L 138 57.1 L 144 17.1 L 150 59.2 L 156 55 Q 168 49.8 180 55 L 200 55 L 210 55 Q 218 51.9 226 55 L 234 55 L 238 57.1 L 244 17.1 L 250 59.2 L 256 55 Q 268 49.8 280 55 L 300 55 L 310 55 Q 318 51.9 326 55 L 334 55 L 338 57.1 L 344 17.1 L 350 59.2 L 356 55 Q 368 49.8 380 55 L 400 55 L 410 55 Q 418 51.9 426 55 L 434 55 L 438 57.1 L 444 17.1 L 450 59.2 L 456 55 Q 468 49.8 480 55 L 500 55 L 510 55 Q 518 51.9 526 55 L 534 55 L 538 57.1 L 544 17.1 L 550 59.2 L 556 55 Q 568 49.8 580 55 L 600 55 L 610 55 Q 618 51.9 626 55 L 634 55 L 638 57.1 L 644 17.1 L 650 59.2 L 656 55 Q 668 49.8 680 55 L 700 55 L 710 55 Q 718 51.9 726 55 L 734 55 L 738 57.1 L 744 17.1 L 750 59.2 L 756 55 Q 768 49.8 780 55 L 800 55" style="stroke: #3a86ff; filter: url(#ecgGlow6);"/>
                  </svg>
                </div>
                <div class="hr-overlay">
                  <div class="hr-overlay-left">
                    <div>
                      <span class="pulse-bpm" style="color: #3a86ff; text-shadow: 0 0 16px rgba(58,134,255,0.6), 0 0 40px rgba(58,134,255,0.25);">42</span><span class="pulse-bpm-unit">BPM</span>
                    </div>
                    <span class="pulse-status-badge" style="color: var(--neon-blue); background: rgba(58,134,255,0.12); border: 1px solid rgba(58,134,255,0.25);">Bradycardia</span>
                  </div>
                  <div class="hr-overlay-right">
                    <span class="hr-hrv-label">HRV</span>
                    <span class="hr-hrv-value" style="color: #06d6a0; text-shadow: 0 0 12px rgba(6,214,160,0.5), 0 0 30px rgba(6,214,160,0.2);">80</span>
                    <span class="hr-hrv-unit">ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 7: Meditation — 55 BPM, HRV 70ms -->
        <div class="scenario-card">
          <div class="scenario-label scenario-label-resting">Meditation</div>
          <div class="scenario-sublabel">~55 BPM &mdash; Calm, focused breathing. ECG: 6s cycle. HRV excellent (70ms, green).</div>
