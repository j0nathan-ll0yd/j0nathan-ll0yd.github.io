<script is:inline>
(function() {
  var canvases = document.querySelectorAll('.ecg-canvas');
  if (!canvases.length) return;

  var motionReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- Waveform generator: ECGSYN Gaussian model ----
  function ecgBeat(bpm, numSamples) {
    var hrFact = Math.sqrt(bpm / 60);
    // [amplitude, center, baseWidth, isQRS]
    var waves = [
      [0.15,  0.12, 0.040, false],  // P
      [-0.10, 0.28, 0.015, true],   // Q
      [1.00,  0.32, 0.018, true],   // R
      [-0.25, 0.38, 0.020, true],   // S
      [0.30,  0.58, 0.070, false]   // T
    ];
    var samples = [];
    var i, j, t, val, w, width, center, exponent;
    for (i = 0; i < numSamples; i++) {
      t = i / numSamples;
      val = 0;
      for (j = 0; j < waves.length; j++) {
        w = waves[j];
        width = w[3] ? w[2] : w[2] / hrFact;
        center = w[1];
        // T-wave shifts earlier at high HR (QT shortening)
        if (j === 4) {
          center = 0.58 - (hrFact - 1) * 0.08;
          if (center < 0.42) center = 0.42;
        }
        exponent = (t - center) / width;
        val += w[0] * Math.exp(-0.5 * exponent * exponent);
      }
      samples[i] = val;
    }
    return samples;
  }

  // ---- HRV beat spacing jitter ----
  function nextRR(meanRR, sdnn) {
    var jitter = (Math.random() - 0.5) * 2 * sdnn;
    var rr = meanRR + jitter;
    if (rr < 250) rr = 250;
    if (rr > 2000) rr = 2000;
    return rr;
  }

  // ---- Draw medical grid (call once on init/resize) ----
  function drawGrid(ctx, w, h) {
    var gridSpacing = 20;
    var i;
    ctx.save();
    ctx.lineWidth = 0.5;
    // Minor grid
    ctx.strokeStyle = 'rgba(255,255,255,0.03)';
    for (i = 0; i <= w; i += gridSpacing) {
      ctx.beginPath();
      ctx.moveTo(Math.round(i) + 0.5, 0);
      ctx.lineTo(Math.round(i) + 0.5, h);
      ctx.stroke();
    }
    for (i = 0; i <= h; i += gridSpacing) {
      ctx.beginPath();
      ctx.moveTo(0, Math.round(i) + 0.5);
      ctx.lineTo(w, Math.round(i) + 0.5);
      ctx.stroke();
    }
    // Major grid (every 5th line)
    ctx.strokeStyle = 'rgba(255,255,255,0.07)';
    for (i = 0; i <= w; i += gridSpacing * 5) {
      ctx.beginPath();
      ctx.moveTo(Math.round(i) + 0.5, 0);
      ctx.lineTo(Math.round(i) + 0.5, h);
      ctx.stroke();
    }
    for (i = 0; i <= h; i += gridSpacing * 5) {
      ctx.beginPath();
      ctx.moveTo(0, Math.round(i) + 0.5);
      ctx.lineTo(w, Math.round(i) + 0.5);
      ctx.stroke();
    }
    ctx.restore();
  }

  // ---- Redraw grid in a strip (used by sweep erase bar) ----
  function redrawGridStrip(ctx, x, stripW, h) {
    var gridSpacing = 20;
    var i, gx, gy;
    var x1 = x;
    var x2 = x + stripW;
    ctx.save();
    ctx.lineWidth = 0.5;
    // Minor vertical lines in strip
    ctx.strokeStyle = 'rgba(255,255,255,0.03)';
    var firstMinor = Math.floor(x1 / gridSpacing) * gridSpacing;
    for (gx = firstMinor; gx <= x2; gx += gridSpacing) {
      if (gx >= x1 && gx <= x2) {
        ctx.beginPath();
        ctx.moveTo(Math.round(gx) + 0.5, 0);
        ctx.lineTo(Math.round(gx) + 0.5, h);
        ctx.stroke();
      }
    }
    // Minor horizontal lines (full width, so always draw in strip)
    for (gy = 0; gy <= h; gy += gridSpacing) {
      ctx.beginPath();
      ctx.moveTo(x1, Math.round(gy) + 0.5);
      ctx.lineTo(x2, Math.round(gy) + 0.5);
      ctx.stroke();
    }
    // Major vertical lines in strip
    ctx.strokeStyle = 'rgba(255,255,255,0.07)';
    var firstMajor = Math.floor(x1 / (gridSpacing * 5)) * (gridSpacing * 5);
    for (gx = firstMajor; gx <= x2; gx += gridSpacing * 5) {
      if (gx >= x1 && gx <= x2) {
        ctx.beginPath();
        ctx.moveTo(Math.round(gx) + 0.5, 0);
        ctx.lineTo(Math.round(gx) + 0.5, h);
        ctx.stroke();
      }
    }
    // Major horizontal lines in strip
    ctx.strokeStyle = 'rgba(255,255,255,0.07)';
    for (gy = 0; gy <= h; gy += gridSpacing * 5) {
      ctx.beginPath();
      ctx.moveTo(x1, Math.round(gy) + 0.5);
      ctx.lineTo(x2, Math.round(gy) + 0.5);
      ctx.stroke();
    }
    ctx.restore();
  }

  // ---- Resize canvas buffer to CSS size * DPR ----
  function resizeCanvas(widget) {
    var rect = widget.canvas.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    widget.canvas.width = Math.round(rect.width * dpr);
    widget.canvas.height = Math.round(rect.height * dpr);
    widget.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    widget.canvasW = rect.width;
    widget.canvasH = rect.height;
    // Fill background
    widget.ctx.fillStyle = '#06060f';
    widget.ctx.fillRect(0, 0, rect.width, rect.height);
    // Draw grid
    drawGrid(widget.ctx, rect.width, rect.height);
    // Reset cursor
    widget.cursorX = 0;
    widget.prevX = 0;
    widget.prevY = rect.height * 0.6;
  }

  // ---- Render one frame per widget ----
  function renderWidget(widget, now) {
    var ctx = widget.ctx;
    var w = widget.canvasW;
    var h = widget.canvasH;

    // Advance cursor
    var elapsed = now - widget.lastFrameTime;
    if (elapsed > 100) elapsed = 100; // cap large gaps (e.g. tab switch)
    widget.lastFrameTime = now;
    var advance = (elapsed / 1000) * widget.pixelsPerSecond;
    var x = widget.cursorX + advance;
    var wrapped = false;
    if (x >= w) {
      x = x - w;
      wrapped = true;
    }

    var clearWidth = Math.max(10, w * 0.04);

    // Handle wrap-around clear
    if (wrapped) {
      // Clear from old position to right edge
      ctx.fillStyle = '#06060f';
      ctx.fillRect(Math.round(widget.cursorX), 0, Math.ceil(w - widget.cursorX), h);
      redrawGridStrip(ctx, Math.round(widget.cursorX), Math.ceil(w - widget.cursorX), h);
    }
    // Clear strip ahead of current cursor
    ctx.fillStyle = '#06060f';
    ctx.fillRect(Math.round(x), 0, Math.ceil(clearWidth), h);
    redrawGridStrip(ctx, Math.round(x), Math.ceil(clearWidth), h);

    // Determine beat sample
    var baseline = h * 0.6;
    var amplitude = h * 0.48;
    var sample = 0;

    if (now >= widget.nextBeatTime) {
      widget.currentRR = nextRR(widget.meanRR, widget.hrv);
      widget.nextBeatTime = now + widget.currentRR;
      widget.beatStartTime = now;
      var activeFraction = 0.55 + 0.30 * (1 - Math.exp(-(widget.bpm - 40) / 80));
      widget.beatDurationMs = widget.currentRR * activeFraction;
    }

    var timeSinceBeat = now - widget.beatStartTime;
    if (timeSinceBeat >= 0 && timeSinceBeat < widget.beatDurationMs) {
      var progress = timeSinceBeat / widget.beatDurationMs;
      var idx = Math.floor(progress * widget.samplesPerBeat);
      if (idx >= widget.samplesPerBeat) idx = widget.samplesPerBeat - 1;
      sample = widget.beatSamples[idx];
    }

    var y = baseline - sample * amplitude;

    // Draw ECG line segment (connect prev to current)
    if (!wrapped) {
      // Glow: wide dim stroke
      ctx.beginPath();
      ctx.moveTo(Math.round(widget.prevX), Math.round(widget.prevY));
      ctx.lineTo(Math.round(x), Math.round(y));
      ctx.strokeStyle = widget.stroke;
      ctx.globalAlpha = 0.25;
      ctx.lineWidth = 3.5;
      ctx.stroke();
      // Core: narrow bright stroke
      ctx.beginPath();
      ctx.moveTo(Math.round(widget.prevX), Math.round(widget.prevY));
      ctx.lineTo(Math.round(x), Math.round(y));
      ctx.globalAlpha = 1.0;
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.globalAlpha = 1.0;
    } else {
      // Just place a dot at new position after wrap, no connecting line
      ctx.beginPath();
      ctx.arc(Math.round(x), Math.round(y), 1.5, 0, Math.PI * 2);
      ctx.fillStyle = widget.stroke;
      ctx.globalAlpha = 1.0;
      ctx.fill();
    }

    widget.cursorX = x;
    widget.prevX = x;
    widget.prevY = y;
  }

  // ---- Draw a single static PQRST waveform (reduced motion) ----
  function drawStaticWaveform(widget) {
    var ctx = widget.ctx;
    var w = widget.canvasW;
    var h = widget.canvasH;
    var baseline = h * 0.6;
    var amplitude = h * 0.48;
    var samples = widget.beatSamples;
    var n = samples.length;
    // Draw waveform centered in canvas, covering 60% of width
    var waveW = w * 0.6;
    var startX = w * 0.2;
    ctx.beginPath();
    ctx.moveTo(0, baseline);
    ctx.lineTo(startX, baseline);
    var i, x, y;
    for (i = 0; i < n; i++) {
      x = startX + (i / (n - 1)) * waveW;
      y = baseline - samples[i] * amplitude;
      if (i === 0) {
        ctx.moveTo(x, y);
      } else {
        ctx.lineTo(x, y);
      }
    }
    ctx.lineTo(w, baseline);
    ctx.strokeStyle = widget.stroke;
    ctx.globalAlpha = 0.7;
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.globalAlpha = 1.0;
  }

  // ---- Shared animation loop ----
  var widgets = [];

  function animationLoop(timestamp) {
    var i;
    for (i = 0; i < widgets.length; i++) {
      if (widgets[i].isVisible) {
        renderWidget(widgets[i], timestamp);
      }
    }
    requestAnimationFrame(animationLoop);
  }

  // ---- Initialize widgets ----
  var i, canvas, ctx, bpm, hrv, stroke, widget, now;
  now = performance.now();

  for (i = 0; i < canvases.length; i++) {
    canvas = canvases[i];
    ctx = canvas.getContext('2d', { alpha: false });
    bpm = parseInt(canvas.getAttribute('data-bpm'), 10);
    hrv = parseInt(canvas.getAttribute('data-hrv'), 10);
    stroke = canvas.getAttribute('data-stroke');

    widget = {
      canvas: canvas,
      ctx: ctx,
      bpm: bpm,
      hrv: hrv,
      stroke: stroke,
      beatSamples: ecgBeat(bpm, 64),
      samplesPerBeat: 64,
      cursorX: 0,
      canvasW: 0,
      canvasH: 0,
      pixelsPerSecond: 50,
      meanRR: 60000 / bpm,
      nextBeatTime: now + Math.random() * (60000 / bpm),
      beatStartTime: now - 9999,
      beatProgress: 0,
      beatDurationMs: 0,
      currentRR: 60000 / bpm,
      lastFrameTime: now,
      prevX: 0,
      prevY: 0,
      isVisible: false
    };

    widgets.push(widget);
    resizeCanvas(widget);

    if (motionReduced) {
      drawStaticWaveform(widget);
    }
  }

  if (motionReduced) return;

  // ---- IntersectionObserver ----
  var observer = new IntersectionObserver(function(entries) {
    var j, k, entry;
    for (j = 0; j < entries.length; j++) {
      entry = entries[j];
      for (k = 0; k < widgets.length; k++) {
        if (widgets[k].canvas === entry.target) {
          widgets[k].isVisible = entry.isIntersecting;
          if (entry.isIntersecting) {
            // Reset lastFrameTime to avoid large elapsed gap after being off-screen
            widgets[k].lastFrameTime = performance.now();
          }
          break;
        }
      }
    }
  }, { threshold: 0.1 });

  for (i = 0; i < widgets.length; i++) {
    observer.observe(widgets[i].canvas);
  }

  // ---- Debounced resize ----
  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      var k;
      for (k = 0; k < widgets.length; k++) {
        resizeCanvas(widgets[k]);
      }
    }, 200);
  });

  // ---- Start animation ----
  requestAnimationFrame(animationLoop);
})();
</script>
