---
import fs from 'node:fs';
import path from 'node:path';
import Showcase from '../layouts/Showcase.astro';
import HeartRate from '../components/HeartRate.astro';
import DailyActivity from '../components/DailyActivity.astro';
import NightSummary from '../components/NightSummary.astro';
import Hydration from '../components/Hydration.astro';
import Bookshelf from '../components/Bookshelf.astro';
import BookModal from '../components/BookModal.astro';
import ReadingFeed from '../components/ReadingFeed.astro';

const dataDir = path.join(process.cwd(), 'data');
const health = JSON.parse(fs.readFileSync(path.join(dataDir, 'health.json'), 'utf-8'));
const books = JSON.parse(fs.readFileSync(path.join(dataDir, 'books.json'), 'utf-8'));
const reading = JSON.parse(fs.readFileSync(path.join(dataDir, 'reading.json'), 'utf-8'));

const devices = [
  /* ── Phones ── */
  { label: 'iPhone SE',       width: 375,  height: 812,  frame: 'phone',   category: 'Phones' },
  { label: 'iPhone 16',       width: 390,  height: 844,  frame: 'phone',   category: 'Phones' },
  { label: 'Android (Pixel)', width: 412,  height: 915,  frame: 'phone',   category: 'Phones' },
  { label: 'iPhone Pro Max',  width: 430,  height: 932,  frame: 'phone',   category: 'Phones' },
  /* ── Tablets ── */
  { label: 'iPad Portrait',   width: 768,  height: 1024, frame: 'tablet',  category: 'Tablets' },
  { label: 'iPad Landscape',  width: 1024, height: 768,  frame: 'tablet',  category: 'Tablets' },
  /* ── Desktops ── */
  { label: 'Laptop',          width: 1366, height: 768,  frame: 'browser', category: 'Desktops' },
  { label: 'Desktop HD',      width: 1920, height: 1080, frame: 'browser', category: 'Desktops' },
];

/* Group devices by category for section headers */
const categories = [...new Set(devices.map(d => d.category))];
---
<Showcase title="Responsive Preview">
  <main class="lib-container">
    <h1 class="lib-page-title">Responsive Preview</h1>
    <p class="lib-page-desc">Live dashboard at 8 real-world viewport sizes (phones, tablets, desktops), plus interactive widget scaling to test container queries and fluid tokens.</p>

    <!-- ===== DEVICE PREVIEW ===== -->
    <h2 class="lib-section-title">Device Preview</h2>

    <div class="rp-toolbar">
      <button class="rp-view-btn active" data-view="grid">Grid</button>
      <button class="rp-view-btn" data-view="focus">Focus</button>
      <select class="rp-focus-select" style="display: none;">
        {devices.map((d, i) => (
          <option value={String(i)}>{d.label} ({d.width}px)</option>
        ))}
      </select>
    </div>

    <div class="rp-container rp-grid-mode">
      {categories.map(cat => (
        <Fragment>
          <div class="rp-category-header">{cat}</div>
          {devices.filter(d => d.category === cat).map(d => {
            const i = devices.indexOf(d);
            return (
              <div class="rp-device" data-category={cat}>
                <div class="rp-device-label">
                  <span class="rp-device-name">{d.label}</span>
                  <span class="rp-device-size">{d.width} &times; {d.height}</span>
                </div>
                <div class={`rp-device-frame rp-frame-${d.frame}`}>
                  {d.frame === 'browser' && (
                    <div class="rp-browser-chrome">
                      <div class="rp-traffic-dot rp-dot-red"></div>
                      <div class="rp-traffic-dot rp-dot-yellow"></div>
                      <div class="rp-traffic-dot rp-dot-green"></div>
                    </div>
                  )}
                  {d.frame === 'phone' && <div class="rp-phone-notch"></div>}
                  <div class="rp-iframe-wrapper">
                    <iframe
                      src="/"
                      width={String(d.width)}
                      height={String(d.height)}
                      title={`${d.label} preview (${d.width}px)`}
                      loading={i === 0 ? 'eager' : 'lazy'}
                    ></iframe>
                  </div>
                </div>
              </div>
            );
          })}
        </Fragment>
      ))}
    </div>

    <!-- ===== WIDGET SCALE ===== -->
    <h2 class="lib-section-title">Widget Scale</h2>
    <p class="lib-page-desc" style="margin-bottom: 20px;">
      Drag the slider or pick a preset to resize all widget containers. Container queries and fluid tokens adapt each widget to its available width.
    </p>

    <div class="ws-toolbar">
      <div class="ws-presets">
        <button class="ws-preset" data-width="200">200px</button>
        <button class="ws-preset" data-width="300">300px</button>
        <button class="ws-preset active" data-width="400">400px</button>
        <button class="ws-preset" data-width="600">600px</button>
      </div>
      <div class="ws-slider-wrap">
        <input type="range" class="ws-slider" id="ws-slider" min="180" max="620" value="400" step="1">
        <span class="ws-width-label" id="ws-width-label">400px</span>
      </div>
    </div>

    <div class="ws-grid">
      <div class="ws-widget" style="width: 400px;">
        <div class="ws-widget-name">HeartRate</div>
        <HeartRate health={health} />
      </div>
      <div class="ws-widget" style="width: 400px;">
        <div class="ws-widget-name">DailyActivity</div>
        <DailyActivity health={health} />
      </div>
      <div class="ws-widget" style="width: 400px;">
        <div class="ws-widget-name">NightSummary</div>
        <NightSummary health={health} />
      </div>
      <div class="ws-widget" style="width: 400px;">
        <div class="ws-widget-name">Hydration</div>
        <Hydration health={health} />
      </div>
      <div class="ws-widget" style="width: 400px;">
        <div class="ws-widget-name">Bookshelf</div>
        <Bookshelf books={books} />
      </div>
      <div class="ws-widget" style="width: 400px;">
        <div class="ws-widget-name">ReadingFeed</div>
        <ReadingFeed reading={reading} />
      </div>
    </div>

    <BookModal books={books} />
  </main>

  <!-- Device preview iframe scaling -->
  <script is:inline>
  (function() {
    var frames = document.querySelectorAll('.rp-device');
    var headers = document.querySelectorAll('.rp-category-header');
    var gridBtn = document.querySelector('[data-view="grid"]');
    var focusBtn = document.querySelector('[data-view="focus"]');
    var focusSelect = document.querySelector('.rp-focus-select');
    var container = document.querySelector('.rp-container');

    function scaleFrames() {
      for (var i = 0; i < frames.length; i++) {
        var wrapper = frames[i].querySelector('.rp-iframe-wrapper');
        var iframe = frames[i].querySelector('iframe');
        if (!wrapper || !iframe) continue;
        var targetWidth = parseInt(iframe.getAttribute('width'), 10);
        var targetHeight = parseInt(iframe.getAttribute('height'), 10);
        var availableWidth = wrapper.clientWidth;
        var scale = availableWidth / targetWidth;
        iframe.style.width = targetWidth + 'px';
        iframe.style.height = targetHeight + 'px';
        iframe.style.transform = 'scale(' + scale + ')';
        iframe.style.transformOrigin = 'top left';
        wrapper.style.height = (targetHeight * scale) + 'px';
      }
    }

    function showHeaders(visible) {
      for (var h = 0; h < headers.length; h++) {
        headers[h].style.display = visible ? '' : 'none';
      }
    }

    gridBtn.addEventListener('click', function() {
      container.classList.remove('rp-focus-mode');
      container.classList.add('rp-grid-mode');
      gridBtn.classList.add('active');
      focusBtn.classList.remove('active');
      focusSelect.style.display = 'none';
      showHeaders(true);
      for (var i = 0; i < frames.length; i++) frames[i].style.display = '';
      scaleFrames();
    });

    focusBtn.addEventListener('click', function() {
      container.classList.remove('rp-grid-mode');
      container.classList.add('rp-focus-mode');
      focusBtn.classList.add('active');
      gridBtn.classList.remove('active');
      focusSelect.style.display = '';
      showHeaders(false);
      var idx = parseInt(focusSelect.value, 10);
      for (var i = 0; i < frames.length; i++) {
        frames[i].style.display = i === idx ? '' : 'none';
      }
      scaleFrames();
    });

    focusSelect.addEventListener('change', function() {
      var idx = parseInt(focusSelect.value, 10);
      for (var i = 0; i < frames.length; i++) {
        frames[i].style.display = i === idx ? '' : 'none';
      }
      scaleFrames();
    });

    window.addEventListener('resize', scaleFrames);
    window.addEventListener('load', scaleFrames);
    scaleFrames();
  })();
  </script>

  <!-- Widget scale slider -->
  <script is:inline>
  (function() {
    var slider = document.getElementById('ws-slider');
    var label = document.getElementById('ws-width-label');
    var widgets = document.querySelectorAll('.ws-widget');
    var presets = document.querySelectorAll('.ws-preset');

    function setWidth(w) {
      label.textContent = w + 'px';
      slider.value = w;
      for (var i = 0; i < widgets.length; i++) {
        widgets[i].style.width = w + 'px';
      }
      for (var j = 0; j < presets.length; j++) {
        var pw = parseInt(presets[j].getAttribute('data-width'), 10);
        if (pw === w) {
          presets[j].classList.add('active');
        } else {
          presets[j].classList.remove('active');
        }
      }
    }

    slider.addEventListener('input', function() {
      var w = parseInt(slider.value, 10);
      label.textContent = w + 'px';
      for (var i = 0; i < widgets.length; i++) {
        widgets[i].style.width = w + 'px';
      }
      for (var j = 0; j < presets.length; j++) {
        presets[j].classList.remove('active');
      }
    });

    for (var k = 0; k < presets.length; k++) {
      presets[k].addEventListener('click', function() {
        var w = parseInt(this.getAttribute('data-width'), 10);
        setWidth(w);
      });
    }
  })();
  </script>
</Showcase>
