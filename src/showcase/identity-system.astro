---
import fs from 'node:fs';
import path from 'node:path';
import Showcase from '../layouts/Showcase.astro';
import IdentityCard from '../components/IdentityCard.astro';
import BioTerminal from '../components/BioTerminal.astro';
import SystemStatus from '../components/SystemStatus.astro';
import ComingSoon from '../components/ComingSoon.astro';

const dataDir = path.join(process.cwd(), 'data');
const profile = JSON.parse(fs.readFileSync(path.join(dataDir, 'profile.json'), 'utf-8'));
const system = JSON.parse(fs.readFileSync(path.join(dataDir, 'system.json'), 'utf-8'));
const empty = JSON.parse(fs.readFileSync(path.join(dataDir, 'showcase-empty.json'), 'utf-8'));

// Mock active state for SystemStatus — system.json now holds PENDING fallback;
// the real active state comes from live API data, so we simulate it here.
const activeSystem = {
  lines: [
    { key: "Health", value: 'ACTIVE <span class="sys-val">(15m ago)</span>', dotClass: "sys-dot-red", valClass: "sys-val-green" },
    { key: "Sleep", value: 'ACTIVE <span class="sys-val">(15m ago)</span>', dotClass: "sys-dot-purple", valClass: "sys-val-green" },
    { key: "Location", value: 'ACTIVE <span class="sys-val">(25m ago)</span>', dotClass: "sys-dot-blue", valClass: "sys-val-green" },
    { key: "Books", value: 'ACTIVE <span class="sys-val">(3d ago)</span>', dotClass: "sys-dot-amber", valClass: "sys-val-green" },
    { key: "Articles", value: 'ACTIVE <span class="sys-val">(1h ago)</span>', dotClass: "sys-dot-amber", valClass: "sys-val-green" },
    { key: "Github Events", value: 'ACTIVE <span class="sys-val">(2h ago)</span>', dotClass: "sys-dot-green", valClass: "sys-val-green" },
    { key: "Github Stars", value: 'ACTIVE <span class="sys-val">(4h ago)</span>', dotClass: "sys-dot-green", valClass: "sys-val-green" },
  ]
};
---
<Showcase title="Identity & System">
  <main class="lib-container">
    <h1 class="lib-page-title">Identity &amp; System</h1>
    <p class="lib-page-desc">
      Seven identity and system components: personal identity card, terminal-style bio, system status readout, command bar header, coming-soon mission dossier overlay, two tablet layout variations, and two mobile layout variations.
    </p>

    <h2 class="lib-section-title">Profile</h2>

    <!-- ==================== 1. IDENTITY CARD ==================== -->
    <div class="component-section">
      <div class="component-name">IdentityCard</div>
      <div class="component-description">
        The primary identity component featuring an avatar with a neon glow ring, hero-sized name with dual-color text shadow, an uppercase title, a short bio paragraph, and pill-shaped social links.
      </div>
      <div class="component-classes">.identity-card, .id-avatar, .id-name, .id-title, .id-bio, .id-links, .neon-pill</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="identity-card" style="text-align: center;">
              <div class="skeleton-circle" style="width: 96px; height: 96px; margin: 0 auto 16px;"></div>
              <div class="skeleton-bar" style="width: 60%; height: 24px; margin: 0 auto 10px;"></div>
              <div class="skeleton-bar" style="width: 40%; height: 10px; margin: 0 auto 14px;"></div>
              <div class="skeleton-bar" style="width: 80%; height: 10px; margin: 0 auto 6px;"></div>
              <div class="skeleton-bar" style="width: 65%; height: 10px; margin: 0 auto 16px;"></div>
              <div style="display: flex; gap: 8px; justify-content: center;">
                <div class="skeleton-bar" style="width: 64px; height: 26px; border-radius: 50px;"></div>
                <div class="skeleton-bar" style="width: 64px; height: 26px; border-radius: 50px;"></div>
                <div class="skeleton-bar" style="width: 64px; height: 26px; border-radius: 50px;"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <IdentityCard profile={empty.profile} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <IdentityCard profile={profile} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 2. BIO TERMINAL ==================== -->
    <div class="component-section">
      <div class="component-name">BioTerminal</div>
      <div class="component-description">
        A faux terminal with macOS-style titlebar, sequentially typing lines, and a blinking cursor. Contains id="terminalBody" so only one instance per page.
      </div>
      <div class="component-classes">.terminal-container, .terminal-titlebar, .terminal-btn, .terminal-body, .terminal-line, .terminal-cursor</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-blue left-panel-bio">
              <div class="widget-header">
                <span class="widget-label">Bio</span>
                <div class="widget-header-right">
                  <div class="live-dot live-dot-blue"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body" style="padding: 0;">
                <div class="terminal-container">
                  <div class="terminal-titlebar">
                    <div class="terminal-btn terminal-btn-red"></div>
                    <div class="terminal-btn terminal-btn-yellow"></div>
                    <div class="terminal-btn terminal-btn-green"></div>
                    <div class="terminal-title">zsh</div>
                  </div>
                  <div class="terminal-body" style="padding: 12px 16px;">
                    <div class="skeleton-bar" style="width: 70%; height: 12px; margin-bottom: 10px;"></div>
                    <div class="skeleton-bar" style="width: 55%; height: 12px; margin-bottom: 10px;"></div>
                    <div class="skeleton-bar" style="width: 80%; height: 12px; margin-bottom: 10px;"></div>
                    <div class="skeleton-bar" style="width: 40%; height: 12px;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <!-- Static HTML: avoids duplicate #terminalBody -->
            <div class="tri-card tri-card-accent-blue left-panel-bio">
              <div class="widget-header">
                <span class="widget-label">Bio</span>
                <div class="widget-header-right">
                  <div class="live-dot live-dot-blue"></div>
                  <span class="widget-timestamp">bash</span>
                </div>
              </div>
              <div class="widget-body" style="padding: 0;">
                <div class="terminal-container">
                  <div class="terminal-titlebar">
                    <div class="terminal-btn terminal-btn-red"></div>
                    <div class="terminal-btn terminal-btn-yellow"></div>
                    <div class="terminal-btn terminal-btn-green"></div>
                    <div class="terminal-title">zsh &mdash; about</div>
                  </div>
                  <div class="terminal-body">
                    <div class="terminal-line visible">
                      <span class="terminal-prompt">$ </span>
                      <span class="terminal-cursor"></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <BioTerminal profile={profile} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== TABLET VARIATIONS ==================== -->
    <h2 class="lib-section-title">Tablet Variations</h2>
    <p class="lib-page-desc" style="margin-bottom: 24px;">
      Two layout explorations for the identity card at tablet viewport widths (~1000px). Each variation uses the same profile data in a distinct arrangement.
    </p>

    <!-- Variation A: Compact Row -->
    <div class="component-section">
      <div class="component-name">Tablet Compact Row</div>
      <div class="component-description">
        Horizontal flex layout. Avatar 56px inline with name and title. Social links pushed right. Bio and tagline span the full width below.
      </div>
      <div class="tablet-variation">
        <div class="tv-a" style="background: var(--glass-bg); border: 1px solid var(--glass-border); backdrop-filter: blur(16px); border-radius: var(--radius-xl); padding: 20px 24px;">
          <div style="display: flex; align-items: center; gap: 16px;">
            <img src={profile.avatar} alt="Avatar" style="width: 56px; height: 56px; border-radius: 50%; border: 2px solid var(--neon-indigo); flex-shrink: 0;" />
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: var(--font-size-lg); font-weight: 700; color: var(--text); text-shadow: 0 0 12px rgba(129,140,248,0.5);">{profile.name}</div>
              <div style="font-size: var(--font-size-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); margin-top: 2px;">{profile.title}</div>
            </div>
            <nav style="display: flex; gap: 8px; margin-left: auto; flex-shrink: 0;" aria-label="Social">
              <a href={profile.github} class="neon-pill" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a href={profile.linkedin} class="neon-pill" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </nav>
          </div>
          <div style="margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--glass-border);">
            <p style="font-size: var(--font-size-sm); color: var(--text-muted); font-style: italic; margin: 0 0 6px;">{profile.bio}</p>
            <p style="font-size: var(--font-size-base); font-weight: 700; color: #818cf8; text-shadow: 0 0 20px rgba(129,140,248,0.6), 0 0 40px rgba(129,140,248,0.3); letter-spacing: 4px; text-transform: uppercase; margin: 0;">WELCOME TO MY HUMAN DATASTREAM.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Variation E: Profile Sidebar -->
    <div class="component-section">
      <div class="component-name">Tablet Profile Sidebar</div>
      <div class="component-description">
        Grid with a fixed 180px left column for avatar, name, and title. Right column holds bio, tagline, and links — like a mini profile card next to content.
      </div>
      <div class="tablet-variation">
        <div class="tv-e" style="background: var(--glass-bg); border: 1px solid var(--glass-border); backdrop-filter: blur(16px); border-radius: var(--radius-xl); padding: 24px; display: grid; grid-template-columns: 180px 1fr; gap: 24px;">
          <div style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px;">
            <img src={profile.avatar} alt="Avatar" style="width: 72px; height: 72px; border-radius: 50%; border: 2px solid var(--neon-indigo); box-shadow: 0 0 16px rgba(129,140,248,0.3);" />
            <div style="font-size: var(--font-size-sm); font-weight: 700; color: var(--text); text-shadow: 0 0 10px rgba(129,140,248,0.4);">{profile.name}</div>
            <div style="font-size: var(--font-size-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); line-height: 1.4;">{profile.title}</div>
          </div>
          <div style="display: flex; flex-direction: column; justify-content: center; gap: 10px; border-left: 1px solid var(--glass-border); padding-left: 24px;">
            <p style="font-size: var(--font-size-sm); color: var(--text-muted); font-style: italic; margin: 0; line-height: 1.6;">{profile.bio}</p>
            <p style="font-size: var(--font-size-base); font-weight: 700; color: #818cf8; text-shadow: 0 0 20px rgba(129,140,248,0.6), 0 0 40px rgba(129,140,248,0.3); letter-spacing: 4px; text-transform: uppercase; margin: 0;">WELCOME TO MY HUMAN DATASTREAM.</p>
            <nav style="display: flex; gap: 8px; flex-wrap: wrap;" aria-label="Social">
              <a href={profile.github} class="neon-pill" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a href={profile.linkedin} class="neon-pill" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </nav>
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== MOBILE VARIATIONS ==================== -->
    <h2 class="lib-section-title">Mobile Variations</h2>
    <p class="lib-page-desc" style="margin-bottom: 24px;">
      Two layout explorations for the identity card at mobile viewport width (~375px). Each variation uses the same profile data in a distinct arrangement.
    </p>

    <!-- Mobile Centered Profile Card -->
    <div class="component-section">
      <div class="component-name">Mobile Centered Profile Card</div>
      <div class="component-description">
        Centered avatar and name/title row, bio (2-line clamp), tagline, and links. Full-width centered layout with generous spacing between sections.
      </div>
      <div class="mobile-variation">
        <div style="background: var(--glass-bg); border: 1px solid var(--glass-border); backdrop-filter: blur(16px); border-radius: var(--radius-xl); padding: 24px 16px; text-align: center;">
          <div style="display: flex; align-items: center; gap: 16px; justify-content: center; margin-bottom: 16px;">
            <img src={profile.avatar} alt="Avatar" style="width: 68px; height: 68px; border-radius: 50%; border: 3px solid var(--neon-indigo); box-shadow: 0 0 20px rgba(129,140,248,0.3), 0 0 40px rgba(129,140,248,0.15); flex-shrink: 0;" />
            <div>
              <div style="font-size: 1.7rem; font-weight: 700; color: var(--text); text-shadow: 0 0 12px rgba(129,140,248,0.5); white-space: nowrap;">{profile.name}</div>
              <div style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); margin-top: 4px;">{profile.title}</div>
            </div>
          </div>
          <p style="font-size: 0.8rem; color: var(--text-muted); font-style: italic; margin: 16px 0 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">{profile.bio}</p>
          <p style="font-size: 0.75rem; font-weight: 700; color: #818cf8; text-shadow: 0 0 20px rgba(129,140,248,0.6), 0 0 40px rgba(129,140,248,0.3); letter-spacing: 4px; text-transform: uppercase; margin: 0 0 14px;">WELCOME TO MY HUMAN DATASTREAM.</p>
          <nav style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;" aria-label="Social">
            <a href={profile.github} class="neon-pill" style="padding: 7px 16px; font-size: 0.7rem;" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={profile.linkedin} class="neon-pill" style="padding: 7px 16px; font-size: 0.7rem;" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Mobile Editorial Strip -->
    <div class="component-section">
      <div class="component-name">Mobile Editorial Strip</div>
      <div class="component-description">
        Left accent border with avatar and name/title in a row. Bio on its own line. Tagline and links in a footer row. Clean editorial feel.
      </div>
      <div class="mobile-variation">
        <div style="background: var(--glass-bg); border: 1px solid var(--glass-border); border-left: 3px solid var(--neon-indigo); backdrop-filter: blur(16px); border-radius: var(--radius-md); padding: 16px 16px 16px 20px;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
            <img src={profile.avatar} alt="Avatar" style="width: 44px; height: 44px; border-radius: 50%; border: 2px solid var(--neon-indigo); flex-shrink: 0;" />
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: var(--font-size-md); font-weight: 700; color: var(--text); text-shadow: 0 0 10px rgba(129,140,248,0.4);">{profile.name}</div>
              <div style="font-size: var(--font-size-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-top: 2px;">{profile.title}</div>
            </div>
          </div>
          <p style="font-size: var(--font-size-sm); color: var(--text-muted); font-style: italic; margin: 0 0 12px; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{profile.bio}</p>
          <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 12px; border-top: 1px solid var(--glass-border);">
            <p style="font-size: var(--font-size-xs); font-weight: 700; color: #818cf8; text-shadow: 0 0 16px rgba(129,140,248,0.5); letter-spacing: 3px; text-transform: uppercase; margin: 0;">DATASTREAM</p>
            <nav style="display: flex; gap: 6px; flex-shrink: 0;" aria-label="Social">
              <a href={profile.github} class="neon-pill" style="padding: 5px 12px; font-size: var(--font-size-xs);" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a href={profile.linkedin} class="neon-pill" style="padding: 5px 12px; font-size: var(--font-size-xs);" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </nav>
          </div>
        </div>
      </div>
    </div>

    <h2 class="lib-section-title">System</h2>

    <!-- ==================== 3. SYSTEM STATUS ==================== -->
    <div class="component-section">
      <div class="component-name">SystemStatus</div>
      <div class="component-description">
        A compact status readout with colored indicator dots and key-value pairs in monospace font. Each row shows a system metric with a pulsing dot.
      </div>
      <div class="component-classes">.left-panel-status, .sys-line, .sys-dot, .sys-key, .sys-val</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="left-panel-status">
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                  <div class="skeleton-circle" style="width: 6px; height: 6px;"></div>
                  <div class="skeleton-bar" style="width: 50px; height: 10px;"></div>
                  <div class="skeleton-bar" style="width: 60px; height: 10px; margin-left: auto;"></div>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                  <div class="skeleton-circle" style="width: 6px; height: 6px;"></div>
                  <div class="skeleton-bar" style="width: 45px; height: 10px;"></div>
                  <div class="skeleton-bar" style="width: 55px; height: 10px; margin-left: auto;"></div>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                  <div class="skeleton-circle" style="width: 6px; height: 6px;"></div>
                  <div class="skeleton-bar" style="width: 55px; height: 10px;"></div>
                  <div class="skeleton-bar" style="width: 50px; height: 10px; margin-left: auto;"></div>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                  <div class="skeleton-circle" style="width: 6px; height: 6px;"></div>
                  <div class="skeleton-bar" style="width: 48px; height: 10px;"></div>
                  <div class="skeleton-bar" style="width: 58px; height: 10px; margin-left: auto;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <SystemStatus system={system} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <SystemStatus system={activeSystem} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 4. COMMAND BAR ==================== -->
    <div class="component-section">
      <div class="component-name">Command Bar</div>
      <div class="component-description">
        Fixed header bar with page title and live clock. Rendered as inline HTML (no .astro component file).
      </div>
      <div class="component-classes">.top-bar, .top-bar-title, .top-bar-clock</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div style="position: relative; width: 100%; height: 48px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; background: rgba(6,6,15,0.7); border-bottom: 1px solid rgba(255,255,255,0.06); border-radius: 8px;">
              <div class="skeleton-bar" style="width: 120px; height: 10px;"></div>
              <div class="skeleton-bar" style="width: 64px; height: 10px;"></div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <div style="position: relative; width: 100%; height: 48px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; background: rgba(6,6,15,0.7); border-bottom: 1px solid rgba(255,255,255,0.06); border-radius: 8px;">
              <div class="skeleton-bar" style="width: 120px; height: 10px;"></div>
              <span class="top-bar-clock" style="color: var(--text-muted); text-shadow: none;">--:--:--</span>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <div style="position: relative; width: 100%; height: 48px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; background: rgba(6,6,15,0.7); border-bottom: 1px solid rgba(255,255,255,0.06); border-radius: 8px;">
              <span class="top-bar-title">HUMAN DATASTREAM</span>
              <span class="top-bar-clock">14:32:07</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 5. COMING SOON ==================== -->
    <div class="component-section">
      <div class="component-name">ComingSoon</div>
      <div class="component-description">
        Full-page "Mission Pending" dossier overlay with field labels, objectives checklist, and animated status dot. Contains id="coming-soon-overlay" and id="dossierId" so only one instance per page. The showcase CSS overrides position: fixed to render it inline.
      </div>
      <div class="component-classes">#coming-soon-overlay, .dossier, .dossier-header, .status-row, .fields, .objectives</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="coming-soon-overlay" style="position: relative; inset: auto; z-index: auto; min-height: 400px; display: flex; align-items: center; justify-content: center; background: var(--bg); border-radius: 12px;">
              <div style="width: min(480px, 90%); background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; overflow: hidden;">
                <div style="padding: 16px 28px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between;">
                  <div class="skeleton-bar" style="width: 100px; height: 10px;"></div>
                  <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
                </div>
                <div style="padding: 28px; display: flex; flex-direction: column; gap: 16px;">
                  <div class="skeleton-bar" style="width: 50%; height: 18px; margin: 0 auto;"></div>
                  <div style="height: 1px; background: rgba(255,255,255,0.06);"></div>
                  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div style="display: flex; flex-direction: column; gap: 4px;">
                      <div class="skeleton-bar" style="width: 60px; height: 8px;"></div>
                      <div class="skeleton-bar" style="width: 100px; height: 12px;"></div>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 4px;">
                      <div class="skeleton-bar" style="width: 50px; height: 8px;"></div>
                      <div class="skeleton-bar" style="width: 90px; height: 12px;"></div>
                    </div>
                  </div>
                  <div style="height: 1px; background: rgba(255,255,255,0.06);"></div>
                  <div style="display: flex; flex-direction: column; gap: 8px;">
