---
import Showcase from '../layouts/Showcase.astro';

import DevActivityLog from '../components/github/DevActivityLog.astro';
import { sampleData as devLogData, emptyData as devLogEmpty } from '../components/github/DevActivityLog.query';
import DevActivityTimeline from '../components/github/DevActivityTimeline.astro';
import { sampleData as devTimelineData, emptyData as devTimelineEmpty } from '../components/github/DevActivityTimeline.query';
import DevActivityCards from '../components/github/DevActivityCards.astro';
import { sampleData as devCardsData, emptyData as devCardsEmpty } from '../components/github/DevActivityCards.query';
import DevActivityByRepo from '../components/github/DevActivityByRepo.astro';
import { sampleData as devByRepoData, emptyData as devByRepoEmpty } from '../components/github/DevActivityByRepo.query';
import DevActivityPulse from '../components/github/DevActivityPulse.astro';
import { sampleData as devPulseData, emptyData as devPulseEmpty } from '../components/github/DevActivityPulse.query';
import ActivityFeed from '../components/github/ActivityFeed.astro';
import { sampleData as activityData, emptyData as activityEmpty } from '../components/github/ActivityFeed.query';
---
<Showcase title="Activity Feeds">
  <main class="lib-container">
    <h1 class="lib-page-title">Activity Feeds</h1>
    <p class="lib-page-desc">
      Six feed-style components that display developer activity in different formats: dense terminal logs, vertical timelines, rich glass cards, repository-grouped views, sparkline pulses, and mixed event feeds.
    </p>

    <h2 class="lib-section-title">Dev Activity</h2>

    <!-- ==================== 1. DEV ACTIVITY LOG ==================== -->
    <div class="component-section">
      <div class="component-name">DevActivityLog</div>
      <div class="component-description">
        Dense monospace terminal view unifying commits, PRs, and issues into a single chronological stream. Each event is one compact row with type icon, repo, title, detail, and date.
      </div>
      <div class="component-classes">.tri-card-accent-green</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Dev Log</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="display: flex; flex-direction: column; gap: 8px; font-family: 'Space Grotesk', monospace;">
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <span class="skeleton-bar" style="width: 16px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 70px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 55%; height: 12px;"></span>
                    <span class="skeleton-bar" style="width: 50px; height: 12px; margin-left: auto; flex-shrink: 0;"></span>
                  </div>
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <span class="skeleton-bar" style="width: 16px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 65px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 45%; height: 12px;"></span>
                    <span class="skeleton-bar" style="width: 50px; height: 12px; margin-left: auto; flex-shrink: 0;"></span>
                  </div>
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <span class="skeleton-bar" style="width: 16px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 80px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 50%; height: 12px;"></span>
                    <span class="skeleton-bar" style="width: 50px; height: 12px; margin-left: auto; flex-shrink: 0;"></span>
                  </div>
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <span class="skeleton-bar" style="width: 16px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 72px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 40%; height: 12px;"></span>
                    <span class="skeleton-bar" style="width: 50px; height: 12px; margin-left: auto; flex-shrink: 0;"></span>
                  </div>
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <span class="skeleton-bar" style="width: 16px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 68px; height: 12px; flex-shrink: 0;"></span>
                    <span class="skeleton-bar" style="width: 48%; height: 12px;"></span>
                    <span class="skeleton-bar" style="width: 50px; height: 12px; margin-left: auto; flex-shrink: 0;"></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <DevActivityLog {...devLogEmpty} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <DevActivityLog {...devLogData} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 2. DEV ACTIVITY TIMELINE ==================== -->
    <div class="component-section">
      <div class="component-name">DevActivityTimeline</div>
      <div class="component-description">
        Vertical timeline with a gradient line and event-type-colored dots. Each item shows title, colored type badge pill, repo name, date, and commit stats or issue/PR reference.
      </div>
      <div class="component-classes">.tri-card-accent-green</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Dev Timeline</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="display: flex; flex-direction: column; gap: 16px; padding-left: 20px; border-left: 2px solid rgba(255,255,255,0.06);">
                  <div style="position: relative;">
                    <div class="skeleton-circle" style="width: 10px; height: 10px; position: absolute; left: -25px; top: 2px;"></div>
                    <div class="skeleton-bar" style="width: 70%; height: 13px; margin-bottom: 6px;"></div>
                    <div style="display: flex; gap: 8px;">
                      <div class="skeleton-bar" style="width: 50px; height: 16px; border-radius: 50px;"></div>
                      <div class="skeleton-bar" style="width: 80px; height: 12px;"></div>
                    </div>
                  </div>
                  <div style="position: relative;">
                    <div class="skeleton-circle" style="width: 10px; height: 10px; position: absolute; left: -25px; top: 2px;"></div>
                    <div class="skeleton-bar" style="width: 60%; height: 13px; margin-bottom: 6px;"></div>
                    <div style="display: flex; gap: 8px;">
                      <div class="skeleton-bar" style="width: 45px; height: 16px; border-radius: 50px;"></div>
                      <div class="skeleton-bar" style="width: 75px; height: 12px;"></div>
                    </div>
                  </div>
                  <div style="position: relative;">
                    <div class="skeleton-circle" style="width: 10px; height: 10px; position: absolute; left: -25px; top: 2px;"></div>
                    <div class="skeleton-bar" style="width: 65%; height: 13px; margin-bottom: 6px;"></div>
                    <div style="display: flex; gap: 8px;">
                      <div class="skeleton-bar" style="width: 55px; height: 16px; border-radius: 50px;"></div>
                      <div class="skeleton-bar" style="width: 70px; height: 12px;"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <DevActivityTimeline {...devTimelineEmpty} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <DevActivityTimeline {...devTimelineData} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 3. DEV ACTIVITY CARDS ==================== -->
    <div class="component-section">
      <div class="component-name">DevActivityCards</div>
      <div class="component-description">
        Rich glass card feed where each event gets its own card with a 2px colored left border by event type. Most readable and spacious variant with header, title, and footer rows.
      </div>
      <div class="component-classes">.tri-card-accent-green</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Dev Activity</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="display: flex; flex-direction: column; gap: 12px;">
                  <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-left: 2px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 14px;">
                    <div class="skeleton-bar" style="width: 50%; height: 10px; margin-bottom: 8px;"></div>
                    <div class="skeleton-bar" style="width: 80%; height: 13px; margin-bottom: 8px;"></div>
                    <div class="skeleton-bar" style="width: 40%; height: 10px;"></div>
                  </div>
                  <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-left: 2px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 14px;">
                    <div class="skeleton-bar" style="width: 45%; height: 10px; margin-bottom: 8px;"></div>
                    <div class="skeleton-bar" style="width: 70%; height: 13px; margin-bottom: 8px;"></div>
                    <div class="skeleton-bar" style="width: 35%; height: 10px;"></div>
                  </div>
                  <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-left: 2px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 14px;">
                    <div class="skeleton-bar" style="width: 55%; height: 10px; margin-bottom: 8px;"></div>
                    <div class="skeleton-bar" style="width: 75%; height: 13px; margin-bottom: 8px;"></div>
                    <div class="skeleton-bar" style="width: 38%; height: 10px;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <DevActivityCards {...devCardsEmpty} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <DevActivityCards {...devCardsData} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 4. DEV ACTIVITY BY REPO ==================== -->
    <div class="component-section">
      <div class="component-name">DevActivityByRepo</div>
      <div class="component-description">
        Events grouped under repository section headers with event count badges. Each group contains compact rows with type icon, label, title, detail, and date.
      </div>
      <div class="component-classes">.tri-card-accent-green</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Dev By Repo</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="display: flex; flex-direction: column; gap: 16px;">
                  <div>
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                      <div class="skeleton-bar" style="width: 100px; height: 12px;"></div>
                      <div class="skeleton-bar" style="width: 20px; height: 16px; border-radius: 50px;"></div>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 6px; padding-left: 8px;">
                      <div class="skeleton-bar" style="width: 80%; height: 11px;"></div>
                      <div class="skeleton-bar" style="width: 65%; height: 11px;"></div>
                    </div>
                  </div>
                  <div>
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                      <div class="skeleton-bar" style="width: 90px; height: 12px;"></div>
                      <div class="skeleton-bar" style="width: 20px; height: 16px; border-radius: 50px;"></div>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 6px; padding-left: 8px;">
                      <div class="skeleton-bar" style="width: 70%; height: 11px;"></div>
                      <div class="skeleton-bar" style="width: 75%; height: 11px;"></div>
                      <div class="skeleton-bar" style="width: 60%; height: 11px;"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <DevActivityByRepo {...devByRepoEmpty} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <DevActivityByRepo {...devByRepoData} />
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== 5. DEV ACTIVITY PULSE ==================== -->
    <div class="component-section">
      <div class="component-name">DevActivityPulse</div>
      <div class="component-description">
        SVG sparkline with vertical pulse spikes per event colored by type and positioned by recency. Summary row shows event type breakdown counts. Bottom section lists the 3 most recent events.
      </div>
      <div class="component-classes">.tri-card-accent-green</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Dev Pulse</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div class="skeleton-bar" style="width: 100%; height: 60px; border-radius: 8px; margin-bottom: 12px;"></div>
                <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                  <div class="skeleton-bar" style="width: 60px; height: 10px;"></div>
                  <div class="skeleton-bar" style="width: 50px; height: 10px;"></div>
                  <div class="skeleton-bar" style="width: 55px; height: 10px;"></div>
                </div>
                <div style="display: flex; flex-direction: column; gap: 6px;">
                  <div class="skeleton-bar" style="width: 85%; height: 11px;"></div>
                  <div class="skeleton-bar" style="width: 70%; height: 11px;"></div>
                  <div class="skeleton-bar" style="width: 75%; height: 11px;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <DevActivityPulse {...devPulseEmpty} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <DevActivityPulse {...devPulseData} />
          </div>
        </div>
      </div>
    </div>

    <h2 class="lib-section-title">General Activity</h2>

    <!-- ==================== 6. ACTIVITY FEED ==================== -->
    <div class="component-section">
      <div class="component-name">ActivityFeed</div>
      <div class="component-description">
        Mixed event feed showing recent pushes, PRs, issues, and stars with type icons and timestamps. Powered by the REST public events API.
      </div>
      <div class="component-classes">.tri-card-accent-green</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Activity Feed</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="display: flex; flex-direction: column; gap: 10px;">
                  <div style="display: flex; gap: 10px; align-items: center;">
                    <div class="skeleton-circle" style="width: 20px; height: 20px; flex-shrink: 0;"></div>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                      <div class="skeleton-bar" style="width: 75%; height: 12px;"></div>
                      <div class="skeleton-bar" style="width: 40%; height: 10px;"></div>
                    </div>
                  </div>
                  <div style="display: flex; gap: 10px; align-items: center;">
                    <div class="skeleton-circle" style="width: 20px; height: 20px; flex-shrink: 0;"></div>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                      <div class="skeleton-bar" style="width: 65%; height: 12px;"></div>
                      <div class="skeleton-bar" style="width: 35%; height: 10px;"></div>
                    </div>
                  </div>
                  <div style="display: flex; gap: 10px; align-items: center;">
                    <div class="skeleton-circle" style="width: 20px; height: 20px; flex-shrink: 0;"></div>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                      <div class="skeleton-bar" style="width: 80%; height: 12px;"></div>
                      <div class="skeleton-bar" style="width: 45%; height: 10px;"></div>
                    </div>
                  </div>
                  <div style="display: flex; gap: 10px; align-items: center;">
                    <div class="skeleton-circle" style="width: 20px; height: 20px; flex-shrink: 0;"></div>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                      <div class="skeleton-bar" style="width: 70%; height: 12px;"></div>
                      <div class="skeleton-bar" style="width: 38%; height: 10px;"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <ActivityFeed {...activityEmpty} />
          </div>
        </div>
        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <ActivityFeed {...activityData} />
          </div>
        </div>
      </div>
    </div>

  </main>
</Showcase>
