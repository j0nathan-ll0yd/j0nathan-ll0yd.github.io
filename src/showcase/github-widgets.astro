---
import Showcase from '../layouts/Showcase.astro';

import ContributionGrid from '../components/github/ContributionGrid.astro';
import { sampleData as gridData } from '../components/github/ContributionGrid.query';
import ContributionCalendar from '../components/github/ContributionCalendar.astro';
import { sampleData as calendarData } from '../components/github/ContributionCalendar.query';
import StreakCounter from '../components/github/StreakCounter.astro';
import { sampleData as streakData } from '../components/github/StreakCounter.query';

import CommitLog from '../components/github/CommitLog.astro';
import { sampleData as commitLogData } from '../components/github/CommitLog.query';
import CommitTimeline from '../components/github/CommitTimeline.astro';
import { sampleData as timelineData } from '../components/github/CommitTimeline.query';
import CodingHours from '../components/github/CodingHours.astro';
import { sampleData as codingHoursData } from '../components/github/CodingHours.query';

import WeeklyPulse from '../components/github/WeeklyPulse.astro';
import { sampleData as pulseData } from '../components/github/WeeklyPulse.query';
import ActivityFeed from '../components/github/ActivityFeed.astro';
import { sampleData as activityData } from '../components/github/ActivityFeed.query';
import ContributionBreakdown from '../components/github/ContributionBreakdown.astro';
import { sampleData as breakdownData } from '../components/github/ContributionBreakdown.query';

import LanguageBars from '../components/github/LanguageBars.astro';
import { sampleData as langBarsData } from '../components/github/LanguageBars.query';
import LanguageStack from '../components/github/LanguageStack.astro';
import { sampleData as langStackData } from '../components/github/LanguageStack.query';
import LanguageGrid from '../components/github/LanguageGrid.astro';
import { sampleData as langGridData } from '../components/github/LanguageGrid.query';

import PinnedRepos from '../components/github/PinnedRepos.astro';
import { sampleData as pinnedData } from '../components/github/PinnedRepos.query';
import TopRepos from '../components/github/TopRepos.astro';
import { sampleData as topReposData } from '../components/github/TopRepos.query';
import RepoShowcase from '../components/github/RepoShowcase.astro';
import { sampleData as showcaseData } from '../components/github/RepoShowcase.query';

import ProfileCard from '../components/github/ProfileCard.astro';
import { sampleData as profileData } from '../components/github/ProfileCard.query';
import YearInReview from '../components/github/YearInReview.astro';
import { sampleData as yearData } from '../components/github/YearInReview.query';
import ContributionRings from '../components/github/ContributionRings.astro';
import { sampleData as ringsData } from '../components/github/ContributionRings.query';

import CodeVelocity from '../components/github/CodeVelocity.astro';
import { sampleData as velocityData } from '../components/github/CodeVelocity.query';
import TopicCloud from '../components/github/TopicCloud.astro';
import { sampleData as topicData } from '../components/github/TopicCloud.query';

import StarredRepoList from '../components/github/StarredRepoList.astro';
import { sampleData as starredListData } from '../components/github/StarredRepoList.query';
import StarredRepoCards from '../components/github/StarredRepoCards.astro';
import { sampleData as starredCardsData } from '../components/github/StarredRepoCards.query';
import StarredTimeline from '../components/github/StarredTimeline.astro';
import { sampleData as starredTimelineData } from '../components/github/StarredTimeline.query';
import StarredByLanguage from '../components/github/StarredByLanguage.astro';
import { sampleData as starredByLangData } from '../components/github/StarredByLanguage.query';

import DevActivityLog from '../components/github/DevActivityLog.astro';
import { sampleData as devLogData } from '../components/github/DevActivityLog.query';
import DevActivityTimeline from '../components/github/DevActivityTimeline.astro';
import { sampleData as devTimelineData } from '../components/github/DevActivityTimeline.query';
import DevActivityCards from '../components/github/DevActivityCards.astro';
import { sampleData as devCardsData } from '../components/github/DevActivityCards.query';
import DevActivityByRepo from '../components/github/DevActivityByRepo.astro';
import { sampleData as devByRepoData } from '../components/github/DevActivityByRepo.query';
import DevActivityPulse from '../components/github/DevActivityPulse.astro';
import { sampleData as devPulseData } from '../components/github/DevActivityPulse.query';
---
<Showcase title="GitHub Widgets">
  <main class="lib-container">
    <h1 class="lib-page-title">GitHub Widget Library</h1>
    <p class="lib-page-desc">
      A library of 29 GitHub-powered widget components exploring what GitHub data is available and how it can be visualized in the Command Center aesthetic. Each widget has a co-located query file documenting the API call needed to power it.
    </p>

    <!-- ==================== CONTRIBUTION HEATMAPS ==================== -->
    <h2 class="lib-section-title">Contribution Heatmaps</h2>

    <div class="component-section">
      <div class="component-name">ContributionGrid</div>
      <div class="component-description">
        Classic 52-week GitHub-style contribution heatmap with stats row. Cells colored by activity level (0-4). Powered by the GraphQL contributionCalendar API.
      </div>
      <div class="state-render">
        <ContributionGrid {...gridData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">ContributionCalendar</div>
      <div class="component-description">
        Last 90 days with larger cells, month headers, and day labels. A more readable alternative to the full-year grid. Same GraphQL query, sliced to 13 weeks.
      </div>
      <div class="state-render">
        <ContributionCalendar {...calendarData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">StreakCounter</div>
      <div class="component-description">
        Big number display showing current and longest contribution streaks, with a row of 30 activity dots showing recent daily activity. Derived from the contribution calendar data.
      </div>
      <div class="state-render">
        <StreakCounter {...streakData} />
      </div>
    </div>

    <!-- ==================== COMMIT WIDGETS ==================== -->
    <h2 class="lib-section-title">Commit Widgets</h2>

    <div class="component-section">
      <div class="component-name">CommitLog</div>
      <div class="component-description">
        Terminal-style commit list with hash, message, repo name, relative date, and +additions/-deletions delta. Uses the GraphQL commit history API across recent repositories.
      </div>
      <div class="state-render">
        <CommitLog {...commitLogData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">CommitTimeline</div>
      <div class="component-description">
        Vertical timeline with commit dots, messages, and colored repo badges. A visual alternative to the terminal-style commit log. Same underlying data, different presentation.
      </div>
      <div class="state-render">
        <CommitTimeline {...timelineData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">CodingHours</div>
      <div class="component-description">
        7-day x 24-hour punch card heatmap showing when you code most. Aggregated from the REST punch_card stats endpoint across your most active repositories.
      </div>
      <div class="state-render">
        <CodingHours {...codingHoursData} />
      </div>
    </div>

    <!-- ==================== ACTIVITY WIDGETS ==================== -->
    <h2 class="lib-section-title">Activity Widgets</h2>

    <div class="component-section">
      <div class="component-name">WeeklyPulse</div>
      <div class="component-description">
        Bar chart sparkline of the last 12 weeks of contribution activity. The current week is highlighted. Shows contribution volume trends at a glance.
      </div>
      <div class="state-render">
        <WeeklyPulse {...pulseData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">ActivityFeed</div>
      <div class="component-description">
        Mixed event feed showing recent pushes, PRs, issues, and stars with type icons and timestamps. Powered by the REST public events API.
      </div>
      <div class="state-render">
        <ActivityFeed {...activityData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">ContributionBreakdown</div>
      <div class="component-description">
        Four stat pills showing commits, pull requests, issues, and code reviews for the year. Direct extraction from the GraphQL contributionsCollection totals.
      </div>
      <div class="state-render">
        <ContributionBreakdown {...breakdownData} />
      </div>
    </div>

    <!-- ==================== LANGUAGE WIDGETS ==================== -->
    <h2 class="lib-section-title">Language Widgets</h2>

    <div class="component-section">
      <div class="component-name">LanguageBars</div>
      <div class="component-description">
        Horizontal progress bars per language with percentage labels and colored dots. Aggregated from language data across your top repositories via GraphQL.
      </div>
      <div class="state-render">
        <LanguageBars {...langBarsData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">LanguageStack</div>
      <div class="component-description">
        Single stacked horizontal bar with a legend below. Like GitHub's repo language bar but aggregated across all repositories. Compact and fits tight spaces.
      </div>
      <div class="state-render">
        <LanguageStack {...langStackData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">LanguageGrid</div>
      <div class="component-description">
        Grid of language badges showing colored dot, name, percentage, and repository count. A card-like alternative to bars or stacked views.
      </div>
      <div class="state-render">
        <LanguageGrid {...langGridData} />
      </div>
    </div>

    <!-- ==================== REPOSITORY WIDGETS ==================== -->
    <h2 class="lib-section-title">Repository Widgets</h2>

    <div class="component-section">
      <div class="component-name">PinnedRepos</div>
      <div class="component-description">
        Card list of pinned repositories with description, stars, forks, and primary language badge. Uses the GraphQL pinnedItems API.
      </div>
      <div class="state-render">
        <PinnedRepos {...pinnedData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">TopRepos</div>
      <div class="component-description">
        Ranked list of top repositories by stars. Terminal-style compact layout with rank, name, star count, and language. GraphQL repositories sorted by stargazers.
      </div>
      <div class="state-render">
        <TopRepos {...topReposData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">RepoShowcase</div>
      <div class="component-description">
        Rich repo cards with description, stars, forks, primary language, and topic tags. 2-column grid layout. Combines pinned items with repository topics from GraphQL.
      </div>
      <div class="state-render">
        <RepoShowcase {...showcaseData} />
      </div>
    </div>

    <!-- ==================== PROFILE & STATS ==================== -->
    <h2 class="lib-section-title">Profile &amp; Stats</h2>

    <div class="component-section">
      <div class="component-name">ProfileCard</div>
      <div class="component-description">
        GitHub profile summary: avatar, name, bio, follower/following counts, member since date, and public repos count. Direct GraphQL user query.
      </div>
      <div class="state-render">
        <ProfileCard {...profileData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">YearInReview</div>
      <div class="component-description">
        Annual summary card with total contributions, top language, most active month, repos created, and longest streak. Combines multiple GraphQL data sources.
      </div>
      <div class="state-render">
        <YearInReview {...yearData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">ContributionRings</div>
      <div class="component-description">
        Apple Watch-style concentric ring chart for contribution types: commits (green), PRs (blue), issues (amber), reviews (purple). Rendered as inline SVG arcs.
      </div>
      <div class="state-render">
        <ContributionRings {...ringsData} />
      </div>
    </div>

    <!-- ==================== CREATIVE WIDGETS ==================== -->
    <h2 class="lib-section-title">Creative Widgets</h2>

    <div class="component-section">
      <div class="component-name">CodeVelocity</div>
      <div class="component-description">
        Additions vs deletions sparkline over 52 weeks. Green area for additions, red area for deletions. Shows net code velocity. REST code_frequency endpoint.
      </div>
      <div class="state-render">
        <CodeVelocity {...velocityData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">TopicCloud</div>
      <div class="component-description">
        Repository topics displayed as a tag cloud. More frequently used topics appear larger and brighter. GraphQL repositoryTopics aggregated across all repos.
      </div>
      <div class="state-render">
        <TopicCloud {...topicData} />
      </div>
    </div>

    <!-- ==================== STARRED REPOS ==================== -->
    <h2 class="lib-section-title">Starred Repos</h2>

    <div class="component-section">
      <div class="component-name">StarredRepoList</div>
      <div class="component-description">
        Compact chronological list of recently starred repos with owner/name, star count, language dot, and relative date. Terminal-style layout like TopRepos and CommitLog.
      </div>
      <div class="state-render">
        <StarredRepoList {...starredListData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">StarredRepoCards</div>
      <div class="component-description">
        Rich card grid of recently starred repos with descriptions, owner name, language badge, and star/fork counts. 2-column layout like RepoShowcase.
      </div>
      <div class="state-render">
        <StarredRepoCards {...starredCardsData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">StarredTimeline</div>
      <div class="component-description">
        Vertical timeline with dates on the left and repo info on the right. Language-colored dots show starring activity pattern over time.
      </div>
      <div class="state-render">
        <StarredTimeline {...starredTimelineData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">StarredByLanguage</div>
      <div class="component-description">
        Starred repos grouped under language section headers, showing which languages you explore most. Sorted by group size descending.
      </div>
      <div class="state-render">
        <StarredByLanguage {...starredByLangData} />
      </div>
    </div>

    <!-- ==================== DEV ACTIVITY ==================== -->
    <h2 class="lib-section-title">Dev Activity</h2>

    <div class="component-section">
      <div class="component-name">DevActivityLog</div>
      <div class="component-description">
        Dense monospace terminal view unifying commits, PRs, and issues into a single chronological stream. Each event is one compact row with type icon, repo, title, detail, and date. Webhook-driven data.
      </div>
      <div class="state-render">
        <DevActivityLog {...devLogData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">DevActivityTimeline</div>
      <div class="component-description">
        Vertical timeline with a gradient line and event-type-colored dots. Each item shows title, colored type badge pill, repo name, date, and commit stats or issue/PR reference. Webhook-driven data.
      </div>
      <div class="state-render">
        <DevActivityTimeline {...devTimelineData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">DevActivityCards</div>
      <div class="component-description">
        Rich glass card feed where each event gets its own card with a 2px colored left border by event type. Most readable and spacious variant with header, title, and footer rows. Webhook-driven data.
      </div>
      <div class="state-render">
        <DevActivityCards {...devCardsData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">DevActivityByRepo</div>
      <div class="component-description">
        Events grouped under repository section headers with event count badges. Each group contains compact rows with type icon, label, title, detail, and date. Grouping computed at build time. Webhook-driven data.
      </div>
      <div class="state-render">
        <DevActivityByRepo {...devByRepoData} />
      </div>
    </div>

    <div class="component-section">
      <div class="component-name">DevActivityPulse</div>
      <div class="component-description">
        SVG sparkline with vertical pulse spikes per event colored by type and positioned by recency. Summary row shows event type breakdown counts. Bottom section lists the 3 most recent events. Webhook-driven data.
      </div>
      <div class="state-render">
        <DevActivityPulse {...devPulseData} />
      </div>
    </div>

  </main>
</Showcase>
