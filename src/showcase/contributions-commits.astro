---
import fs from 'node:fs';
import path from 'node:path';
import Showcase from '../layouts/Showcase.astro';

// Root components (use data/*.json)
import GitHubHeatmap from '../components/GitHubHeatmap.astro';
import RecentCommits from '../components/RecentCommits.astro';

// GitHub widgets (use .query.ts sampleData + emptyData)
import ContributionGrid from '../components/github/ContributionGrid.astro';
import { sampleData as gridData, emptyData as gridEmpty } from '../components/github/ContributionGrid.query';
import ContributionCalendar from '../components/github/ContributionCalendar.astro';
import { sampleData as calendarData, emptyData as calendarEmpty } from '../components/github/ContributionCalendar.query';
import ContributionBreakdown from '../components/github/ContributionBreakdown.astro';
import { sampleData as breakdownData, emptyData as breakdownEmpty } from '../components/github/ContributionBreakdown.query';
import ContributionRings from '../components/github/ContributionRings.astro';
import { sampleData as ringsData, emptyData as ringsEmpty } from '../components/github/ContributionRings.query';
import CommitLog from '../components/github/CommitLog.astro';
import { sampleData as commitLogData, emptyData as commitLogEmpty } from '../components/github/CommitLog.query';
import CommitTimeline from '../components/github/CommitTimeline.astro';
import { sampleData as timelineData, emptyData as timelineEmpty } from '../components/github/CommitTimeline.query';
import StreakCounter from '../components/github/StreakCounter.astro';
import { sampleData as streakData, emptyData as streakEmpty } from '../components/github/StreakCounter.query';
import CodingHours from '../components/github/CodingHours.astro';
import { sampleData as codingHoursData, emptyData as codingHoursEmpty } from '../components/github/CodingHours.query';
import WeeklyPulse from '../components/github/WeeklyPulse.astro';
import { sampleData as pulseData, emptyData as pulseEmpty } from '../components/github/WeeklyPulse.query';
import CodeVelocity from '../components/github/CodeVelocity.astro';
import { sampleData as velocityData, emptyData as velocityEmpty } from '../components/github/CodeVelocity.query';

const dataDir = path.join(process.cwd(), 'data');
const github = JSON.parse(fs.readFileSync(path.join(dataDir, 'github.json'), 'utf-8'));
const empty = JSON.parse(fs.readFileSync(path.join(dataDir, 'showcase-empty.json'), 'utf-8'));
---
<Showcase title="Contributions &amp; Commits">
  <main class="lib-container">
    <h1 class="lib-page-title">Contributions &amp; Commits</h1>
    <p class="lib-page-desc">
      Twelve components that visualize GitHub contribution patterns and commit history: heatmaps, commit feeds, streak counters, coding hours, weekly pulses, and code velocity charts.
    </p>

    <h2 class="lib-section-title">Heatmaps</h2>

    <!-- ==================== 1. CONTRIBUTION GRID ==================== -->
    <div class="component-section">
      <div class="component-name">ContributionGrid</div>
      <div class="component-description">
        Classic 52-week GitHub-style contribution heatmap with stats row. Cells colored by activity level (0-4). Powered by the GraphQL contributionCalendar API.
      </div>
      <div class="component-classes">.tri-card-accent-green</div>

      <div class="state-grid">
        <div class="state-column">
          <span class="state-label state-label-skeleton">Skeleton</span>
          <div class="state-render">
            <div class="tri-card tri-card-accent-green">
              <div class="widget-header">
                <span class="widget-label">Contribution Grid</span>
                <div class="widget-header-right">
                  <div class="live-dot"></div>
                  <span class="widget-timestamp">---</span>
                </div>
              </div>
              <div class="widget-body">
                <div style="display: grid; grid-template-columns: repeat(52, 6px); gap: 2px;">
                  <div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style="width: 6px; height: 6px;"></div><div class="skeleton-bar" style=