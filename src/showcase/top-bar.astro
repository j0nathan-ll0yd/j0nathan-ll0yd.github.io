---
import Showcase from '../layouts/Showcase.astro';
---
<Showcase title="Top Bar">
  <main class="lib-container">
    <h1 class="lib-page-title">Top Bar</h1>
    <p class="lib-page-desc">
      The command bar that sits at the top of the right panel. It contains the page title and a live clock.
    </p>

    <section class="component-section">
      <h2 class="component-name">Command Bar</h2>
      <p class="component-classes">.top-bar &nbsp; .top-bar-title &nbsp; .top-bar-clock</p>
      <p class="component-description">
        Fixed header bar with title and live clock. Sits atop the right panel with a glass-morphism background blur.
      </p>

      <div class="state-grid">

        <div class="state-column">
          <span class="state-label state-label-empty">Empty</span>
          <div class="state-render">
            <div style="position: relative; left: auto; right: auto; width: 100%; height: 48px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; background: rgba(6,6,15,0.7); border-bottom: 1px solid rgba(255,255,255,0.06); border-radius: 8px;">
              <div class="skeleton-bar" style="width: 120px; height: 10px;"></div>
              <span class="top-bar-clock" style="color: var(--text-muted); text-shadow: none;">--:--:--</span>
            </div>
          </div>
        </div>

        <div class="state-column">
          <span class="state-label state-label-active">Active</span>
          <div class="state-render">
            <div style="position: relative; left: auto; right: auto; width: 100%; height: 48px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; background: rgba(6,6,15,0.7); border-bottom: 1px solid rgba(255,255,255,0.06); border-radius: 8px;">
              <span class="top-bar-title">COMMAND CENTER</span>
              <span class="top-bar-clock">14:32:07</span>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>
</Showcase>
