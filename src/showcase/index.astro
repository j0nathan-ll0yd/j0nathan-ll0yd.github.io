---
import Showcase from '../layouts/Showcase.astro';
---
<Showcase title="Component Library">
  <main class="lib-container">
    <h1 class="lib-page-title">Component Library</h1>
    <p class="lib-page-desc">
      A catalogue of the 55 components that make up the Human Datastream, organized by domain. Each page shows every component in its skeleton, empty, and active states with the CSS classes used to build it.
    </p>

    <div class="lib-grid">

      <a href="/showcase/identity-system" class="lib-card">
        <div class="lib-card-accent lib-card-accent-pink"></div>
        <div class="lib-card-title">Identity &amp; System</div>
        <div class="lib-card-count">5 components</div>
      </a>

      <a href="/showcase/health-wellness" class="lib-card">
        <div class="lib-card-accent lib-card-accent-amber"></div>
        <div class="lib-card-title">Health &amp; Wellness</div>
        <div class="lib-card-count">6 components</div>
      </a>

      <a href="/showcase/location-widgets" class="lib-card">
        <div class="lib-card-accent lib-card-accent-pink"></div>
        <div class="lib-card-title">Location Widgets</div>
        <div class="lib-card-count">10 components</div>
      </a>

      <a href="/showcase/contributions-commits" class="lib-card">
        <div class="lib-card-accent lib-card-accent-green"></div>
        <div class="lib-card-title">Contributions &amp; Commits</div>
        <div class="lib-card-count">12 components</div>
      </a>

      <a href="/showcase/repositories-languages" class="lib-card">
        <div class="lib-card-accent lib-card-accent-blue"></div>
        <div class="lib-card-title">Repositories &amp; Languages</div>
        <div class="lib-card-count">13 components</div>
      </a>

      <a href="/showcase/activity-feeds" class="lib-card">
        <div class="lib-card-accent lib-card-accent-purple"></div>
        <div class="lib-card-title">Activity Feeds</div>
        <div class="lib-card-count">6 components</div>
      </a>

      <a href="/showcase/reading-books" class="lib-card">
        <div class="lib-card-accent lib-card-accent-green"></div>
        <div class="lib-card-title">Reading &amp; Books</div>
        <div class="lib-card-count">3 components</div>
      </a>

      <a href="/showcase/theatre-reviews" class="lib-card">
        <div class="lib-card-accent lib-card-accent-pink"></div>
        <div class="lib-card-title">Theatre Reviews</div>
        <div class="lib-card-count">10 variations</div>
      </a>

      <a href="/showcase/fullscreen-overlays" class="lib-card">
        <div class="lib-card-accent lib-card-accent-red"></div>
        <div class="lib-card-title">Full-Screen Overlays</div>
        <div class="lib-card-count">10 overlays</div>
      </a>

      <a href="/showcase/404-pages" class="lib-card">
        <div class="lib-card-accent lib-card-accent-red"></div>
        <div class="lib-card-title">404 Pages</div>
        <div class="lib-card-count">10 variations</div>
      </a>

      <a href="/showcase/og-images" class="lib-card">
        <div class="lib-card-accent lib-card-accent-cyan"></div>
        <div class="lib-card-title">OG Images</div>
        <div class="lib-card-count">1 component</div>
      </a>

      <a href="/showcase/responsive-preview" class="lib-card">
        <div class="lib-card-accent lib-card-accent-pink"></div>
        <div class="lib-card-title">Responsive Preview</div>
        <div class="lib-card-count">4 viewports</div>
      </a>

    </div>
  </main>
</Showcase>
