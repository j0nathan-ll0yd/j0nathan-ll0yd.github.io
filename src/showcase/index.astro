---
import Showcase from '../layouts/Showcase.astro';
---
<Showcase title="Component Library">
  <main class="lib-container">
    <h1 class="lib-page-title">Component Library</h1>
    <p class="lib-page-desc">
      A catalogue of the 14 components that make up the Command Center, organized by the panel they belong to. Each page shows the component in its empty and active states with the CSS classes used to build it.
    </p>

    <div class="lib-grid">

      <a href="/showcase/left-panel" class="lib-card">
        <div class="lib-card-accent lib-card-accent-pink"></div>
        <div class="lib-card-title">Left Panel</div>
        <div class="lib-card-count">3 components</div>
      </a>

      <a href="/showcase/top-bar" class="lib-card">
        <div class="lib-card-accent lib-card-accent-blue"></div>
        <div class="lib-card-title">Top Bar</div>
        <div class="lib-card-count">1 component</div>
      </a>

      <a href="/showcase/body-column" class="lib-card">
        <div class="lib-card-accent lib-card-accent-pink"></div>
        <div class="lib-card-title">Body Column</div>
        <div class="lib-card-count">6 components</div>
      </a>

      <a href="/showcase/mind-column" class="lib-card">
        <div class="lib-card-accent lib-card-accent-green"></div>
        <div class="lib-card-title">Mind Column</div>
        <div class="lib-card-count">4 components</div>
      </a>

    </div>
  </main>
</Showcase>
