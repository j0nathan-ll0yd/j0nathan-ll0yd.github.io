---
import Showcase from '../layouts/Showcase.astro';

const pages = [
  {
    id: 'glitch-protocol',
    name: 'Glitch Protocol',
    file: '/previews/404-1-glitch-protocol.html',
    accent: 'red',
    description: 'CSS RGB channel-split glitch on the "404" numerals with drifting scanline overlay. Pure CSS animation.',
    features: ['RGB split glitch', 'Scanline overlay', 'Character flicker', 'Pure CSS'],
  },
  {
    id: 'terminal-traceroute',
    name: 'Terminal Traceroute',
    file: '/previews/404-2-terminal-traceroute.html',
    accent: 'green',
    description: 'Green-on-black terminal simulating a traceroute command where hops progressively time out. Typewriter text reveal with blinking cursor.',
    features: ['Typewriter effect', 'Terminal chrome', 'Blinking cursor', 'CRT text glow'],
  },
  {
    id: 'radar-sweep',
    name: 'Radar Sweep',
    file: '/previews/404-3-radar-sweep.html',
    accent: 'cyan',
    description: 'SVG circular radar display with rotating sweep line and momentary contact blips. Military-style HUD aesthetic.',
    features: ['SVG radar', 'Rotating sweep', 'Contact blips', 'Compass markings'],
  },
  {
    id: 'matrix-rain',
    name: 'Matrix Rain',
    file: '/previews/404-4-matrix-rain.html',
    accent: 'green',
    description: 'Canvas-based falling character rain that periodically coalesces to form "404" before dissolving back into rain.',
    features: ['Canvas animation', 'Katakana characters', '404 formation', 'Trail effect'],
  },
  {
    id: 'heartbeat-flatline',
    name: 'Heartbeat Flatline',
    file: '/previews/404-5-heartbeat-flatline.html',
    accent: 'amber',
    description: 'ECG monitor with PQRST heartbeat waveform that flatlines after several beats. BPM counter drops from 72 to 0.',
    features: ['SVG ECG trace', 'BPM counter', 'Flatline animation', 'Status transition'],
  },
  {
    id: 'asteroid-field',
    name: 'Asteroid Field',
    file: '/previews/404-6-asteroid-field.html',
    accent: 'blue',
    description: 'ASCII asteroids drifting through a star field with a cursor-following ship character. Interactive navigation error.',
    features: ['Cursor tracking', 'ASCII asteroids', 'Star parallax', 'Touch support'],
  },
  {
    id: 'corrupted-transmission',
    name: 'Corrupted Transmission',
    file: '/previews/404-7-corrupted-transmission.html',
    accent: 'orange',
    description: 'VHS tracking distortion with CRT curved edges, static noise, and garbled text that periodically resolves. SMPTE color bars flash.',
    features: ['VHS tracking', 'CRT curvature', 'Static noise', 'Color bar flash'],
  },
  {
    id: 'black-hole',
    name: 'Black Hole',
    file: '/previews/404-8-black-hole.html',
    accent: 'purple',
    description: 'The "0" in 404 is a spinning vortex with particles spiraling inward and accretion disk rings. Gravitational typography.',
    features: ['Spiral particles', 'Accretion disk', 'Gravitational type', 'Star field'],
  },
  {
    id: 'system-reboot',
    name: 'System Reboot',
    file: '/previews/404-9-system-reboot.html',
    accent: 'cyan',
    description: 'Fake BIOS boot sequence with memory check, sector scan, and BAD SECTOR 404 error. Interactive Y/N reboot prompt.',
    features: ['BIOS sequence', 'Memory counter', 'Sector scan', 'Y/N prompt'],
  },
  {
    id: 'ghost-in-the-machine',
    name: 'Ghost in the Machine',
    file: '/previews/404-10-ghost-in-the-machine.html',
    accent: 'indigo',
    description: 'Translucent CSS ghost shape phasing in and out with floating particle dust. Ethereal interdimensional error message.',
    features: ['CSS ghost shape', 'Phase animation', 'Floating particles', 'Watermark 404'],
  },
];
---
<Showcase title="404 Pages">
  <main class="lib-container">
    <h1 class="lib-page-title">404 Page Variations</h1>
    <p class="lib-page-desc">
      Ten creative 404 page designs for the Human Datastream. All are self-contained HTML, ES5 IIFE-wrapped, and respect <code>prefers-reduced-motion</code>. Pick your favorite(s) to inline into the production 404 page.
    </p>

    <div class="fso-nav" data-group="pages">
      {pages.map((p, i) => (
        <button
          class:list={['fso-nav-btn', `fso-nav-btn-${p.accent}`, { active: i === 0 }]}
          data-target={p.id}
        >
          {p.name}
        </button>
      ))}
    </div>

    <div class="fso-panel-group" data-group="pages">
      {pages.map((p, i) => (
        <div class:list={['fso-panel', { active: i === 0 }]} id={`panel-${p.id}`}>
          <div class="component-section">
            <div class="component-name">{p.name}</div>
            <div class="component-description">{p.description}</div>
            <div class="component-classes">
              {p.features.map((f, fi) => (
                <Fragment>
                  {fi > 0 && ', '}
                  {f}
                </Fragment>
              ))}
            </div>

            <div class="fso-preview-frame">
              <div class="fso-preview-bar">
                <div class="fso-preview-dots">
                  <span class="fso-dot fso-dot-red"></span>
                  <span class="fso-dot fso-dot-amber"></span>
                  <span class="fso-dot fso-dot-green"></span>
                </div>
                <span class="fso-preview-title">{p.name}</span>
                <a href={p.file} target="_blank" class="fso-open-link">Open ↗</a>
              </div>
              <iframe
                src={p.file}
                class="fso-iframe"
                title={`${p.name} 404 page preview`}
                loading={i === 0 ? 'eager' : 'lazy'}
              ></iframe>
            </div>
          </div>
        </div>
      ))}
    </div>

    <h2 class="lib-section-title">Shared Behavior</h2>
    <div class="component-section">
      <div class="component-description">
        All ten variations share a common contract:
      </div>
      <table class="fso-spec-table">
        <thead>
          <tr><th>Property</th><th>Value</th></tr>
        </thead>
        <tbody>
          <tr><td>Position</td><td>Standalone HTML, centered content</td></tr>
          <tr><td>Background</td><td><code>#06060f</code> (matches page bg)</td></tr>
          <tr><td>Font</td><td>Space Grotesk (self-hosted, inline <code>@font-face</code>)</td></tr>
          <tr><td>JS style</td><td>ES5, IIFE-wrapped, no build step</td></tr>
          <tr><td>a11y</td><td><code>prefers-reduced-motion: reduce</code> disables animations</td></tr>
          <tr><td>Return link</td><td>Fixed bottom-center link back to <code>/</code></td></tr>
          <tr><td>Responsive</td><td>Adapts to 1400px, 900px, 600px widths</td></tr>
        </tbody>
      </table>
    </div>
  </main>
</Showcase>

<style>
  /* ── Tab navigation ── */
  .fso-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
  }
  .fso-nav-btn {
    padding: 6px 16px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .fso-nav-btn:hover { background: rgba(255, 255, 255, 0.06); }
  .fso-nav-btn.active.fso-nav-btn-red    { border-color: var(--neon-red);    color: var(--neon-red);    background: rgba(239, 68, 68, 0.08); }
  .fso-nav-btn.active.fso-nav-btn-amber  { border-color: var(--neon-amber);  color: var(--neon-amber);  background: rgba(245, 158, 11, 0.08); }
  .fso-nav-btn.active.fso-nav-btn-green  { border-color: var(--neon-green);  color: var(--neon-green);  background: rgba(6, 214, 160, 0.08); }
  .fso-nav-btn.active.fso-nav-btn-purple { border-color: var(--neon-purple); color: var(--neon-purple); background: rgba(168, 85, 247, 0.08); }
  .fso-nav-btn.active.fso-nav-btn-blue   { border-color: var(--neon-blue);   color: var(--neon-blue);   background: rgba(58, 134, 255, 0.08); }
  .fso-nav-btn.active.fso-nav-btn-cyan   { border-color: var(--neon-cyan);   color: var(--neon-cyan);   background: rgba(0, 212, 255, 0.08); }
  .fso-nav-btn.active.fso-nav-btn-orange { border-color: var(--neon-orange); color: var(--neon-orange); background: rgba(255, 107, 0, 0.08); }
  .fso-nav-btn.active.fso-nav-btn-indigo { border-color: var(--neon-indigo); color: var(--neon-indigo); background: rgba(129, 140, 248, 0.08); }

  /* ── Panels ── */
  .fso-panel { display: none; }
  .fso-panel.active { display: block; }

  /* ── Preview frame (browser chrome) ── */
  .fso-preview-frame {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
    margin-top: 16px;
  }
  .fso-preview-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .fso-preview-dots { display: flex; gap: 6px; }
  .fso-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .fso-dot-red   { background: #ef4444; }
  .fso-dot-amber { background: #f59e0b; }
  .fso-dot-green { background: #06d6a0; }
  .fso-preview-title {
    flex: 1;
    text-align: center;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .fso-open-link {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .fso-open-link:hover { opacity: 1; }

  /* ── Iframe ── */
  .fso-iframe {
    width: 100%;
    height: 560px;
    border: none;
    background: #06060f;
  }

  /* ── Spec table ── */
  .fso-spec-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.72rem;
    margin-top: 12px;
  }
  .fso-spec-table th,
  .fso-spec-table td {
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .fso-spec-table th {
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .fso-spec-table td { color: var(--text); }
  .fso-spec-table code {
    font-size: 0.65rem;
    padding: 1px 5px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--neon-cyan);
  }

  @media (max-width: 600px) {
    .fso-iframe { height: 420px; }
    .fso-nav-btn { font-size: 0.6rem; padding: 5px 12px; }
  }
</style>

<script is:inline>
(function() {
  var navs = document.querySelectorAll('.fso-nav[data-group]');
  for (var g = 0; g < navs.length; g++) {
    var nav = navs[g];
    var groupName = nav.getAttribute('data-group');
    var buttons = nav.querySelectorAll('.fso-nav-btn');
    var panelGroup = document.querySelector('.fso-panel-group[data-group="' + groupName + '"]');
    if (!panelGroup) continue;
    var panels = panelGroup.querySelectorAll('.fso-panel');

    for (var i = 0; i < buttons.length; i++) {
      (function(btn, groupButtons, groupPanels) {
        btn.addEventListener('click', function() {
          var target = btn.getAttribute('data-target');
          for (var j = 0; j < groupButtons.length; j++) {
            groupButtons[j].classList.remove('active');
          }
          for (var k = 0; k < groupPanels.length; k++) {
            groupPanels[k].classList.remove('active');
          }
          btn.classList.add('active');
          var panel = document.getElementById('panel-' + target);
          if (panel) panel.classList.add('active');
        });
      })(buttons[i], buttons, panels);
    }
  }
})();
</script>
