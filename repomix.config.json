{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "style": "xml",
    "filePath": "repomix-output.xml",
    "headerText": "Human Datastream — Astro 5.x personal portfolio dashboard by Jonathan Lloyd (jonathanlloyd.me)",
    "instructionFilePath": "repomix-prompt.md",
    "showLineNumbers": false,
    "removeComments": false,
    "compress": false,
    "topFilesLength": 10,
    "git": {
      "sortByChanges": false
    }
  },
  "tokenCount": {
    "encoding": "cl100k_base"
  },
  "include": [
    "CLAUDE.md",
    "AGENTS.md",
    ".editorconfig",
    "astro.config.mjs",
    "package.json",
    "tsconfig.json",
    "src/env.d.ts",
    "src/types/exports.ts",
    "src/lib/constants.ts",
    "src/lib/image-utils.ts",
    "public/css/tokens.css",
    "public/llms.txt",
    "public/manifest.webmanifest",
    "src/layouts/*.astro",
    "src/pages/*.astro",
    "src/lib/api.ts",
    "src/lib/adapters.ts",
    "src/lib/updaters.ts",
    "src/lib/updaters-status.ts",
    "src/lib/updaters-theatre.ts",
    "src/lib/updaters-focus.ts",
    "src/lib/poll-engine.ts",
    "src/lib/ws-client.ts",
    "src/lib/heart-rate.ts",
    "src/lib/sleep.ts",
    "src/scripts/*.ts",
    "public/css/base.css",
    "public/css/effects.css",
    "public/css/components.css",
    "src/styles/layout.css",
    "src/components/*.astro",
    "src/components/github/*.astro",
    "src/components/location/*.astro",
    "data/profile.json",
    "data/health.json",
    "data/github.json",
    "data/books.json",
    "data/reading.json",
    "data/system.json",
    "docs/wiki/Astro-Implementation.md",
    "docs/wiki/Brand-Guide.md",
    ".github/workflows/deploy.yml",
    ".github/workflows/sync-wiki.yml",
    "scripts/*.mjs",
    "scripts/*.sh"
  ],
  "ignore": {
    "customPatterns": [
      "src/showcase/**",
      "previews/**",
      "src/components/github/*.query.ts",
      "src/lib/updaters-odometer-variations.ts",
      "src/lib/updaters-leaderboard-variations.ts",
      "README.md",
      "docs/wiki/Home.md",
      "docs/wiki/Why-Astro.md",
      "public/vendor/**",
      "public/fonts/**",
      "public/images/**",
      "public/assets/**",
      "package-lock.json",
      "data/showcase-empty.json",
      "data/theatre-reviews-sample.json",
      "repomix-output.xml",
      "repomix-lean-output.xml"
    ]
  }
}
