{
  "name": "human-datastream",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "generate:fixtures": "npx tsx test/fixtures/generate.ts",
    "validate:fixtures": "npx tsx test/fixtures/validate.ts",
    "generate:types": "node scripts/generate-types.mjs && npm run validate:fixtures --if-present",
    "fetch:images": "node scripts/fetch-images.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:build": "vitest run --config vitest.build.config.ts",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "test:visual:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@playwright/test": "^1.58.2",
    "@vite-pwa/astro": "^1.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "ajv": "^8.18.0",
    "cheerio": "^1.2.0",
    "jsdom": "^29.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
